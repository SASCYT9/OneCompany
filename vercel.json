{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["fra1"],
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"master\" ]; then exit 1; else exit 0; fi",
  "git": {
    "deploymentEnabled": {
      "archive/promotions-2026-03": false,
      "archive/stash-admin-redesign-2025-11": false,
      "archive/stash-urban-grid-2026-03": false,
      "archive/stash-wiki-changelog-2026-04": false,
      "release-please--branches--master--components--onecompany": false
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.onecompany.global"
        }
      ],
      "destination": "https://onecompany.global/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/telegram/webhook",
      "destination": "/api/telegram/webhook-grammy"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/warmup-shop",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/shop-knowledge",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/shop-ai-retention",
      "schedule": "17 3 * * *"
    }
  ]
}
