{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "regions": ["fra1"],
  "ignoreCommand": "if [ \"${VERCEL_GIT_COMMIT_REF#archive/}\" != \"$VERCEL_GIT_COMMIT_REF\" ]; then echo 'Skipping build for archive branch'; exit 0; else exit 1; fi",
  "git": {
    "deploymentEnabled": {
      "archive/promotions-2026-03": false,
      "archive/stash-admin-redesign-2025-11": false,
      "archive/stash-urban-grid-2026-03": false,
      "archive/stash-wiki-changelog-2026-04": false
    }
  },
  "rewrites": [
    {
      "source": "/api/telegram/webhook",
      "destination": "/api/telegram/webhook-grammy"
    }
  ],
  "crons": [
    {
      "path": "/api/telegram/cron?task=all",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/cron/atomic-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin/cron/airtable-stocks",
      "schedule": "0 * * * *"
    }
  ]
}
