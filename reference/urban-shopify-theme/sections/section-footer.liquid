{%- style -%}

/* ── Reset & base ── */
.uf {
  --ff-display: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
  --ff-body: 'Sora', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --c-black: #0a0a0a;
  --c-dark: #111;
  --c-grey-1: #141414;
  --c-grey-2: #1e1e1e;
  --c-grey-3: #2a2a2a;
  --c-white: #f5f5f3;
  --ease-expo: cubic-bezier(.16,1,.3,1);
  background: var(--c-black) !important;
  color: var(--c-white);
  font-family: var(--ff-body);
  position: relative;
  overflow: hidden;
  border: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
}
.uf *, .uf *::before, .uf *::after { box-sizing: border-box; }

/* ── Decorative top border ── */
.uf__border-top {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,245,243,.12) 30%, rgba(245,245,243,.12) 70%, transparent);
}

/* ── Top accent strip ── */
.uf__accent {
  padding: clamp(50px,6vw,80px) 0 0;
  text-align: center;
}
.uf__accent-rule {
  width: 1px; height: 50px; margin: 0 auto 24px;
  background: linear-gradient(180deg, transparent, rgba(245,245,243,.2));
}
.uf__accent-text {
  font-family: var(--ff-body);
  font-size: clamp(9px,1vw,11px);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .3em;
  color: rgba(245,245,243,.35);
}

/* ── Main grid ── */
.uf__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: clamp(48px,6vw,80px) clamp(20px,4vw,60px) 0;
}
.uf__grid {
  display: grid;
  grid-template-columns: 1.4fr repeat(4, 1fr);
  gap: clamp(30px,4vw,64px);
}

/* ── Brand column ── */
.uf__brand { display: flex; flex-direction: column; gap: 28px; }
.uf__logo { display: block; max-width: 180px; transition: opacity .3s ease; }
.uf__logo:hover { opacity: .7; }
.uf__logo img {
  width: 180px; height: auto; display: block;
  filter: brightness(1.1);
}
.uf__logo-fallback {
  font-family: var(--ff-display);
  font-size: 22px; font-weight: 300;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--c-white);
  display: block; width: 180px;
}
.uf__brand-desc {
  font-size: 13px; line-height: 1.7;
  color: rgba(245,245,243,.45);
  max-width: 280px;
}

/* Social icons row */
.uf__socials {
  display: flex; gap: 10px; flex-wrap: wrap;
}
.uf__social-link {
  display: flex; align-items: center; justify-content: center;
  width: 40px; height: 40px;
  border: 1px solid rgba(245,245,243,.1);
  border-radius: 50%;
  color: rgba(245,245,243,.5);
  text-decoration: none;
  transition: all .35s var(--ease-expo);
}
.uf__social-link:hover {
  border-color: rgba(245,245,243,.35);
  color: var(--c-white);
  transform: translateY(-2px);
}
.uf__social-link svg {
  width: 16px; height: 16px; fill: currentColor;
}

/* Address card */
.uf__address {
  font-size: 13px; line-height: 1.7;
  color: rgba(245,245,243,.5);
  padding: 16px 18px;
  border-left: 1px solid rgba(245,245,243,.12);
  max-width: 260px;
}
.uf__address-icon {
  display: inline-block; margin-right: 4px;
  font-style: normal; opacity: .6;
}

/* ── Navigation columns ── */
.uf__col-title {
  font-family: var(--ff-display);
  font-size: clamp(16px,1.4vw,20px);
  font-weight: 400;
  letter-spacing: .06em;
  color: var(--c-white);
  margin: 0 0 20px;
  position: relative;
  padding-bottom: 14px;
}
.uf__col-title::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 24px; height: 1px;
  background: rgba(245,245,243,.2);
  transition: width .4s var(--ease-expo);
}
.uf__col:hover .uf__col-title::after {
  width: 48px;
  background: rgba(245,245,243,.4);
}
.uf__nav {
  list-style: none;
  margin: 0; padding: 0;
}
.uf__nav li { margin-bottom: 10px; }
.uf__nav a {
  font-size: 13px; line-height: 1.5;
  color: rgba(245,245,243,.45);
  text-decoration: none;
  transition: all .3s ease;
  position: relative;
  display: inline-block;
}
.uf__nav a::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0;
  width: 0; height: 1px;
  background: rgba(245,245,243,.3);
  transition: width .35s var(--ease-expo);
}
.uf__nav a:hover {
  color: var(--c-white);
  transform: translateX(3px);
}
.uf__nav a:hover::after { width: 100%; }
.uf__nav-copy {
  font-size: 12px;
  color: rgba(245,245,243,.2);
  margin-bottom: 12px;
  padding: 0;
  list-style: none;
}

/* ── Bottom bar ── */
.uf__bottom {
  max-width: 1400px;
  margin: clamp(48px,6vw,80px) auto 0;
  padding: clamp(20px,3vw,28px) clamp(20px,4vw,60px) clamp(24px,3vw,32px);
  border-top: 1px solid rgba(245,245,243,.06);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.uf__powered {
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(245,245,243,.15);
  font-family: var(--ff-body);
}
.uf__powered a {
  color: rgba(245,245,243,.25);
  text-decoration: none;
  transition: color .3s ease;
}
.uf__powered a:hover { color: rgba(245,245,243,.55); }

/* ── Subtle grain overlay ── */
.uf__grain {
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.025'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 0;
}
.uf__content { position: relative; z-index: 1; }

/* ── Mobile ── */
@media (max-width: 1024px) {
  .uf__grid {
    grid-template-columns: 1fr 1fr;
    gap: 40px 30px;
  }
  .uf__brand { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .uf__grid {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 36px;
  }
  .uf__brand { align-items: center; }
  .uf__brand-desc { max-width: 100%; text-align: center; }
  .uf__logo { margin: 0 auto; }
  .uf__socials { justify-content: center; }
  .uf__address {
    border-left: 0;
    border-top: 1px solid rgba(245,245,243,.08);
    padding: 16px 0 0; margin: 0 auto;
    text-align: center; max-width: 100%;
  }
  .uf__col-title { text-align: center; }
  .uf__col-title::after { left: 50%; transform: translateX(-50%); }
  .uf__nav { text-align: center; }
  .uf__nav a:hover { transform: none; }
  .uf__bottom { flex-direction: column; gap: 8px; }
}

{%- endstyle -%}

