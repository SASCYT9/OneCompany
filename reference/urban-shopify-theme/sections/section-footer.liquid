    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="uf__bottom">
      <span class="uf__powered">Powered by <a href="https://onecompany.global/" target="_blank" rel="noopener">One Company</a></span>
    </div>
  </div>
</footer>
