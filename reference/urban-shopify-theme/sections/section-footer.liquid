        </div>

        {%- comment -%} Support {%- endcomment -%}
        <div class="uf__col">
          <h3 class="uf__col-title">{{ support_title }}</h3>
          <ul class="uf__nav">
            <li><a href="/pages/contact">{{ support_contact }}</a></li>
          </ul>
