        {%- comment -%} Company {%- endcomment -%}
        <div class="uf__col">
          <h3 class="uf__col-title">{{ about_title }}</h3>
          <ul class="uf__nav">
            <li><a href="/pages/about-us">{{ about_info }}</a></li>
            <li><a href="/pages/faq">{{ about_faq }}</a></li>
            <li><a href="/blogs/news">{{ about_blog }}</a></li>
