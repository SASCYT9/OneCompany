            <li><a href="/pages/public-offer">{{ legal_offer }}</a></li>
            <li><a href="/policies/privacy-policy">{{ legal_privacy }}</a></li>
            <li><a href="/policies/refund-policy">{{ legal_refund }}</a></li>
            <li><a href="/policies/terms-of-service">{{ legal_terms }}</a></li>
