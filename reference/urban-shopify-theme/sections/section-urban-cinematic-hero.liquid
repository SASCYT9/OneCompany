{%- assign is_uk = false -%}
{%- if request.locale.iso_code == 'uk' -%}{%- assign is_uk = true -%}{%- endif -%}

{% liquid
  assign hero_id = 'UrbanHero-' | append: section.id
  assign has_upload_video = false
  if section.settings.video != blank
    assign has_upload_video = true
  endif

  assign has_embed_video = false
  if section.settings.external_video_embed_url != blank
    assign has_embed_video = true
  endif

  assign has_direct_video = false
  if section.settings.external_video_url != blank
    assign has_direct_video = true
  endif

  assign direct_video_url = section.settings.external_video_url | strip
  if has_direct_video and direct_video_url != blank
    if direct_video_url contains '://'
      assign direct_video_url = direct_video_url
    else
      assign direct_video_url = direct_video_url | file_url
    endif
  endif

  assign external_poster_url = section.settings.external_poster_url | strip
  assign resolved_external_poster_url = ''
  if external_poster_url != blank
    if external_poster_url contains '://'
      assign resolved_external_poster_url = external_poster_url
    else
      assign resolved_external_poster_url = external_poster_url | file_url
    endif
  endif

  assign loader_logo_url = section.settings.loader_logo_url | strip
  assign resolved_loader_logo_url = ''
  if loader_logo_url != blank
    if loader_logo_url contains '://'
      assign resolved_loader_logo_url = loader_logo_url
    else
      assign resolved_loader_logo_url = loader_logo_url | file_url
    endif
  endif

  assign embed_url = section.settings.external_video_embed_url
  if has_embed_video
    if embed_url contains '?'
      assign embed_url = embed_url | append: '&autoplay=1&mute=1&loop=1&background=1&playsinline=1'
    else
      assign embed_url = embed_url | append: '?autoplay=1&mute=1&loop=1&background=1&playsinline=1'
    endif
  endif
%}

<section
  id="{{ hero_id }}"
  class="urban-hero"
  data-enable-loader="{{ section.settings.enable_loader }}"
  data-scroll-target="{{ section.settings.scroll_target | escape }}"
>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;600&display=swap');

    .section-urban-cinematic-hero {
      position: relative;
      z-index: 1;
    }

    #{{ hero_id }} {
      --urban-overlay-alpha: {{ section.settings.overlay_opacity | times: 0.01 }};
      --urban-loader-bg: {{ section.settings.loader_background }};
      --urban-hero-height-mobile: {{ section.settings.mobile_height }}svh;
      --urban-hero-height-desktop: {{ section.settings.desktop_height }}svh;
      --urban-accent: {{ section.settings.accent_color }};
      position: relative;
      min-height: var(--urban-hero-height-mobile);
      color: #fff;
      overflow: hidden;
      background: #000;
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    @media (min-width: 990px) {
      #{{ hero_id }} {
        min-height: var(--urban-hero-height-desktop);
      }
    }

    #{{ hero_id }} .urban-hero__media {
      position: absolute;
      inset: 0;
      z-index: 1;
      transform: scale(1.08);
      transition: transform 9s ease-out;
    }

    #{{ hero_id }}.is-loaded .urban-hero__media {
      transform: scale(1);
    }

    #{{ hero_id }} .urban-hero__video,
    #{{ hero_id }} .urban-hero__iframe,
    #{{ hero_id }} .urban-hero__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border: 0;
    }

    #{{ hero_id }} .urban-hero__iframe {
      position: absolute;
      inset: 50% auto auto 50%;
      width: 100vw;
      height: 56.25vw;
      min-height: 100%;
      min-width: 177.8vh;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    @media (max-width: 749px) {
      #{{ hero_id }} .urban-hero__iframe {
        width: 300%;
        height: 100%;
        min-width: 300%;
        min-height: 100%;
      }
    }

    #{{ hero_id }} .urban-hero__overlay {
      position: absolute;
      inset: 0;
      z-index: 2;
      background:
        radial-gradient(circle at center, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.58) 55%, rgba(0, 0, 0, 0.88) 100%),
        rgba(0, 0, 0, var(--urban-overlay-alpha));
    }

    #{{ hero_id }} .urban-hero__shutter {
      position: absolute;
      inset: 0;
      z-index: 4;
      background: #000;
      transform: translate3d(0, 0, 0);
      transition: transform 1.15s cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
      pointer-events: none;
    }

    #{{ hero_id }}.is-loaded .urban-hero__shutter {
      transform: translate3d(0, -105%, 0);
    }

    #{{ hero_id }} .urban-hero__content {
      position: relative;
      z-index: 5;
      min-height: inherit;
      display: grid;
      place-items: center;
      text-align: center;
      padding: clamp(24px, 3vw, 48px);
    }

    #{{ hero_id }} .urban-hero__caption {
      width: min(92vw, 840px);
      transform: translate3d(0, 42px, 0);
      opacity: 0;
      transition: transform 0.9s ease, opacity 0.9s ease;
      transition-delay: 0.2s;
    }

    #{{ hero_id }}.is-loaded .urban-hero__caption {
      transform: translate3d(0, 0, 0);
      opacity: 1;
    }

    #{{ hero_id }} .urban-hero__eyebrow {
      font-size: clamp(12px, 1.1vw, 15px);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin: 0 0 14px;
      opacity: 0.88;
      font-weight: 500;
    }

    #{{ hero_id }} .urban-hero__title {
      margin: 0;
      text-transform: uppercase;
      font-size: clamp(34px, 8.8vw, 118px);
      line-height: 0.94;
      letter-spacing: 0.06em;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-weight: 500;
      text-wrap: balance;
    }

    #{{ hero_id }} .urban-hero__subtitle {
      margin: 18px auto 0;
      max-width: 70ch;
      font-size: clamp(14px, 1.35vw, 20px);
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.8);
      text-wrap: pretty;
    }

    #{{ hero_id }} .urban-hero__button {
      margin-top: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #fff;
      color: #101010;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      padding: 12px 24px;
      font-size: 12px;
      font-weight: 700;
      border: 1px solid #fff;
      transition: transform 0.28s ease, background 0.28s ease, color 0.28s ease;
    }

    #{{ hero_id }} .urban-hero__button:hover {
      transform: translateY(-2px);
      background: transparent;
      color: #fff;
    }

    #{{ hero_id }} .urban-hero__scroll {
      position: absolute;
      left: 18px;
      bottom: 14px;
      z-index: 5;
      width: 40px;
      height: 40px;
      border: 1px solid rgba(255, 255, 255, 0.45);
      background: rgba(0, 0, 0, 0.35);
      color: #fff;
      cursor: pointer;
      transform: rotate(90deg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.25s ease, transform 0.25s ease;
    }

    #{{ hero_id }} .urban-hero__scroll:hover {
      background: rgba(255, 255, 255, 0.14);
      transform: rotate(90deg) translateX(2px);
    }

    #{{ hero_id }} .urban-hero__loader {
      position: absolute;
      inset: 0;
      z-index: 10;
      background: var(--urban-loader-bg);
      display: grid;
      place-items: center;
      transition: opacity 0.35s ease;
    }

    #{{ hero_id }}.is-loaded .urban-hero__loader {
      opacity: 0;
      pointer-events: none;
    }

    #{{ hero_id }} .urban-hero__loader-mark {
      width: min(72vw, 340px);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding-bottom: 24px;
    }

    #{{ hero_id }} .urban-hero__loader-mark img {
      width: 100%;
      height: auto;
      display: block;
    }

    #{{ hero_id }} .urban-hero__loader-mark span {
      color: #fff;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-size: clamp(26px, 5vw, 54px);
      letter-spacing: 0.26em;
      text-transform: uppercase;
    }

    #{{ hero_id }} .urban-hero__loader-mark::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 0;
      height: 2px;
      width: 100%;
      transform-origin: left center;
      background: linear-gradient(90deg, #fff 0%, var(--urban-accent) 100%);
      animation: urban-loader-line-{{ section.id }} 1.3s linear infinite;
    }

    @keyframes urban-loader-line-{{ section.id }} {
      0% { transform: scaleX(0.08); opacity: 0.55; }
      50% { transform: scaleX(1); opacity: 1; }
      100% { transform: scaleX(0.08); opacity: 0.55; }
    }

    #{{ hero_id }}.skip-loader .urban-hero__loader {
      display: none;
    }

    @media (max-width: 749px) {
      #{{ hero_id }} .urban-hero__subtitle {
        max-width: 36ch;
      }

      #{{ hero_id }} .urban-hero__eyebrow {
        letter-spacing: 0.15em;
      }

      #{{ hero_id }} .urban-hero__button {
        letter-spacing: 0.16em;
        padding: 11px 18px;
        font-size: clamp(10px, 1vw, 12px);
      }

      #{{ hero_id }} .urban-hero__loader-mark {
        letter-spacing: 0.1em;
      }

      #{{ hero_id }} .urban-hero__scroll {
        left: 10px;
        bottom: 8px;
      }
    }

    #{{ hero_id }} .urban-hero__title,
    #{{ hero_id }} .urban-hero__subtitle {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ hero_id }} .urban-hero__media,
      #{{ hero_id }} .urban-hero__caption,
      #{{ hero_id }} .urban-hero__shutter {
        transition: none;
      }
    }
  </style>

  <div class="urban-hero__media">
    {% if has_upload_video %}
      <video
        class="urban-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        {% if section.settings.poster_image != blank %}
          poster="{{ section.settings.poster_image | image_url: width: 2400 }}"
        {% endif %}
      >
        {% for source in section.settings.video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif has_embed_video %}
      <iframe
        class="urban-hero__iframe"
        src="{{ embed_url }}"
        title="{{ section.settings.title | escape }}"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    {% elsif has_direct_video %}
      <video
        class="urban-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        {% if section.settings.poster_image != blank %}
          poster="{{ section.settings.poster_image | image_url: width: 2400 }}"
        {% elsif resolved_external_poster_url != blank %}
          poster="{{ resolved_external_poster_url }}"
        {% endif %}
      >
        <source src="{{ direct_video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.poster_image != blank %}
      <img
        class="urban-hero__image"
        src="{{ section.settings.poster_image | image_url: width: 2800 }}"
        alt="{{ section.settings.poster_image.alt | default: section.settings.title | escape }}"
        width="{{ section.settings.poster_image.width }}"
        height="{{ section.settings.poster_image.height }}"
        loading="lazy"
      >
    {% elsif section.settings.external_poster_url != blank %}
      <img
        class="urban-hero__image"
        src="{{ resolved_external_poster_url }}"
        alt="{{ section.settings.title | escape }}"
        loading="lazy"
      >
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'urban-hero__image' }}
    {% endif %}
  </div>

  <div class="urban-hero__overlay"></div>
  <div class="urban-hero__shutter"></div>

  <div class="urban-hero__content">
    <div class="urban-hero__caption">
      {% if section.settings.eyebrow != blank %}
        <p class="urban-hero__eyebrow">{% if is_uk and section.settings.eyebrow_uk != blank %}{{ section.settings.eyebrow_uk }}{% else %}{{ section.settings.eyebrow }}{% endif %}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="urban-hero__title">{% if is_uk and section.settings.title_uk != blank %}{{ section.settings.title_uk }}{% else %}{{ section.settings.title }}{% endif %}</h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="urban-hero__subtitle">{% if is_uk and section.settings.subtitle_uk != blank %}{{ section.settings.subtitle_uk }}{% else %}{{ section.settings.subtitle }}{% endif %}</p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a
          class="urban-hero__button"
          href="{{ section.settings.button_link }}"
          {% if section.settings.button_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {% if is_uk and section.settings.button_label_uk != blank %}{{ section.settings.button_label_uk }}{% else %}{{ section.settings.button_label }}{% endif %}
        </a>
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_scroll_button %}
    <button class="urban-hero__scroll" type="button" aria-label="{% if is_uk %}Перейти до наступної секції{% else %}Scroll to next section{% endif %}">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
        <path d="M6 12h11M13 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {% endif %}

  <div class="urban-hero__loader" aria-hidden="true">
    <div class="urban-hero__loader-mark">
      {% if resolved_loader_logo_url != blank %}
        <img src="{{ resolved_loader_logo_url }}" alt="One Company" width="422" height="155" loading="eager">
      {% else %}
        <span>{{ section.settings.loader_text }}</span>
      {% endif %}
    </div>
  </div>

  <script>
    (() => {
      const root = document.getElementById('{{ hero_id }}');
      if (!root || root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const seenKey = 'urban-cinematic-hero-seen-v1';
      const allowLoader = root.dataset.enableLoader === 'true' && !reduceMotion;
      const storage = (() => {
        try {
          return window.sessionStorage;
        } catch (error) {
          return null;
        }
      })();
      const hasSeen = storage ? storage.getItem(seenKey) === '1' : false;
      const shouldSkipLoader = !allowLoader || hasSeen;

      const reveal = () => {
        root.classList.add('is-loaded');
        if (storage) storage.setItem(seenKey, '1');
      };

      if (shouldSkipLoader) {
        root.classList.add('skip-loader');
        reveal();
      } else if (document.readyState === 'complete') {
        setTimeout(reveal, 220);
      } else {
        window.addEventListener('load', () => setTimeout(reveal, 220), { once: true });
        setTimeout(reveal, 1800);
      }

      const scrollButton = root.querySelector('.urban-hero__scroll');
      if (!scrollButton) return;

      scrollButton.addEventListener('click', () => {
        const targetSelector = root.dataset.scrollTarget;
        const target = targetSelector ? document.querySelector(targetSelector) : null;

        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          return;
        }

        window.scrollBy({ top: Math.max(window.innerHeight * 0.85, 420), behavior: 'smooth' });
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Urban Cinematic Hero",
  "tag": "section",
  "class": "section section-urban-cinematic-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "One Company x Urban Automotive"
    },
    {
      "type": "text",
      "id": "eyebrow_uk",
      "label": "Eyebrow (UK)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Road Presence Redefined"
    },
    {
      "type": "text",
      "id": "title_uk",
      "label": "Title (UK)"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Bespoke styling packages for luxury automotive brands."
    },
    {
      "type": "textarea",
      "id": "subtitle_uk",
      "label": "Subtitle (UK)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "text",
      "id": "button_label_uk",
      "label": "Button label (UK)"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_new_tab",
      "label": "Open button in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Video and media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Uploaded video (Shopify file)"
    },
    {
      "type": "text",
      "id": "external_video_embed_url",
      "label": "External video embed URL",
      "info": "Example: https://player.vimeo.com/video/123456789"
    },
    {
      "type": "text",
      "id": "external_video_url",
      "label": "External direct video URL",
      "info": "MP4 URL or Shopify Files filename, for example hero-video.mp4"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster / fallback image"
    },
    {
      "type": "text",
      "id": "external_poster_url",
      "label": "External poster image URL"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "enable_loader",
      "label": "Enable intro loader animation",
      "default": true
    },
    {
      "type": "text",
      "id": "loader_text",
      "label": "Loader text",
      "default": "ONE COMPANY"
    },
    {
      "type": "text",
      "id": "loader_logo_url",
      "label": "Loader logo URL",
      "default": "https://onecompany.global/branding/logo-light.svg",
      "info": "External URL or Shopify Files filename."
    },
    {
      "type": "checkbox",
      "id": "show_scroll_button",
      "label": "Show scroll button",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_target",
      "label": "Scroll target selector",
      "default": "#MainContent",
      "info": "Example: #main or #MainContent"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "loader_background",
      "label": "Loader background",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Urban Cinematic Hero"
    }
  ]
}
{% endschema %}
