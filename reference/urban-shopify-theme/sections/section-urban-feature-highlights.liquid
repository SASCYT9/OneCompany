{% liquid
  assign features_id = 'UrbanFeatures-' | append: section.id
  assign is_uk = false
  if request.locale and request.locale.iso_code
    if request.locale.iso_code contains 'uk'
      assign is_uk = true
    endif
  endif
%}

<section id="{{ features_id }}" class="urban-features">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;600&display=swap');

    #{{ features_id }} {
      --feat-bg: {{ section.settings.background_color }};
      --feat-border: {{ section.settings.border_color }};
      --feat-copy: {{ section.settings.copy_color }};
      background: var(--feat-bg);
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #fff;
    }

    #{{ features_id }} .urban-features__header {
      max-width: min(1600px, 92vw);
      margin: 0 auto clamp(24px, 4vw, 52px);
      padding: 0 clamp(16px, 2vw, 24px);
      text-align: center;
    }

    #{{ features_id }} .urban-features__eyebrow {
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-size: clamp(10px, 0.9vw, 12px);
      color: rgba(255, 255, 255, 0.55);
      font-weight: 500;
    }

    #{{ features_id }} .urban-features__heading {
      margin: 0;
      text-transform: uppercase;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-size: clamp(28px, 5vw, 62px);
      line-height: 1;
      letter-spacing: 0.06em;
      font-weight: 500;
    }

    #{{ features_id }} .urban-features__sub {
      margin: 12px auto 0;
      max-width: 60ch;
      font-size: clamp(13px, 1.15vw, 16px);
      line-height: 1.7;
      color: var(--feat-copy);
    }

    /* Grid */
    #{{ features_id }} .urban-features__grid {
      max-width: min(1600px, 96vw);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: var(--feat-border);
      border: 1px solid var(--feat-border);
    }

    @media (min-width: 750px) {
      #{{ features_id }} .urban-features__grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1200px) {
      #{{ features_id }} .urban-features__grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Card */
    #{{ features_id }} .urban-features__card {
      background: var(--feat-bg);
      position: relative;
      overflow: hidden;
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }

    #{{ features_id }}.is-visible .urban-features__card {
      opacity: 1;
      transform: translateY(0);
    }

    {% for i in (1..12) %}
    #{{ features_id }}.is-visible .urban-features__card:nth-child({{ i }}) {
      transition-delay: {{ i | minus: 1 | times: 0.1 | at_most: 0.5 }}s;
    }
    {% endfor %}

    #{{ features_id }} .urban-features__card-media {
      position: relative;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: #0a0a0a;
    }

    #{{ features_id }} .urban-features__card-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1);
    }

    #{{ features_id }} .urban-features__card:hover .urban-features__card-media img {
      transform: scale(1.06);
    }

    #{{ features_id }} .urban-features__card-media::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, transparent 50%);
      pointer-events: none;
    }

    #{{ features_id }} .urban-features__card-body {
      padding: clamp(16px, 2.5vw, 28px);
    }

    #{{ features_id }} .urban-features__card-title {
      margin: 0;
      text-transform: uppercase;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-size: clamp(18px, 2vw, 26px);
      letter-spacing: 0.05em;
      font-weight: 500;
      line-height: 1.15;
    }

    #{{ features_id }} .urban-features__card-desc {
      margin: 10px 0 0;
      font-size: clamp(12px, 1vw, 14px);
      line-height: 1.65;
      color: var(--feat-copy);
    }

    #{{ features_id }} .urban-features__card-placeholder {
      width: 100%;
      height: 100%;
      opacity: 0.25;
    }

    /* CTA row */
    #{{ features_id }} .urban-features__cta-row {
      max-width: min(1600px, 92vw);
      margin: clamp(24px, 4vw, 48px) auto 0;
      text-align: center;
    }

    #{{ features_id }} .urban-features__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 13px 28px;
      border: 1px solid #fff;
      background: #fff;
      color: #111;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 11px;
      font-weight: 700;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

    #{{ features_id }} .urban-features__cta:hover {
      transform: translateY(-2px);
      background: transparent;
      color: #fff;
    }

    /* ── Mobile text adaptation ── */
    @media (max-width: 749px) {
      #{{ features_id }} .urban-features__eyebrow { letter-spacing: 0.15em; }
      #{{ features_id }} .urban-features__cta { letter-spacing: 0.12em; font-size: 10px; }
    }

    #{{ features_id }} .urban-features__heading,
    #{{ features_id }} .urban-features__subheading {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ features_id }} .urban-features__card,
      #{{ features_id }} .urban-features__card-media img {
        transition: none;
      }
    }
  </style>

  {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="urban-features__header">
      {% if section.settings.eyebrow != blank %}
        <p class="urban-features__eyebrow">
          {%- if is_uk and section.settings.eyebrow_uk != blank -%}{{ section.settings.eyebrow_uk }}{%- else -%}{{ section.settings.eyebrow }}{%- endif -%}
        </p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="urban-features__heading">
          {%- if is_uk and section.settings.heading_uk != blank -%}{{ section.settings.heading_uk }}{%- else -%}{{ section.settings.heading }}{%- endif -%}
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="urban-features__sub">
          {%- if is_uk and section.settings.subheading_uk != blank -%}{{ section.settings.subheading_uk }}{%- else -%}{{ section.settings.subheading }}{%- endif -%}
        </p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="urban-features__grid">
      {% for block in section.blocks %}
        {% liquid
          assign external_url = block.settings.external_image_url | strip
          assign resolved_url = ''
          if external_url != blank
            if external_url contains '://'
              assign resolved_url = external_url
            elsif external_url contains 'urban-part-'
              assign resolved_url = external_url | asset_url
            else
              assign resolved_url = external_url | file_url
            endif
          endif
        %}
        <article class="urban-features__card" {{ block.shopify_attributes }}>
          <div class="urban-features__card-media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif resolved_url != blank %}
              <img
                src="{{ resolved_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'collection-apparel-3' | placeholder_svg_tag: 'urban-features__card-placeholder' }}
            {% endif %}
          </div>
          <div class="urban-features__card-body">
            {% if block.settings.title != blank %}
              <h3 class="urban-features__card-title">
                {%- if is_uk and block.settings.title_uk != blank -%}{{ block.settings.title_uk }}{%- else -%}{{ block.settings.title }}{%- endif -%}
              </h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="urban-features__card-desc">
                {%- if is_uk and block.settings.description_uk != blank -%}{{ block.settings.description_uk }}{%- else -%}{{ block.settings.description }}{%- endif -%}
              </p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
    <div class="urban-features__cta-row">
      <a
        class="urban-features__cta"
        href="{{ section.settings.cta_link }}"
        {% if section.settings.cta_new_tab %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
      >
        {%- if is_uk and section.settings.cta_label_uk != blank -%}{{ section.settings.cta_label_uk }}{%- else -%}{{ section.settings.cta_label }}{%- endif -%}
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  {% endif %}

  <script>
    (() => {
      const root = document.getElementById('{{ features_id }}');
      if (!root || root.dataset.init === '1') return;
      root.dataset.init = '1';

      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          root.classList.add('is-visible');
          observer.disconnect();
        }
      }, { threshold: 0.08 });
      observer.observe(root);
    })();
  </script>
</section>

{% schema %}
{
  "name": "Urban Feature Highlights",
  "tag": "section",
  "class": "section section-urban-feature-highlights",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Urban Specification"
    },
    {
      "type": "text",
      "id": "eyebrow_uk",
      "label": "Eyebrow (UA)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Widetrack Specification"
    },
    {
      "type": "text",
      "id": "heading_uk",
      "label": "Heading (UA)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "subheading_uk",
      "label": "Subheading (UA)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop The Collection"
    },
    {
      "type": "text",
      "id": "cta_label_uk",
      "label": "CTA label (UA)"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open CTA in new tab",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Grid border color",
      "default": "#1b1b1b"
    },
    {
      "type": "color",
      "id": "copy_color",
      "label": "Body text color",
      "default": "#a0a0a0"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Name"
        },
        {
          "type": "text",
          "id": "title_uk",
          "label": "Title (UA)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "textarea",
          "id": "description_uk",
          "label": "Description (UA)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "external_image_url",
          "label": "External image URL",
          "info": "Full URL or Shopify filename"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Urban Feature Highlights"
    }
  ]
}
{% endschema %}
