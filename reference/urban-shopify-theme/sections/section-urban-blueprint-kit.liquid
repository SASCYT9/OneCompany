{% liquid
  assign bp_id = 'UrbanBlueprint-' | append: section.id
  assign loc = request.locale.iso_code | downcase
  assign is_uk = false
  if loc == 'uk' or loc == 'uk-ua' or loc contains 'uk-'
    assign is_uk = true
  endif
%}

<section id="{{ bp_id }}" class="urban-bp">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Sora:wght@200;300;400;500;600&display=swap');

    #{{ bp_id }} {
      --bp-bg: {{ section.settings.background_color }};
      --bp-card-bg: {{ section.settings.card_background }};
      --bp-text: {{ section.settings.text_color }};
      --bp-muted: {{ section.settings.muted_color }};
      --bp-sep: {{ section.settings.separator_color }};
      background: var(--bp-bg);
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      font-family: 'Sora', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: var(--bp-text);
    }

    /* ---- Header ---- */
    #{{ bp_id }} .urban-bp__header {
      max-width: min(1400px, 92vw);
      margin: 0 auto clamp(28px, 4vw, 56px);
      padding: 0 clamp(16px, 2vw, 24px);
      text-align: center;
    }

    #{{ bp_id }} .urban-bp__eyebrow {
      margin: 0 0 8px;
      text-transform: uppercase;
      letter-spacing: 0.4em;
      font-size: clamp(9px, 0.8vw, 11px);
      font-weight: 400;
      color: var(--bp-muted);
    }

    #{{ bp_id }} .urban-bp__heading {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(28px, 4.5vw, 56px);
      font-weight: 300;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1.1;
    }

    #{{ bp_id }} .urban-bp__sub {
      margin: 12px auto 0;
      max-width: 55ch;
      font-size: clamp(12px, 1vw, 14px);
      line-height: 1.7;
      color: var(--bp-muted);
      font-weight: 300;
    }

    /* ---- Grid ---- */
    #{{ bp_id }} .urban-bp__grid {
      max-width: min(1400px, 94vw);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(12px, 2vw, 24px);
    }

    @media (min-width: 600px) {
      #{{ bp_id }} .urban-bp__grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1200px) {
      #{{ bp_id }} .urban-bp__grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    /* ---- Card ---- */
    #{{ bp_id }} .urban-bp__card {
      background: var(--bp-card-bg);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }

    #{{ bp_id }}.is-visible .urban-bp__card {
      opacity: 1;
      transform: translateY(0);
    }

    #{{ bp_id }}.is-visible .urban-bp__card:nth-child(1) { transition-delay: 0s; }
    #{{ bp_id }}.is-visible .urban-bp__card:nth-child(2) { transition-delay: 0.1s; }
    #{{ bp_id }}.is-visible .urban-bp__card:nth-child(3) { transition-delay: 0.2s; }
    #{{ bp_id }}.is-visible .urban-bp__card:nth-child(4) { transition-delay: 0.3s; }

    #{{ bp_id }} .urban-bp__card-media {
      position: relative;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: var(--bp-card-bg);
    }

    #{{ bp_id }} .urban-bp__card-media img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      padding: 8%;
      transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }

    #{{ bp_id }} .urban-bp__card:hover .urban-bp__card-media img {
      transform: scale(1.04);
    }

    #{{ bp_id }} .urban-bp__card-body {
      padding: clamp(14px, 2vw, 22px) clamp(14px, 2vw, 22px);
      border-top: 1px solid var(--bp-sep);
      display: flex;
      flex-direction: column;
      flex: 1 1 auto;
    }

    #{{ bp_id }} .urban-bp__card-position {
      margin: 0 0 4px;
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-size: clamp(8px, 0.7vw, 10px);
      font-weight: 500;
      color: var(--bp-muted);
    }

    #{{ bp_id }} .urban-bp__card-title {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(14px, 1.35vw, 18px);
      font-weight: 400;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      line-height: 1.2;
      color: var(--bp-muted);
      min-height: calc(1.2em * 2);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    #{{ bp_id }} .urban-bp__card-head {
      min-height: clamp(72px, 8vw, 96px);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 6px;
      margin-bottom: 10px;
    }

    #{{ bp_id }} .urban-bp__card-divider {
      width: 32px;
      height: 1px;
      background: var(--bp-sep);
      margin: 0;
    }

    #{{ bp_id }} .urban-bp__card-parts {
      margin: 0;
      padding: 0;
      list-style: none;
      font-size: clamp(11px, 0.9vw, 13px);
      line-height: 1.85;
      color: var(--bp-muted);
      font-weight: 300;
    }

    #{{ bp_id }} .urban-bp__card-parts li {
      position: relative;
      padding-left: 14px;
    }

    #{{ bp_id }} .urban-bp__card-parts li::before {
      content: '//';
      position: absolute;
      left: 0;
      color: var(--bp-text);
      font-weight: 500;
      font-size: 0.85em;
    }

    /* ---- CTA ---- */
    #{{ bp_id }} .urban-bp__cta-row {
      max-width: min(1400px, 92vw);
      margin: clamp(24px, 4vw, 48px) auto 0;
      text-align: center;
    }

    #{{ bp_id }} .urban-bp__cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 13px 32px;
      border: 1px solid var(--bp-text);
      background: var(--bp-text);
      color: var(--bp-bg);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 11px;
      font-weight: 600;
      font-family: 'Sora', sans-serif;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

    #{{ bp_id }} .urban-bp__cta:hover {
      transform: translateY(-2px);
      background: transparent;
      color: var(--bp-text);
    }

    /* Placeholder */
    #{{ bp_id }} .urban-bp__card-placeholder {
      width: 100%;
      height: 100%;
      opacity: 0.15;
    }

    /* ── Mobile text adaptation ── */
    @media (max-width: 749px) {
      #{{ bp_id }} .urban-bp__eyebrow { letter-spacing: 0.25em; }
      #{{ bp_id }} .urban-bp__cta { letter-spacing: 0.12em; font-size: 10px; }
      #{{ bp_id }} .urban-bp__card-position { letter-spacing: 0.08em; }
    }

    #{{ bp_id }} .urban-bp__heading {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ bp_id }} .urban-bp__card,
      #{{ bp_id }} .urban-bp__card-media img {
        transition: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>

  {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
    <div class="urban-bp__header">
      {% if section.settings.eyebrow != blank %}
        <p class="urban-bp__eyebrow">{% if is_uk and section.settings.eyebrow_uk != blank %}{{ section.settings.eyebrow_uk }}{% else %}{{ section.settings.eyebrow }}{% endif %}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="urban-bp__heading">{% if is_uk and section.settings.heading_uk != blank %}{{ section.settings.heading_uk }}{% else %}{{ section.settings.heading }}{% endif %}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="urban-bp__sub">{% if is_uk and section.settings.subheading_uk != blank %}{{ section.settings.subheading_uk }}{% else %}{{ section.settings.subheading }}{% endif %}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="urban-bp__grid">
      {% for block in section.blocks %}
        {% liquid
          assign ext_url = block.settings.external_image_url | strip
          assign img_url = ''
          if ext_url != blank
            if ext_url contains '://'
              assign img_url = ext_url
            else
              assign img_url = ext_url | file_url
            endif
          endif

          assign title_en = block.settings.title_en | strip
          assign title_uk = block.settings.title_uk | strip
          assign parts_en_raw = block.settings.parts_en | strip
          assign parts_uk_raw = block.settings.parts_uk | strip

          if is_uk
            assign show_title = title_uk
            assign show_parts = parts_uk_raw
          else
            assign show_title = title_en
            assign show_parts = parts_en_raw
          endif

          if show_title == blank
            assign show_title = title_en
          endif
          if show_parts == blank
            assign show_parts = parts_en_raw
          endif

          assign show_position = block.settings.position_label | strip
          assign pos_key = show_position | downcase
          if is_uk
            case pos_key
              when 'front'
                assign show_position = 'Перед'
              when 'left'
                assign show_position = 'Ліворуч'
              when 'right'
                assign show_position = 'Праворуч'
              when 'back'
                assign show_position = 'Ззаду'
            endcase
          endif
        %}

        <article class="urban-bp__card" {{ block.shopify_attributes }}>
          <div class="urban-bp__card-media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1000 }}"
                alt="{{ show_title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif img_url != blank %}
              {% assign final_img = img_url %}
              {% if ext_url contains 'blueprint-' %}
                {% unless ext_url contains '://' %}
                  {% assign final_img = ext_url | asset_url %}
                {% endunless %}
              {% endif %}
              <img
                src="{{ final_img }}"
                alt="{{ show_title | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'urban-bp__card-placeholder' }}
            {% endif %}
          </div>

          <div class="urban-bp__card-body">
            <div class="urban-bp__card-head">
              {% if show_position != blank %}
                <p class="urban-bp__card-position">{{ show_position }}</p>
              {% endif %}

              {% if show_title != blank %}
                <h3 class="urban-bp__card-title">{{ show_title }}</h3>
              {% endif %}

              {% if show_parts != blank %}
                <div class="urban-bp__card-divider"></div>
              {% endif %}
            </div>

            {% if show_parts != blank %}
              <ul class="urban-bp__card-parts">
                {% assign parts_list = show_parts | split: '|' %}
                {% for part in parts_list %}
                  {% assign trimmed = part | strip %}
                  {% if trimmed != blank %}
                    <li>{{ trimmed }}</li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
    <div class="urban-bp__cta-row">
      <a
        class="urban-bp__cta"
        href="{{ section.settings.cta_link }}"
        {% if section.settings.cta_new_tab %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
      >
        {% if is_uk and section.settings.cta_label_uk != blank %}{{ section.settings.cta_label_uk }}{% else %}{{ section.settings.cta_label }}{% endif %}
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  {% endif %}

  <script>
    (() => {
      const root = document.getElementById('{{ bp_id }}');
      if (!root || root.dataset.init === '1') return;
      root.dataset.init = '1';

      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          root.classList.add('is-visible');
          observer.disconnect();
        }
      }, { threshold: 0.08 });
      observer.observe(root);
    })();
  </script>
</section>

{% schema %}
{
  "name": "Urban Blueprint Kit",
  "tag": "section",
  "class": "section section-urban-blueprint-kit",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Urban Range"
    },
    {
      "type": "text",
      "id": "eyebrow_uk",
      "label": "Eyebrow (UK)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Urban Kit"
    },
    {
      "type": "text",
      "id": "heading_uk",
      "label": "Heading (UK)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "subheading_uk",
      "label": "Subheading (UK)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Enquire Now"
    },
    {
      "type": "text",
      "id": "cta_label_uk",
      "label": "CTA label (UK)"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open CTA in new tab",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f5f3"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator / divider color",
      "default": "#e0e0e0"
    }
  ],
  "blocks": [
    {
      "type": "view",
      "name": "Kit View Card",
      "settings": [
        {
          "type": "text",
          "id": "position_label",
          "label": "Position label",
          "info": "e.g. Front, Left, Right, Back"
        },
        {
          "type": "text",
          "id": "title_en",
          "label": "Title (EN)",
          "default": "Carbon Fibre Package"
        },
        {
          "type": "text",
          "id": "title_uk",
          "label": "Title (UK)",
          "default": "Пакет з карбонового волокна"
        },
        {
          "type": "textarea",
          "id": "parts_en",
          "label": "Parts list (EN)",
          "info": "Separate items with | character"
        },
        {
          "type": "textarea",
          "id": "parts_uk",
          "label": "Parts list (UK)",
          "info": "Separate items with | character"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "external_image_url",
          "label": "External image URL",
          "info": "Full CDN URL for kit view image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Urban Blueprint Kit"
    }
  ]
}
{% endschema %}
