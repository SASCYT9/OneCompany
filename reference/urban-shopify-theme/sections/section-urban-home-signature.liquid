{% liquid
  assign home_id = 'UrbanHomeV7-' | append: section.id

  assign has_upload_video = false
  if section.settings.video != blank
    assign has_upload_video = true
  endif

  assign has_embed_video = false
  if section.settings.external_video_embed_url != blank
    assign has_embed_video = true
  endif

  assign has_direct_video = false
  if section.settings.external_video_url != blank
    assign has_direct_video = true
  endif

  assign direct_video_url = section.settings.external_video_url | strip
  if has_direct_video and direct_video_url != blank
    if direct_video_url contains '://'
      assign direct_video_url = direct_video_url
    else
      assign direct_video_url = direct_video_url | file_url
    endif
  endif

  assign external_poster_url = section.settings.external_poster_url | strip
  assign resolved_external_poster_url = ''
  if external_poster_url != blank
    if external_poster_url contains '://'
      assign resolved_external_poster_url = external_poster_url
    else
      assign resolved_external_poster_url = external_poster_url | file_url
    endif
  endif

  assign fallback_poster_remote_url = 'https://smgassets.blob.core.windows.net/customers/urban/dist/img/banners/home/webp/urban-automotive-widetrack-defender-grey-1920.webp'
  assign fallback_poster_url = 'hero-1-1920__e95adafbca.jpg' | file_url
  assign fallback_logo_url = 'https://smgassets.blob.core.windows.net/customers/urban/dist/img/svgs/logo.svg'
  assign one_company_logo_url = 'https://onecompany.global/branding/logo-light.svg'
  assign urban_logo_url = 'https://smgassets.blob.core.windows.net/customers/urban/dist/img/svgs/logo.svg'
  assign hero_fallback_vimeo = 'https://player.vimeo.com/video/905576660?background=1&autoplay=1&loop=1&muted=1&quality=720p'

  assign embed_url = section.settings.external_video_embed_url
  if has_embed_video
    if embed_url contains '?'
      assign embed_url = embed_url | append: '&autoplay=1&mute=1&loop=1&background=1&playsinline=1'
    else
      assign embed_url = embed_url | append: '?autoplay=1&mute=1&loop=1&background=1&playsinline=1'
    endif
  endif

  assign logo_external_url = section.settings.external_logo_url | strip
  assign resolved_logo_external_url = ''
  if logo_external_url != blank
    if logo_external_url contains '://'
      assign resolved_logo_external_url = logo_external_url
    else
      assign resolved_logo_external_url = logo_external_url | file_url
    endif
  endif

  assign locale_code = request.locale.iso_code | downcase
  assign is_uk = false
  if locale_code == 'uk' or locale_code contains 'uk-'
    assign is_uk = true
  endif

  assign hero_eyebrow = section.settings.eyebrow
  if is_uk and section.settings.eyebrow_uk != blank
    assign hero_eyebrow = section.settings.eyebrow_uk
  endif

  assign hero_title = section.settings.title
  if is_uk and section.settings.title_uk != blank
    assign hero_title = section.settings.title_uk
  endif

  assign hero_subtitle = section.settings.subtitle
  if is_uk and section.settings.subtitle_uk != blank
    assign hero_subtitle = section.settings.subtitle_uk
  endif

  assign primary_label = section.settings.primary_button_label
  if is_uk and section.settings.primary_button_label_uk != blank
    assign primary_label = section.settings.primary_button_label_uk
  endif

  assign secondary_label = section.settings.secondary_button_label
  if is_uk and section.settings.secondary_button_label_uk != blank
    assign secondary_label = section.settings.secondary_button_label_uk
  endif

  assign default_scroll_target = '#' | append: home_id | append: '-showcases'
  assign resolved_scroll_target = section.settings.scroll_target | strip
  if resolved_scroll_target == blank or resolved_scroll_target == 'auto'
    assign resolved_scroll_target = default_scroll_target
  endif

  assign ticker_suffix = 'Official Urban Automotive Supplier in Ukraine'
  if is_uk
    assign ticker_suffix = 'Офіційний постачальник Urban Automotive в Україні'
  endif
%}

{%- comment -%} ═══════════════════════════════════════════ {%- endcomment -%}
{%- comment -%} URBAN HOME SIGNATURE v7 — World-class       {%- endcomment -%}
{%- comment -%} Cinematic showcases · 3D cards · Video      {%- endcomment -%}
{%- comment -%} ═══════════════════════════════════════════ {%- endcomment -%}

<section
  id="{{ home_id }}"
  class="uh7"
  data-section-id="{{ section.id }}"
  data-section-type="urban-home-signature"
  style="
    --accent: {{ section.settings.accent_color }};
    --hero-h-mobile: {{ section.settings.mobile_height }}vh;
    --hero-h-desktop: {{ section.settings.desktop_height }}vh;
    --overlay-alpha: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --logo-w: {{ section.settings.logo_width }}px;
  "
>

<style>
/* ═══════════════════════════════════════════
   DESIGN SYSTEM — URBAN v7
   World-class animations · Premium · Refined
   ═══════════════════════════════════════════ */
@property --g-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
@property --shimmer { syntax: '<percentage>'; initial-value: -100%; inherits: false; }
@property --clip-y { syntax: '<percentage>'; initial-value: 100%; inherits: false; }

.uh7 {
  --ff-display: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;
  --ff-body: 'Sora', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --c-black: #0a0a0a;
  --c-dark: #111;
  --c-grey-1: #141414;
  --c-grey-2: #1e1e1e;
  --c-grey-3: #2a2a2a;
  --c-grey-4: #666;
  --c-grey-5: #999;
  --c-white: #f5f5f3;
  --c-accent: var(--accent, #f5f5f3);
  --c-accent-dim: color-mix(in srgb, var(--c-accent) 30%, transparent);
  --c-accent-glow: color-mix(in srgb, var(--c-accent) 8%, transparent);
  --r-sm: 8px; --r-md: 14px; --r-lg: 24px;
  --ease-expo: cubic-bezier(.16,1,.3,1);
  --ease-quart: cubic-bezier(.25,1,.5,1);
  --ease-spring: cubic-bezier(.34,1.56,.64,1);
  --ease-material: cubic-bezier(.4,0,.2,1);
  --gap: clamp(100px, 14vw, 200px);
  color: var(--c-white);
  background: var(--c-black);
  overflow-x: hidden;
  position: relative;
  font-family: var(--ff-body);
}

/* Film grain overlay */
.uh7::before {
  content: ''; position: fixed; inset: 0; z-index: 9999; pointer-events: none;
  opacity: .02;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px;
}

/* ── Scroll Progress ── */
.uh7-progress {
  position: fixed; top: 0; left: 0; right: 0; height: 2px;
  z-index: 10000; pointer-events: none;
  background: rgba(245,245,243,.04);
}
.uh7-progress__bar {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, var(--c-accent), rgba(245,245,243,.5));
  transition: width .1s linear;
}

/* ═══════════════════════════════════════════
   ANIMATION SYSTEM
   Cinematic reveals with letterbox clips
   ═══════════════════════════════════════════ */

/* Fade+rise — default */
.uh7-rv { opacity: 0; transform: translateY(50px); transition: opacity .9s var(--ease-expo), transform 1.1s var(--ease-expo); }
.uh7-rv.is-vis { opacity: 1; transform: translateY(0); }

/* Scale+fade — cinematic zoom */
.uh7-rv-s { opacity: 0; transform: scale(.93); transition: opacity 1s var(--ease-expo), transform 1.4s var(--ease-expo); }
.uh7-rv-s.is-vis { opacity: 1; transform: scale(1); }

/* Letterbox clip reveal — opens top+bottom */
.uh7-rv-ltrbx {
  clip-path: inset(12% 0 12% 0); opacity: 0;
  transition: clip-path 1.6s var(--ease-expo), opacity .8s var(--ease-expo);
}
.uh7-rv-ltrbx.is-vis { clip-path: inset(0 0 0 0); opacity: 1; }

/* Perspective rise */
.uh7-rv-3d {
  opacity: 0; transform: perspective(1200px) rotateX(8deg) translateY(40px);
  transform-origin: bottom center;
  transition: opacity .7s var(--ease-expo), transform 1.2s var(--ease-expo);
}
.uh7-rv-3d.is-vis { opacity: 1; transform: perspective(1200px) rotateX(0) translateY(0); }

/* Blur-in */
.uh7-rv-blur { opacity: 0; filter: blur(16px); transform: translateY(16px); transition: all .9s var(--ease-expo); }
.uh7-rv-blur.is-vis { opacity: 1; filter: blur(0); transform: translateY(0); }

/* Stagger children */
.uh7-stg > * { opacity: 0; transform: translateY(28px); transition: opacity .7s var(--ease-expo), transform .8s var(--ease-expo); }
.uh7-stg.is-vis > * { opacity: 1; transform: translateY(0); }
.uh7-stg.is-vis > *:nth-child(1) { transition-delay: .06s; }
.uh7-stg.is-vis > *:nth-child(2) { transition-delay: .13s; }
.uh7-stg.is-vis > *:nth-child(3) { transition-delay: .20s; }
.uh7-stg.is-vis > *:nth-child(4) { transition-delay: .27s; }
.uh7-stg.is-vis > *:nth-child(5) { transition-delay: .34s; }
.uh7-stg.is-vis > *:nth-child(6) { transition-delay: .41s; }
.uh7-stg.is-vis > *:nth-child(7) { transition-delay: .48s; }
.uh7-stg.is-vis > *:nth-child(8) { transition-delay: .55s; }

/* Magnetic */
.uh7-mag { transition: transform .4s var(--ease-spring); }

/* Section headers */
.uh7-shdr { text-align: center; max-width: 800px; margin: 0 auto; padding: 0 clamp(24px,4vw,60px) clamp(40px,6vw,80px); }
.uh7-shdr__rule { width: 1px; height: 60px; margin: 0 auto clamp(24px,3vw,40px); background: linear-gradient(180deg, transparent, rgba(245,245,243,.3)); }
.uh7-shdr__label { font-size: clamp(10px,1.1vw,12px); font-weight: 600; text-transform: uppercase; letter-spacing: .22em; color: rgba(245,245,243,.45); margin-bottom: 16px; }
.uh7-shdr__title { font-family: var(--ff-display); font-size: clamp(28px,4vw,52px); font-weight: 300; line-height: 1.12; letter-spacing: -.02em; margin: 0 0 16px; }
.uh7-shdr__desc { font-size: clamp(13px,1.2vw,15px); line-height: 1.7; color: var(--c-grey-5); max-width: 540px; margin: 0 auto; }

/* ── Buttons ── */
.uh7-btn {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--ff-body); font-size: clamp(10px,1vw,12px);
  font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  text-decoration: none; padding: 16px 36px; border-radius: 0;
  cursor: pointer; position: relative; overflow: hidden;
  transition: all .5s var(--ease-expo);
}
.uh7-btn::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.06), transparent);
  transform: translateX(-100%); transition: transform .7s;
}
.uh7-btn:hover::before { transform: translateX(100%); }
.uh7-btn--primary { background: var(--c-white); color: var(--c-black); border: 1px solid var(--c-white); }
.uh7-btn--primary:hover { background: transparent; color: var(--c-white); border-color: rgba(245,245,243,.4); }
.uh7-btn--secondary { background: transparent; color: var(--c-white); border: 1px solid rgba(245,245,243,.2); }
.uh7-btn--secondary:hover { border-color: var(--c-white); color: var(--c-white); }
.uh7-btn--shop { background: transparent; color: var(--c-white); border: 1px solid rgba(245,245,243,.2); font-size: 10px; padding: 10px 20px; }
.uh7-btn--shop:hover { background: var(--c-white); color: var(--c-black); }
.uh7-btn--shop svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.5; transition: transform .3s; }
.uh7-btn--shop:hover svg { transform: translateX(3px); }

/* ═══════════════════════════════════════════
   1. LOADER
   ═══════════════════════════════════════════ */
.uh7-loader {
  position: fixed; inset: 0; z-index: 10002;
  background: var(--c-black); display: flex;
  flex-direction: column; align-items: center; justify-content: center; gap: 24px;
  transition: opacity .8s var(--ease-expo), visibility .8s;
}
.uh7-loader.is-hidden { opacity: 0; visibility: hidden; pointer-events: none; }
.uh7-loader__brand {
  display: inline-flex;
  align-items: center;
  gap: clamp(8px, 1.2vw, 14px);
  opacity: 0;
  animation: uh7LoadLogo 1.2s var(--ease-expo) 0.1s forwards;
}
.uh7-loader__brand-one {
  height: clamp(21px, 3.4vw, 40px);
  width: auto;
  display: block;
}
.uh7-loader__brand-urban {
  height: clamp(16px, 2.6vw, 30px);
  width: auto;
  display: block;
  filter: brightness(0) invert(1);
  opacity: .96;
}
.uh7-loader__brand-x {
  font-size: clamp(9px, 1vw, 12px);
  letter-spacing: .16em;
  text-transform: uppercase;
  font-weight: 600;
  color: rgba(245,245,243,.7);
  display: inline-flex;
  align-items: center;
}
@keyframes uh7LoadLogo { 0%{opacity:0;transform:scale(.92)} 100%{opacity:1;transform:scale(1)} }
.uh7-loader__bar { width: 100px; height: 1px; background: rgba(245,245,243,.08); border-radius: 2px; overflow: hidden; }
.uh7-loader__bar-fill { height: 100%; width: 0%; background: var(--c-white); animation: uh7LoadB 2s var(--ease-expo) .4s forwards; }
@keyframes uh7LoadB { to{width:100%} }

/* ═══════════════════════════════════════════
   2. HERO — Cinematic Ultra-Premium
   Frame · Particles · Corner accents
   Shimmer title · Side text · Letterbox
   ═══════════════════════════════════════════ */
@property --hero-frame-progress { syntax: '<percentage>'; initial-value: 0%; inherits: false; }
@property --hero-shimmer-x { syntax: '<percentage>'; initial-value: -100%; inherits: false; }

.uh7-hero {
  position: relative; width: 100%; height: var(--hero-h-mobile);
  overflow: hidden; display: flex; align-items: flex-end; justify-content: center;
}
@media(min-width:750px){ .uh7-hero { height: var(--hero-h-desktop); } }

.uh7-hero__media { position: absolute; inset: 0; z-index: 1; }
.uh7-hero__parallax {
  width: 100%; height: 130%; position: absolute; top: -15%; left: 0; will-change: transform;
}
.uh7-hero__parallax img, .uh7-hero__parallax video, .uh7-hero__parallax iframe {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.uh7-hero__parallax iframe { border: 0; pointer-events: none; }

/* Enhanced multi-layer cinematic overlay with side vignettes */
.uh7-hero__overlay {
  position: absolute; inset: 0; z-index: 2;
  background:
    radial-gradient(ellipse 80% 100% at 50% 50%, transparent 30%, rgba(10,10,10,.45) 100%),
    linear-gradient(180deg, rgba(10,10,10,.35) 0%, rgba(10,10,10,.1) 25%, rgba(10,10,10,.15) 50%, rgba(10,10,10,.65) 75%, rgba(10,10,10,.85) 100%);
}
.uh7-hero__overlay::after {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.02) 2px, rgba(0,0,0,.02) 4px);
}

/* Dual-layer glow — bottom atmospheric */
.uh7-hero__glow {
  position: absolute; bottom: -30%; left: 50%; transform: translateX(-50%);
  width: 90vw; height: 55vh; z-index: 2; pointer-events: none;
  background: radial-gradient(ellipse, rgba(245,245,243,.04), transparent 70%);
  opacity: .5; animation: uh7Glow 6s ease-in-out infinite alternate;
}
.uh7-hero__glow::after {
  content: ''; position: absolute;
  top: -80%; left: 10%; width: 80%; height: 100%;
  background: radial-gradient(ellipse, rgba(245,245,243,.02), transparent 65%);
  opacity: .6; animation: uh7Glow2 8s ease-in-out infinite alternate;
}
@keyframes uh7Glow { 0%{opacity:.35;transform:translateX(-50%) scale(1)} 100%{opacity:.6;transform:translateX(-50%) scale(1.08)} }
@keyframes uh7Glow2 { 0%{opacity:.3;transform:scale(1) translateY(0)} 100%{opacity:.5;transform:scale(1.15) translateY(-5%)} }

/* ── Animated border frame ── */
.uh7-hero__frame {
  position: absolute; inset: clamp(16px,2.5vw,40px); z-index: 4;
  pointer-events: none;
}
.uh7-hero__frame::before,
.uh7-hero__frame::after {
  content: ''; position: absolute;
  opacity: 0; animation: uh7FrameIn 1.4s var(--ease-expo) 1.6s forwards;
}
/* Top + bottom horizontal lines */
.uh7-hero__frame::before {
  top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-accent-dim), transparent);
  transform: scaleX(0); animation: uh7FrameH 1.8s var(--ease-expo) 1.6s forwards;
}
.uh7-hero__frame::after {
  bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-accent-dim), transparent);
  transform: scaleX(0); animation: uh7FrameH 1.8s var(--ease-expo) 1.8s forwards;
}
@keyframes uh7FrameIn { to{opacity:1} }
@keyframes uh7FrameH { 0%{opacity:0;transform:scaleX(0)} 100%{opacity:1;transform:scaleX(1)} }

/* Left + right vertical lines via child spans */
.uh7-hero__frame-v {
  position: absolute; width: 1px;
  background: linear-gradient(180deg, transparent, var(--c-accent-dim), transparent);
  transform: scaleY(0); opacity: 0;
  animation: uh7FrameV 1.8s var(--ease-expo) forwards;
}
.uh7-hero__frame-v--l { top: 0; left: 0; bottom: 0; animation-delay: 2s; }
.uh7-hero__frame-v--r { top: 0; right: 0; bottom: 0; animation-delay: 2.2s; }
@keyframes uh7FrameV { 0%{opacity:0;transform:scaleY(0)} 100%{opacity:1;transform:scaleY(1)} }

/* ── Decorative luxury corners ── */
.uh7-hero__corner {
  position: absolute; width: 28px; height: 28px; z-index: 4;
  pointer-events: none; opacity: 0;
  animation: uh7CornerIn .6s var(--ease-expo) forwards;
}
.uh7-hero__corner::before,
.uh7-hero__corner::after {
  content: ''; position: absolute; background: rgba(245,245,243,.5);
}
.uh7-hero__corner--tl { top: clamp(16px,2.5vw,40px); left: clamp(16px,2.5vw,40px); animation-delay: 2.4s; }
.uh7-hero__corner--tl::before { top: 0; left: 0; width: 28px; height: 1px; }
.uh7-hero__corner--tl::after { top: 0; left: 0; width: 1px; height: 28px; }

.uh7-hero__corner--tr { top: clamp(16px,2.5vw,40px); right: clamp(16px,2.5vw,40px); animation-delay: 2.5s; }
.uh7-hero__corner--tr::before { top: 0; right: 0; width: 28px; height: 1px; }
.uh7-hero__corner--tr::after { top: 0; right: 0; width: 1px; height: 28px; }

.uh7-hero__corner--bl { bottom: clamp(16px,2.5vw,40px); left: clamp(16px,2.5vw,40px); animation-delay: 2.6s; }
.uh7-hero__corner--bl::before { bottom: 0; left: 0; width: 28px; height: 1px; }
.uh7-hero__corner--bl::after { bottom: 0; left: 0; width: 1px; height: 28px; }

.uh7-hero__corner--br { bottom: clamp(16px,2.5vw,40px); right: clamp(16px,2.5vw,40px); animation-delay: 2.7s; }
.uh7-hero__corner--br::before { bottom: 0; right: 0; width: 28px; height: 1px; }
.uh7-hero__corner--br::after { bottom: 0; right: 0; width: 1px; height: 28px; }
@keyframes uh7CornerIn { 0%{opacity:0;transform:scale(.5)} 100%{opacity:.6;transform:scale(1)} }

/* ── Floating particles ── */
.uh7-hero__particles {
  position: absolute; inset: 0; z-index: 3; pointer-events: none; overflow: hidden;
}
.uh7-hero__particle {
  position: absolute; width: 2px; height: 2px;
  background: rgba(245,245,243,.7); border-radius: 50%;
  opacity: 0; animation: uh7Particle var(--dur, 8s) var(--dly, 0s) infinite;
}
@keyframes uh7Particle {
  0% { opacity: 0; transform: translateY(0) scale(0); }
  10% { opacity: .6; transform: translateY(-10vh) scale(1); }
  90% { opacity: .15; }
  100% { opacity: 0; transform: translateY(-85vh) scale(.3); }
}

/* ── Side vertical text ── */
.uh7-hero__side-text {
  position: absolute; z-index: 4; pointer-events: none;
  font-size: 9px; font-weight: 500; letter-spacing: .35em;
  text-transform: uppercase; color: rgba(245,245,243,.12);
  writing-mode: vertical-rl; white-space: nowrap;
  opacity: 0; animation: uh7SideIn 1s var(--ease-expo) 2.8s forwards;
}
.uh7-hero__side-text--l {
  left: clamp(20px,3vw,48px); top: 50%; transform: translateY(-50%) rotate(180deg);
}
.uh7-hero__side-text--r {
  right: clamp(20px,3vw,48px); top: 50%; transform: translateY(-50%);
}
@keyframes uh7SideIn { 0%{opacity:0} 100%{opacity:1} }

/* ── Cinematic letterbox bars ── */
.uh7-hero__letterbox {
  position: absolute; left: 0; right: 0; z-index: 5;
  height: clamp(30px,4vh,60px); background: var(--c-black);
  pointer-events: none;
  animation: uh7Letterbox 1.6s var(--ease-expo) 1.2s forwards;
}
.uh7-hero__letterbox--top { top: 0; transform-origin: top; }
.uh7-hero__letterbox--bot { bottom: 0; transform-origin: bottom; }
@keyframes uh7Letterbox { to { transform: scaleY(0); opacity: 0; } }

/* Shutter */
.uh7-shutter { position: absolute; inset: 0; z-index: 6; display: flex; pointer-events: none; }
.uh7-shutter__p { flex: 1; background: var(--c-black); animation: uh7Shut .9s var(--ease-expo) forwards; animation-delay: calc(.5s + var(--i) * .05s); }
@keyframes uh7Shut { to{transform:scaleY(0)} }

.uh7-hero__content {
  position: relative; z-index: 7; text-align: center;
  padding: 0 clamp(24px,5vw,80px) clamp(60px,8vh,120px);
  max-width: 900px; display: flex; flex-direction: column; align-items: center;
  text-shadow: 0 2px 20px rgba(0,0,0,.6), 0 4px 40px rgba(0,0,0,.4);
}
.uh7-hero__brand {
  display: inline-flex;
  align-items: center;
  gap: clamp(10px, 1.4vw, 16px);
  margin-bottom: clamp(20px,3vw,36px);
  opacity: 0;
  animation: uh7Up .8s var(--ease-expo) 1.1s forwards;
}
.uh7-hero__brand-one {
  height: clamp(28px, 4.1vw, 50px);
  width: auto;
  display: block;
}
.uh7-hero__brand-urban {
  height: clamp(20px, 3.1vw, 38px);
  width: auto;
  display: block;
  filter: brightness(0) invert(1);
  opacity: .96;
}
.uh7-hero__brand-x {
  font-size: clamp(9px, 1vw, 12px);
  letter-spacing: .18em;
  text-transform: uppercase;
  font-weight: 600;
  color: rgba(245,245,243,.72);
  display: inline-flex;
  align-items: center;
}

/* Eyebrow with decorative side lines */
.uh7-hero__eyebrow {
  font-size: clamp(10px,1vw,12px); font-weight: 600;
  text-transform: uppercase; letter-spacing: .3em;
  color: rgba(245,245,243,.6); margin-bottom: 20px;
  display: flex; align-items: center; gap: 16px;
  opacity: 0; animation: uh7Up .7s var(--ease-expo) 1.3s forwards;
}
.uh7-hero__eyebrow::before,
.uh7-hero__eyebrow::after {
  content: ''; display: block; width: clamp(24px,4vw,60px); height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,245,243,.2));
  flex-shrink: 0;
}
.uh7-hero__eyebrow::after {
  background: linear-gradient(90deg, rgba(245,245,243,.2), transparent);
}

/* Title with shimmer sweep */
.uh7-hero__title {
  font-family: var(--ff-display); font-size: clamp(10px,2.1vw,40px);
  font-weight: 300; line-height: .98; letter-spacing: -.01em; margin: 0 0 14px;
  white-space: nowrap !important;
  text-wrap: nowrap;
  overflow-wrap: normal;
  word-break: keep-all;
  position: relative;
}
.uh7-hero__title-shimmer {
  position: absolute; inset: 0; pointer-events: none;
  background: linear-gradient(105deg, transparent 40%, rgba(245,245,243,.12) 48%, rgba(245,245,243,.22) 50%, rgba(245,245,243,.12) 52%, transparent 60%);
  background-size: 200% 100%;
  background-position-x: var(--hero-shimmer-x, -100%);
  -webkit-background-clip: text; background-clip: text;
  color: transparent;
  animation: uh7TitleShimmer 4s var(--ease-expo) 2.5s forwards;
  mix-blend-mode: screen;
}
@keyframes uh7TitleShimmer { 0%{--hero-shimmer-x:-100%} 100%{--hero-shimmer-x:200%} }

.uh7-char {
  display: inline-block; opacity: 0;
  animation: uh7Char .5s var(--ease-expo) forwards;
}
@keyframes uh7Char {
  0% { opacity: 0; transform: translateY(50%) rotateX(25deg); filter: blur(5px); }
  100% { opacity: 1; transform: translateY(0) rotateX(0); filter: blur(0); }
}

@media(max-width:1024px){
  .uh7-hero__title {
    white-space: nowrap !important;
    text-wrap: nowrap;
    font-size: clamp(8px,2.8vw,26px);
    line-height: 1;
    letter-spacing: 0;
  }
}

/* Subtitle with soft glow */
.uh7-hero__subtitle {
  font-size: clamp(14px,1.4vw,17px); line-height: 1.7;
  color: rgba(245,245,243,.75); max-width: 520px; margin-bottom: 36px;
  opacity: 0; animation: uh7Up .8s var(--ease-expo) 1.8s forwards;
}
.uh7-hero__official {
  font-size: clamp(10px, 1vw, 12px);
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(245,245,243,.82);
  margin: 0 0 22px;
  opacity: 0;
  animation: uh7Up .8s var(--ease-expo) 1.92s forwards;
}

/* Buttons row */
.uh7-hero__buttons {
  display: flex; flex-wrap: wrap; gap: 14px; justify-content: center;
  opacity: 0; animation: uh7Up .8s var(--ease-expo) 2s forwards;
}
@keyframes uh7Up { 0%{opacity:0;transform:translateY(24px)} 100%{opacity:1;transform:translateY(0)} }



/* ═══════════════════════════════════════════
   3. TRUST RIBBON
   ═══════════════════════════════════════════ */
.uh7-trust {
  display: flex; justify-content: center; align-items: center;
  gap: clamp(28px,5vw,72px); flex-wrap: wrap;
  padding: clamp(20px,2.5vw,36px) clamp(16px,3vw,40px);
  background: var(--c-grey-1);
  border-bottom: 1px solid rgba(245,245,243,.04);
}
.uh7-trust__item {
  display: flex; align-items: center; gap: 8px;
  font-size: clamp(9px,.9vw,11px); font-weight: 500;
  letter-spacing: .14em; text-transform: uppercase; color: var(--c-grey-5);
}
.uh7-trust__icon { width: 16px; height: 16px; stroke: rgba(245,245,243,.35); fill: none; stroke-width: 1.5; }

/* ═══════════════════════════════════════════
   4. CINEMATIC CAR SHOWCASES
   Full-bleed immersive sections — 8 cars
   ═══════════════════════════════════════════ */
.uh7-showcases { position: relative; }

.uh7-sc {
  position: relative; width: 100%; min-height: 100vh; overflow: hidden;
  display: flex; align-items: flex-end;
}
.uh7-sc__media { position: absolute; inset: 0; }
.uh7-sc__img {
  width: 100%; height: 130%; position: absolute; top: -15%;
  object-fit: cover; will-change: transform;
  transition: transform 10s linear;
}
.uh7-sc.is-vis .uh7-sc__img { transform: scale(1.06); }

/* Video layer for showcase — sits above image, crossfades in */
.uh7-sc__video {
  position: absolute; inset: 0; z-index: 1;
  width: 100%; height: 100%; object-fit: cover;
  opacity: 0; transition: opacity 1.2s var(--ease-material);
}
.uh7-sc.is-vis .uh7-sc__video { opacity: 1; }
/* Vimeo iframe in showcase — covers full area */
.uh7-sc__vimeo {
  position: absolute; inset: -20% -10%; z-index: 1;
  width: 120%; height: 140%;
  border: 0; pointer-events: none;
  opacity: 0; transition: opacity 1.4s var(--ease-material);
}
.uh7-sc.is-vis .uh7-sc__vimeo { opacity: 1; }

.uh7-sc__overlay {
  position: absolute; inset: 0; z-index: 2;
  background: linear-gradient(180deg, rgba(10,10,10,.15) 0%, rgba(10,10,10,.15) 20%, rgba(10,10,10,.4) 45%, rgba(10,10,10,.75) 65%, rgba(10,10,10,.92) 100%);
}

/* Counter */
.uh7-sc__num {
  position: absolute; top: clamp(24px,4vw,60px); right: clamp(24px,4vw,60px);
  z-index: 3; font-family: var(--ff-display); font-size: clamp(56px,8vw,120px);
  font-weight: 200; line-height: 1; letter-spacing: -.04em;
  color: transparent; -webkit-text-stroke: 1px rgba(245,245,243,.08);
  opacity: 0; transform: translateY(30px);
  transition: opacity 1s var(--ease-expo) .2s, transform 1s var(--ease-expo) .2s;
}
.uh7-sc.is-vis .uh7-sc__num { opacity: 1; transform: translateY(0); }

/* Content */
.uh7-sc__content {
  position: relative; z-index: 3;
  padding: clamp(40px,6vw,80px) clamp(32px,5vw,80px);
  max-width: 680px;
  text-shadow: 0 2px 16px rgba(0,0,0,.7), 0 4px 32px rgba(0,0,0,.5);
}
.uh7-sc__badge {
  display: inline-block; font-size: 9px; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: rgba(245,245,243,.7); padding: 5px 14px;
  border: 1px solid rgba(245,245,243,.2); border-radius: 2px;
  margin-bottom: 18px; backdrop-filter: blur(12px);
  background: rgba(10,10,10,.45);
  opacity: 0; transform: translateX(-20px);
  transition: all .7s var(--ease-expo) .15s;
}
.uh7-sc.is-vis .uh7-sc__badge { opacity: 1; transform: translateX(0); }

.uh7-sc__name {
  font-family: var(--ff-display); font-size: clamp(34px,5.5vw,70px);
  font-weight: 300; line-height: 1.05; letter-spacing: -.02em;
  margin: 0 0 14px;
  opacity: 0; transform: translateY(35px);
  transition: all .9s var(--ease-expo) .25s;
}
.uh7-sc.is-vis .uh7-sc__name { opacity: 1; transform: translateY(0); }

.uh7-sc__sub {
  font-size: clamp(13px,1.2vw,15px); line-height: 1.7;
  color: rgba(245,245,243,.75); max-width: 440px; margin-bottom: 24px;
  opacity: 0; transform: translateY(25px);
  transition: all .8s var(--ease-expo) .4s;
}
.uh7-sc.is-vis .uh7-sc__sub { opacity: 1; transform: translateY(0); }

.uh7-sc__actions {
  display: flex; flex-wrap: wrap; align-items: center; gap: 14px;
  opacity: 0; transform: translateY(18px);
  transition: all .7s var(--ease-expo) .55s;
}
.uh7-sc.is-vis .uh7-sc__actions { opacity: 1; transform: translateY(0); }

.uh7-sc__cta {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: var(--c-white); text-decoration: none;
  padding: 12px 0; position: relative;
}
.uh7-sc__cta::after {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 0; height: 1px; background: var(--c-white);
  transition: width .5s var(--ease-expo);
}
.uh7-sc__cta:hover::after { width: 100%; }
.uh7-sc__cta svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.5; transition: transform .3s; }
.uh7-sc__cta:hover svg { transform: translateX(4px); }

.uh7-sc__avail {
  font-size: 9px; font-weight: 500; letter-spacing: .14em;
  text-transform: uppercase; color: rgba(245,245,243,.4);
  display: flex; align-items: center; gap: 5px;
}
.uh7-sc__avail-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(245,245,243,.6); animation: uh7Pulse 2s ease-in-out infinite; }
@keyframes uh7Pulse { 0%,100%{opacity:.4;transform:scale(1)} 50%{opacity:1;transform:scale(1.3)} }

.uh7-sc__divider {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 1px; z-index: 4;
  background: linear-gradient(90deg, transparent, rgba(245,245,243,.06) 50%, transparent);
}

/* ═══════════════════════════════════════════
   5. FLEET CARDS — World-class 3D system
   3D tilt + dual light refraction + magnetic
   + progressive detail reveal + letterbox
   ═══════════════════════════════════════════ */
.uh7-fleet { padding: var(--gap) 0; }
.uh7-fleet__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(14px,1.8vw,22px);
  padding: 0 clamp(16px,3vw,48px);
  max-width: 1600px; margin: 0 auto;
}
@media(min-width:600px){ .uh7-fleet__grid { grid-template-columns: repeat(2,1fr); } }
@media(min-width:960px){ .uh7-fleet__grid { grid-template-columns: repeat(3,1fr); } }

/* Card container — perspective parent */
.uh7-card {
  position: relative; perspective: 900px;
  cursor: pointer; border-radius: var(--r-md);
  transition: transform .5s var(--ease-spring);
  display: block; text-decoration: none; color: inherit;
}

/* Inner card — receives 3D tilt */
.uh7-card__inner {
  position: relative; border-radius: var(--r-md); overflow: hidden;
  aspect-ratio: 3/4; transform-style: preserve-3d;
  transform: rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg));
  transition: transform .15s ease-out;
  /* Multi-layer shadow for realism */
  box-shadow:
    0 4px 6px rgba(0,0,0,.07),
    0 12px 28px rgba(0,0,0,.12),
    0 1px 3px rgba(0,0,0,.08);
}
.uh7-card:hover .uh7-card__inner {
  box-shadow:
    0 8px 16px rgba(0,0,0,.1),
    0 30px 60px rgba(0,0,0,.2),
    0 2px 4px rgba(0,0,0,.1);
}

/* Image layer */
.uh7-card__media { position: absolute; inset: 0; }
.uh7-card__media img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 1.2s var(--ease-expo);
}
.uh7-card:hover .uh7-card__media img { transform: scale(1.06); }

/* Video-on-hover layer — crossfade in */
.uh7-card__vid {
  position: absolute; inset: 0; z-index: 1;
  width: 100%; height: 100%; object-fit: cover;
  opacity: 0; transition: opacity .8s var(--ease-material);
  pointer-events: none;
}
.uh7-card:hover .uh7-card__vid.is-loaded { opacity: 1; }

/* Primary light refraction (follows cursor) */
.uh7-card__light {
  position: absolute; inset: 0; z-index: 2; pointer-events: none;
  background: radial-gradient(circle at var(--mx,50%) var(--my,50%),
    rgba(255,255,255,.12) 0%, transparent 55%);
  opacity: 0; transition: opacity .4s;
  mix-blend-mode: soft-light;
}
.uh7-card:hover .uh7-card__light { opacity: 1; }

/* Secondary warm light (offset, dual-source studio feel) */
.uh7-card__light-warm {
  position: absolute; inset: 0; z-index: 2; pointer-events: none;
  background: radial-gradient(circle at var(--mx2,60%) var(--my2,40%),
    rgba(245,245,243,.05) 0%, transparent 50%);
  opacity: 0; transition: opacity .5s;
}
.uh7-card:hover .uh7-card__light-warm { opacity: 1; }

/* Holographic sweep */
.uh7-card__holo {
  position: absolute; inset: 0; z-index: 2; pointer-events: none;
  background: linear-gradient(var(--g-angle), transparent, rgba(245,245,243,.03), transparent);
  opacity: 0; transition: opacity .5s;
  animation: uh7Holo 4s linear infinite;
}
@keyframes uh7Holo { to{--g-angle:360deg} }
.uh7-card:hover .uh7-card__holo { opacity: 1; }

/* Bottom gradient */
.uh7-card__gradient {
  position: absolute; inset: 0; z-index: 3; pointer-events: none;
  background: linear-gradient(180deg, transparent 25%, rgba(10,10,10,.85));
}

/* Vignette */
.uh7-card__vignette {
  position: absolute; inset: 0; z-index: 3; pointer-events: none;
  box-shadow: inset 0 0 50px rgba(0,0,0,.25);
  opacity: 0; transition: opacity .5s;
}
.uh7-card:hover .uh7-card__vignette { opacity: 1; }

/* Shop badge */
.uh7-card__shop {
  position: absolute; top: 12px; right: 12px; z-index: 5;
  font-size: 8px; font-weight: 700; letter-spacing: .16em;
  text-transform: uppercase; color: var(--c-white);
  padding: 5px 10px; border-radius: 2px;
  background: rgba(10,10,10,.55); backdrop-filter: blur(10px);
  border: 1px solid rgba(245,245,243,.15);
  opacity: 0; transform: translateY(-6px);
  transition: all .4s var(--ease-spring);
  transition-delay: .15s;
}
.uh7-card:hover .uh7-card__shop { opacity: 1; transform: translateY(0); }

/* Content — progressive reveal on hover */
.uh7-card__content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: clamp(16px,2vw,24px); z-index: 4;
}
.uh7-card__badge {
  display: inline-block; font-size: 8px; font-weight: 600;
  letter-spacing: .18em; text-transform: uppercase;
  color: rgba(245,245,243,.65); padding: 4px 10px;
  border: 1px solid rgba(245,245,243,.15); border-radius: 2px;
  margin-bottom: 8px; backdrop-filter: blur(6px);
  background: rgba(10,10,10,.3);
  transform: translateY(8px); opacity: .7;
  transition: all .5s var(--ease-spring);
}
.uh7-card:hover .uh7-card__badge { transform: translateY(0); opacity: 1; }

.uh7-card__title {
  font-family: var(--ff-display); font-size: clamp(20px,2.5vw,28px);
  font-weight: 300; line-height: 1.2; margin: 0 0 4px;
  transform: translateY(6px); transition: transform .5s var(--ease-spring);
  transition-delay: .05s;
}
.uh7-card:hover .uh7-card__title { transform: translateY(0); }

.uh7-card__subtitle { font-size: 11px; color: var(--c-grey-5); margin: 0; }

.uh7-card__tags {
  display: flex; gap: 5px; margin-top: 10px; flex-wrap: wrap;
  opacity: 0; transform: translateY(12px);
  transition: all .5s var(--ease-spring);
  transition-delay: .1s;
}
.uh7-card:hover .uh7-card__tags { opacity: 1; transform: translateY(0); }

.uh7-card__tag {
  font-size: 8px; font-weight: 600; letter-spacing: .1em;
  text-transform: uppercase; color: rgba(245,245,243,.45);
  padding: 3px 7px; border: 1px solid rgba(245,245,243,.07);
  border-radius: 2px;
}

.uh7-card__arrow {
  position: absolute; bottom: 14px; right: 14px; z-index: 5;
  width: 34px; height: 34px; border-radius: 50%;
  background: rgba(245,245,243,.06); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: scale(.6) rotate(-45deg);
  transition: all .5s var(--ease-spring); transition-delay: .12s;
}
.uh7-card:hover .uh7-card__arrow { opacity: 1; transform: scale(1) rotate(0); }
.uh7-card__arrow svg { width: 14px; height: 14px; stroke: var(--c-white); fill: none; stroke-width: 2; }

/* ONE OF ONE block removed */

/* ═══════════════════════════════════════════
   8. DEFENDER SHOWCASE — Cinematic hero
   ═══════════════════════════════════════════ */
.uh7-def {
  position: relative; overflow: hidden;
  padding: 0; margin: clamp(40px,6vw,80px) 0;
}

/* Hero banner */
.uh7-def__hero {
  position: relative; width: 100%;
  aspect-ratio: 21/9;
  min-height: 420px; max-height: 700px;
  overflow: hidden; border-radius: 0;
}
@media(max-width:768px){ .uh7-def__hero { aspect-ratio: 4/3; min-height: 360px; } }
.uh7-def__hero-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 12s linear;
}
.uh7-def__hero.is-visible .uh7-def__hero-img { transform: scale(1.08); }
.uh7-def__hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(180deg, rgba(0,0,0,.3) 0%, rgba(0,0,0,.2) 25%, rgba(0,0,0,.85) 100%),
    linear-gradient(90deg, rgba(0,0,0,.8) 0%, rgba(0,0,0,.4) 40%, transparent 70%);
}
.uh7-def__hero-content {
  position: absolute; inset: 0; z-index: 2;
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: clamp(24px,4vw,60px) clamp(24px,5vw,80px);
  max-width: 1600px; margin: 0 auto;
}
.uh7-def__widetrack-logo {
  width: clamp(120px,14vw,200px); height: auto;
  filter: brightness(0) invert(1); opacity: .8;
  margin-bottom: 16px;
  transform: translateY(20px); opacity: 0;
  transition: all .8s cubic-bezier(.16,1,.3,1);
}
.uh7-def__hero.is-visible .uh7-def__widetrack-logo {
  transform: translateY(0); opacity: .8;
}
.uh7-def__title {
  font-family: var(--ff-display); font-size: clamp(32px,4.5vw,56px);
  font-weight: 300; line-height: 1.1; margin: 0 0 8px;
  letter-spacing: -.02em; color: var(--c-white);
  text-shadow: 0 2px 8px rgba(0,0,0,.9), 0 4px 24px rgba(0,0,0,.7), 0 0 60px rgba(0,0,0,.4);
  transform: translateY(24px); opacity: 0;
  transition: all .8s cubic-bezier(.16,1,.3,1) .1s;
}
.uh7-def__hero.is-visible .uh7-def__title {
  transform: translateY(0); opacity: 1;
}
.uh7-def__subtitle {
  font-family: var(--ff-body); font-size: clamp(12px,1.2vw,15px);
  font-weight: 400; color: rgba(245,245,243,.8);
  letter-spacing: .06em; margin: 0 0 24px;
  max-width: 480px;
  text-shadow: 0 1px 6px rgba(0,0,0,.9), 0 2px 16px rgba(0,0,0,.6);
  transform: translateY(18px); opacity: 0;
  transition: all .8s cubic-bezier(.16,1,.3,1) .2s;
}
.uh7-def__hero.is-visible .uh7-def__subtitle {
  transform: translateY(0); opacity: 1;
}

/* Feature strip */
.uh7-def__features {
  display: flex; gap: clamp(16px,2.5vw,32px); flex-wrap: wrap;
  transform: translateY(16px); opacity: 0;
  transition: all .8s cubic-bezier(.16,1,.3,1) .3s;
}
.uh7-def__hero.is-visible .uh7-def__features {
  transform: translateY(0); opacity: 1;
}
.uh7-def__feat {
  display: flex; align-items: center; gap: 8px;
}
.uh7-def__feat-icon {
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(255,255,255,.08); backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
}
.uh7-def__feat-icon svg { width: 14px; height: 14px; stroke: var(--c-white); fill: none; stroke-width: 1.5; }
.uh7-def__feat-text {
  font-size: 10px; font-weight: 600; letter-spacing: .12em;
  text-transform: uppercase; color: rgba(245,245,243,.85);
  text-shadow: 0 1px 6px rgba(0,0,0,.8);
}

/* CTA button in hero */
.uh7-def__cta {
  display: inline-flex; align-items: center; gap: 10px;
  margin-top: 24px; padding: 14px 32px;
  font-family: var(--ff-body); font-size: 11px; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--c-white); text-decoration: none;
  background: rgba(255,255,255,.06); backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,.15); border-radius: 3px;
  transition: all .4s cubic-bezier(.16,1,.3,1);
  transform: translateY(16px); opacity: 0;
  transition: all .8s cubic-bezier(.16,1,.3,1) .4s;
}
.uh7-def__hero.is-visible .uh7-def__cta {
  transform: translateY(0); opacity: 1;
}
.uh7-def__cta:hover {
  background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.3);
  transform: translateY(-2px);
}
.uh7-def__cta svg {
  width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2;
  transition: transform .3s ease;
}
.uh7-def__cta:hover svg { transform: translateX(3px); }

/* Stats bar */
.uh7-def__stats {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
  display: flex; justify-content: center; gap: 0;
  border-top: 1px solid rgba(255,255,255,.08);
  background: rgba(0,0,0,.4); backdrop-filter: blur(16px);
}
@media(max-width:600px){ .uh7-def__stats { flex-wrap: wrap; } }
.uh7-def__stat {
  flex: 1; text-align: center;
  padding: clamp(14px,1.8vw,20px) clamp(12px,2vw,32px);
  border-right: 1px solid rgba(255,255,255,.06);
  opacity: 0; transform: translateY(12px);
  transition: all .6s cubic-bezier(.16,1,.3,1);
}
.uh7-def__stat:last-child { border-right: none; }
.uh7-def__hero.is-visible .uh7-def__stat { opacity: 1; transform: translateY(0); }
.uh7-def__hero.is-visible .uh7-def__stat:nth-child(1){ transition-delay: .3s; }
.uh7-def__hero.is-visible .uh7-def__stat:nth-child(2){ transition-delay: .4s; }
.uh7-def__hero.is-visible .uh7-def__stat:nth-child(3){ transition-delay: .5s; }
.uh7-def__hero.is-visible .uh7-def__stat:nth-child(4){ transition-delay: .6s; }
.uh7-def__stat-num {
  font-family: var(--ff-display); font-size: clamp(22px,2.5vw,30px);
  font-weight: 200; line-height: 1; color: var(--c-white); margin: 0;
}
.uh7-def__stat-label {
  font-size: 9px; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: rgba(245,245,243,.4); margin: 4px 0 0;
}

/* ═══════════════════════════════════════════
   9. GALLERY — Cinematic masonry + lightbox
   ═══════════════════════════════════════════ */
.uh7-gallery {
  padding: clamp(60px,8vw,100px) 0;
  position: relative; overflow: hidden;
}

/* Section header for gallery */
.uh7-gallery__header {
  text-align: center; margin-bottom: clamp(32px,4vw,56px);
  padding: 0 clamp(16px,3vw,48px);
}
.uh7-gallery__eyebrow {
  font-size: 10px; font-weight: 600; letter-spacing: .2em;
  text-transform: uppercase; color: rgba(245,245,243,.4);
  margin: 0 0 12px; display: flex; align-items: center;
  justify-content: center; gap: 16px;
}
.uh7-gallery__eyebrow::before,
.uh7-gallery__eyebrow::after {
  content: ''; width: 40px; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,245,243,.2));
}
.uh7-gallery__eyebrow::after {
  background: linear-gradient(90deg, rgba(245,245,243,.2), transparent);
}
.uh7-gallery__heading {
  font-family: var(--ff-display); font-size: clamp(28px,3.5vw,44px);
  font-weight: 200; line-height: 1.15; margin: 0 0 10px;
  letter-spacing: -.01em; color: var(--c-white);
}
.uh7-gallery__desc {
  font-size: clamp(12px,1.1vw,14px); color: rgba(245,245,243,.45);
  max-width: 460px; margin: 0 auto; line-height: 1.6;
}

/* Masonry grid */
.uh7-gallery__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: clamp(6px,1vw,10px);
  padding: 0 clamp(12px,2vw,32px);
  max-width: 1500px; margin: 0 auto;
}
@media(min-width:768px){
  .uh7-gallery__grid {
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(160px, auto);
  }
  /* Masonry layout — varied spans */
  .uh7-gi:nth-child(1) { grid-column: span 2; grid-row: span 2; }
  .uh7-gi:nth-child(4) { grid-row: span 2; }
  .uh7-gi:nth-child(7) { grid-column: span 2; }
}

/* Gallery item */
.uh7-gi {
  position: relative; overflow: hidden; border-radius: clamp(4px,.4vw,6px);
  cursor: pointer; min-height: 180px;
  /* Reveal animation */
  opacity: 0; transform: translateY(30px) scale(.96);
  transition: opacity .7s cubic-bezier(.16,1,.3,1),
              transform .7s cubic-bezier(.16,1,.3,1);
}
.uh7-gi.is-visible { opacity: 1; transform: translateY(0) scale(1); }
.uh7-gi:nth-child(1){ transition-delay: 0s; }
.uh7-gi:nth-child(2){ transition-delay: .08s; }
.uh7-gi:nth-child(3){ transition-delay: .16s; }
.uh7-gi:nth-child(4){ transition-delay: .12s; }
.uh7-gi:nth-child(5){ transition-delay: .2s; }
.uh7-gi:nth-child(6){ transition-delay: .28s; }
.uh7-gi:nth-child(7){ transition-delay: .24s; }
.uh7-gi:nth-child(8){ transition-delay: .32s; }

/* Image */
.uh7-gi img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 1.2s cubic-bezier(.16,1,.3,1);
}
.uh7-gi:hover img { transform: scale(1.08); }

/* Overlay on hover */
.uh7-gi::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,.05) 0%, rgba(0,0,0,.3) 100%);
  opacity: 0; transition: opacity .5s cubic-bezier(.16,1,.3,1);
}
.uh7-gi:hover::after { opacity: 1; }

/* Shine sweep */
.uh7-gi::before {
  content: ''; position: absolute; inset: 0; z-index: 2;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,.06) 45%, rgba(255,255,255,.02) 50%, transparent 55%);
  transform: translateX(-100%); transition: transform .9s cubic-bezier(.16,1,.3,1);
  pointer-events: none;
}
.uh7-gi:hover::before { transform: translateX(100%); }

/* Zoom icon */
.uh7-gi__icon {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%) scale(.4);
  z-index: 3; width: 44px; height: 44px;
  border-radius: 50%; background: rgba(0,0,0,.3); backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.12);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: all .5s cubic-bezier(.16,1,.3,1);
}
.uh7-gi:hover .uh7-gi__icon { opacity: 1; transform: translate(-50%,-50%) scale(1); }
.uh7-gi__icon svg { width: 18px; height: 18px; stroke: var(--c-white); fill: none; stroke-width: 1.5; }

/* Lightbox */
.uh7-lb {
  position: fixed; inset: 0; z-index: 10001;
  background: rgba(10,10,10,.95); backdrop-filter: blur(20px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; visibility: hidden; transition: all .5s var(--ease-expo); cursor: pointer;
}
.uh7-lb.is-open { opacity: 1; visibility: visible; }
.uh7-lb img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: var(--r-md); transform: scale(.85); transition: transform .5s var(--ease-expo); }
.uh7-lb.is-open img { transform: scale(1); }
.uh7-lb__close {
  position: absolute; top: 24px; right: 24px; width: 44px; height: 44px;
  border: 1px solid rgba(245,245,243,.15); border-radius: 50%;
  background: rgba(10,10,10,.5); backdrop-filter: blur(12px);
  color: var(--c-white); font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center; transition: all .3s;
}
.uh7-lb__close:hover { border-color: var(--c-white); color: var(--c-white); }

/* ═══════════════════════════════════════════
   10. CTA BANNER — Premium glass card
   ═══════════════════════════════════════════ */
.uh7-cta {
  position: relative; padding: clamp(100px,14vw,200px) clamp(24px,4vw,60px);
  text-align: center; overflow: hidden;
  background: linear-gradient(180deg, var(--c-black), var(--c-grey-1) 50%, var(--c-black));
}
.uh7-cta::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(245,245,243,.04), transparent 70%);
  opacity: .6;
}
.uh7-cta::after {
  content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: min(700px, 90%); height: min(450px, 85%);
  border: 1px solid rgba(245,245,243,.06);
  border-radius: var(--r-lg); pointer-events: none;
}
.uh7-cta__inner {
  position: relative; z-index: 1; max-width: 620px; margin: 0 auto;
  padding: clamp(40px,6vw,72px) clamp(24px,4vw,48px);
  background: rgba(20,20,20,.4); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(245,245,243,.06); border-radius: var(--r-lg);
  box-shadow: 0 24px 80px rgba(0,0,0,.4), inset 0 1px 0 rgba(245,245,243,.04);
}
.uh7-cta__rule {
  width: 1px; height: 48px; margin: 0 auto 28px;
  background: linear-gradient(180deg, transparent, rgba(245,245,243,.25), transparent);
}
.uh7-cta__eyebrow {
  font-size: clamp(10px,1vw,12px); font-weight: 600; text-transform: uppercase;
  letter-spacing: .3em; color: rgba(245,245,243,.5); margin-bottom: 20px;
  display: flex; align-items: center; justify-content: center; gap: 14px;
}
.uh7-cta__eyebrow::before, .uh7-cta__eyebrow::after {
  content: ''; width: clamp(20px,3vw,40px); height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,245,243,.15));
}
.uh7-cta__eyebrow::after { background: linear-gradient(90deg, rgba(245,245,243,.15), transparent); }
.uh7-cta__title { font-family: var(--ff-display); font-size: clamp(32px,5vw,64px); font-weight: 200; line-height: 1.08; letter-spacing: -.02em; margin: 0 0 20px; }
.uh7-cta__desc { font-size: clamp(13px,1.2vw,16px); line-height: 1.8; color: rgba(245,245,243,.55); margin-bottom: 36px; }
.uh7-cta__buttons { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }

/* ═══════════════════════════════════════════
   11. PARTNERS — Refined strip
   ═══════════════════════════════════════════ */
.uh7-partners {
  padding: clamp(60px,8vw,110px) 0;
  background: var(--c-black);
  border-top: 1px solid rgba(245,245,243,.04);
  border-bottom: 1px solid rgba(245,245,243,.04);
}
.uh7-partners__row {
  display: flex; flex-wrap: wrap; justify-content: center;
  align-items: center; gap: clamp(36px,5vw,72px);
  padding: 0 clamp(32px,5vw,80px); max-width: 1100px; margin: 0 auto;
}
.uh7-partners__brand {
  display: inline-flex;
  align-items: flex-end;
  gap: clamp(10px, 1.4vw, 16px);
}
.uh7-partners__brand-one {
  height: clamp(24px, 3.2vw, 40px);
  width: auto;
  display: block;
}
.uh7-partners__brand-urban {
  height: clamp(10px, 1.5vw, 19px);
  width: auto;
  display: block;
  filter: brightness(0) invert(1);
  opacity: .94;
  margin-bottom: 2px;
}
.uh7-partners__brand-x {
  font-size: clamp(9px, 1vw, 12px);
  letter-spacing: .16em;
  text-transform: uppercase;
  font-weight: 600;
  color: rgba(245,245,243,.72);
  margin-bottom: 3px;
}
.uh7-partners__logo {
  height: clamp(28px,3vw,44px); width: auto;
  filter: brightness(0) invert(1); opacity: .2;
  transition: all .6s var(--ease-expo);
}
.uh7-partners__logo:hover { opacity: .55; transform: scale(1.08); filter: brightness(0) invert(1) drop-shadow(0 0 12px rgba(245,245,243,.1)); }

/* ═══════════════════════════════════════════
   12. TICKER — Premium model parade
   ═══════════════════════════════════════════ */
.uh7-ticker {
  padding: clamp(44px,6vw,80px) 0; overflow: hidden;
  background: var(--c-grey-1);
  border-top: 1px solid rgba(245,245,243,.04);
  border-bottom: 1px solid rgba(245,245,243,.04);
  position: relative;
}
.uh7-ticker::before, .uh7-ticker::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: clamp(60px,8vw,120px); z-index: 2; pointer-events: none;
}
.uh7-ticker::before { left: 0; background: linear-gradient(90deg, var(--c-grey-1), transparent); }
.uh7-ticker::after { right: 0; background: linear-gradient(270deg, var(--c-grey-1), transparent); }
.uh7-ticker__track { display: flex; width: max-content; animation: uh7TK var(--ticker-speed, 24s) linear infinite; }
.uh7-ticker__track:hover { animation-play-state: paused; }
@keyframes uh7TK { to{transform:translateX(-50%)} }
.uh7-ticker__item { display: flex; align-items: center; gap: clamp(18px,3vw,36px); padding: 0 clamp(18px,3vw,36px); white-space: nowrap; }
.uh7-ticker__text { font-family: var(--ff-display); font-size: clamp(30px,5vw,64px); font-weight: 300; letter-spacing: -.01em; color: rgba(245,245,243,.06); transition: color .5s; }
.uh7-ticker__track:hover .uh7-ticker__text { color: rgba(245,245,243,.14); }
.uh7-ticker__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--c-accent-dim); flex-shrink: 0; }

/* ═══════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════ */
@media(max-width:749px){
  .uh7-hero__content { padding-bottom: 80px; }
  .uh7-hero__subtitle { font-size: 13px; max-width: 300px; }
  .uh7-hero__frame, .uh7-hero__corner,
  .uh7-hero__side-text, .uh7-hero__particles,
  .uh7-hero__letterbox { display: none; }
  .uh7-hero__eyebrow::before, .uh7-hero__eyebrow::after { width: 18px; }
  .uh7-btn { font-size: 10px; padding: 13px 24px; }
  .uh7-sc__content { padding: 28px 20px; }
  .uh7-sc__name { font-size: 30px; }
  .uh7-sc__num { display: none; }
  .uh7-card__tags { display: none; }
  .uh7-card__title { font-size: 17px; }
  .uh7-trust { gap: 16px; }
  .uh7-trust__item { font-size: 8px; }
  /* Mobile video fix — wider iframe to cover portrait viewport */
  .uh7-hero__parallax iframe { min-width: 300%; left: 50%; transform: translateX(-50%); }
  .uh7-sc__vimeo { inset: -10% -50%; width: 200%; height: 120%; }
  /* Mobile text adaptation */
  .uh7-hero__side-text { display: none; }
  .uh7-hero__eyebrow { letter-spacing: 0.18em; }
  .uh7-sc__sub { letter-spacing: 0.15em; }
  .uh7-sc__cta { letter-spacing: 0.08em; font-size: 10px; }
}

/* Reduced motion */
@media(prefers-reduced-motion:reduce){
  .uh7-hero__title .uh7-char, .uh7-hero__eyebrow, .uh7-hero__subtitle, .uh7-hero__official,
  .uh7-hero__buttons, .uh7-hero__brand, .uh7-loader__brand, .uh7-loader__text span {
    animation: none !important; opacity: 1 !important; transform: none !important;
  }
  .uh7-shutter__p { animation: none !important; opacity: 0 !important; }
  .uh7-hero__frame-v, .uh7-hero__corner, .uh7-hero__particle,
  .uh7-hero__side-text, .uh7-hero__letterbox, .uh7-hero__title-shimmer { animation: none !important; opacity: 1 !important; transform: none !important; }
  .uh7-rv, .uh7-rv-s, .uh7-rv-ltrbx, .uh7-rv-3d, .uh7-rv-blur, .uh7-stg > * {
    opacity: 1 !important; transform: none !important; clip-path: none !important; filter: none !important;
  }
  .uh7-ticker__track { animation: none !important; }
  .uh7-sc__badge, .uh7-sc__name, .uh7-sc__sub,
  .uh7-sc__actions, .uh7-sc__num { opacity: 1 !important; transform: none !important; }
}
</style>

{%- comment -%} ════════════════════════════════════ {%- endcomment -%}
{%- comment -%}  HTML MARKUP — v7                    {%- endcomment -%}
{%- comment -%} ════════════════════════════════════ {%- endcomment -%}

{%- comment -%} ── Scroll progress ── {%- endcomment -%}
<div class="uh7-progress" aria-hidden="true"><div class="uh7-progress__bar" id="{{ home_id }}-progress"></div></div>

{%- comment -%} ── LOADER ── {%- endcomment -%}
{%- if section.settings.enable_loader -%}
  <div class="uh7-loader" id="{{ home_id }}-loader" aria-hidden="true">
    <div class="uh7-loader__brand" aria-label="One Company x Urban Automotive">
      <img class="uh7-loader__brand-one" src="{{ one_company_logo_url }}" alt="One Company" width="422" height="155" loading="eager">
      <span class="uh7-loader__brand-x" aria-hidden="true">x</span>
      <img class="uh7-loader__brand-urban" src="{{ urban_logo_url }}" alt="Urban Automotive" width="643" height="101" loading="eager">
    </div>
    <div class="uh7-loader__bar"><div class="uh7-loader__bar-fill"></div></div>
  </div>
{%- endif -%}

{%- comment -%} ── HERO ── {%- endcomment -%}
<div class="uh7-hero" id="{{ home_id }}-hero">
  <div class="uh7-hero__media">
    <div class="uh7-hero__parallax" data-uh7-parallax="hero">
      {%- if has_embed_video -%}
        <iframe src="{{ embed_url }}" allow="autoplay; fullscreen" loading="lazy" title="{{ hero_title | escape }}"></iframe>
      {%- elsif has_direct_video -%}
        <video autoplay muted loop playsinline preload="auto" {%- if resolved_external_poster_url != blank %} poster="{{ resolved_external_poster_url }}"{% endif %}>
          <source src="{{ direct_video_url }}" type="video/mp4">
        </video>
      {%- elsif has_upload_video -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, preload: 'auto' }}
      {%- elsif section.settings.poster_image != blank -%}
        {%- assign p = section.settings.poster_image -%}
        <img src="{{ p | image_url: width: 1920 }}" srcset="{{ p | image_url: width: 960 }} 960w, {{ p | image_url: width: 1440 }} 1440w, {{ p | image_url: width: 1920 }} 1920w" sizes="100vw" alt="{{ p.alt | default: hero_title | escape }}" loading="eager" fetchpriority="high" width="{{ p.width }}" height="{{ p.height }}">
      {%- elsif resolved_external_poster_url != blank -%}
        <img src="{{ resolved_external_poster_url }}" alt="{{ hero_title | escape }}" loading="eager" fetchpriority="high">
      {%- else -%}
        <iframe src="{{ hero_fallback_vimeo }}" allow="autoplay; fullscreen" loading="eager" title="Urban Automotive — Rolls-Royce Ghost"></iframe>
      {%- endif -%}
    </div>
  </div>
  <div class="uh7-hero__overlay"></div>

  {%- comment -%} Cinematic letterbox bars {%- endcomment -%}
  <div class="uh7-hero__letterbox uh7-hero__letterbox--top" aria-hidden="true"></div>
  <div class="uh7-hero__letterbox uh7-hero__letterbox--bot" aria-hidden="true"></div>

  <div class="uh7-shutter" aria-hidden="true">
    {%- for i in (1..5) -%}<div class="uh7-shutter__p" style="--i:{{ forloop.index0 }}"></div>{%- endfor -%}
  </div>

  {%- comment -%} Border frame {%- endcomment -%}
  <div class="uh7-hero__frame" aria-hidden="true">
    <span class="uh7-hero__frame-v uh7-hero__frame-v--l"></span>
    <span class="uh7-hero__frame-v uh7-hero__frame-v--r"></span>
  </div>

  {%- comment -%} Luxury corner accents {%- endcomment -%}
  <div class="uh7-hero__corner uh7-hero__corner--tl" aria-hidden="true"></div>
  <div class="uh7-hero__corner uh7-hero__corner--tr" aria-hidden="true"></div>
  <div class="uh7-hero__corner uh7-hero__corner--bl" aria-hidden="true"></div>
  <div class="uh7-hero__corner uh7-hero__corner--br" aria-hidden="true"></div>

  {%- comment -%} Floating particles {%- endcomment -%}
  <div class="uh7-hero__particles" aria-hidden="true">
    <div class="uh7-hero__particle" style="left:8%;bottom:10%;--dur:9s;--dly:0s;"></div>
    <div class="uh7-hero__particle" style="left:22%;bottom:5%;--dur:11s;--dly:1.5s;"></div>
    <div class="uh7-hero__particle" style="left:38%;bottom:15%;--dur:8s;--dly:3s;"></div>
    <div class="uh7-hero__particle" style="left:55%;bottom:8%;--dur:10s;--dly:0.8s;"></div>
    <div class="uh7-hero__particle" style="left:68%;bottom:12%;--dur:12s;--dly:2.2s;"></div>
    <div class="uh7-hero__particle" style="left:82%;bottom:6%;--dur:9s;--dly:4s;"></div>
    <div class="uh7-hero__particle" style="left:92%;bottom:18%;--dur:10s;--dly:1s;"></div>
    <div class="uh7-hero__particle" style="left:15%;bottom:20%;--dur:13s;--dly:5s;"></div>
    <div class="uh7-hero__particle" style="left:45%;bottom:3%;--dur:7s;--dly:2.8s;"></div>
    <div class="uh7-hero__particle" style="left:75%;bottom:22%;--dur:11s;--dly:3.5s;"></div>
  </div>

  {%- comment -%} Side vertical text {%- endcomment -%}
  <span class="uh7-hero__side-text uh7-hero__side-text--l" aria-hidden="true">{% if is_uk %}Засн. 2015 — Бірмінгем, Англія{% else %}Est. 2015 — Birmingham, England{% endif %}</span>
  <span class="uh7-hero__side-text uh7-hero__side-text--r" aria-hidden="true">{% if is_uk %}Офіційний постачальник Urban в Україні{% else %}Official Urban Supplier in Ukraine{% endif %}</span>

  <div class="uh7-hero__glow"></div>
  <div class="uh7-hero__content">
    <div class="uh7-hero__brand" aria-label="One Company x Urban Automotive">
      <img class="uh7-hero__brand-one" src="{{ one_company_logo_url }}" alt="One Company" width="422" height="155" loading="eager">
      <span class="uh7-hero__brand-x" aria-hidden="true">x</span>
      <img class="uh7-hero__brand-urban" src="{{ urban_logo_url }}" alt="Urban Automotive" width="643" height="101" loading="eager">
    </div>
    {%- if hero_eyebrow != blank -%}<p class="uh7-hero__eyebrow">{{ hero_eyebrow }}</p>{%- endif -%}
    <h1 class="uh7-hero__title" data-uh7-split>
      {{ hero_title }}
      <span class="uh7-hero__title-shimmer" aria-hidden="true">{{ hero_title }}</span>
    </h1>
    {%- if hero_subtitle != blank -%}<p class="uh7-hero__subtitle">{{ hero_subtitle }}</p>{%- endif -%}
    <p class="uh7-hero__official">{% if is_uk %}Офіційний постачальник Urban Automotive в Україні{% else %}Official Urban Automotive Supplier in Ukraine{% endif %}</p>
    <div class="uh7-hero__buttons">
      {%- if primary_label != blank and section.settings.primary_button_link != blank -%}
