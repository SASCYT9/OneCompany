{%- comment -%} ═══════════════════════════════════════════
  JAVASCRIPT — World-class v7 Interactions
  3D tilt · dual light · video-on-hover
  magnetic · parallax · cinematic reveals
  ═══════════════════════════════════════════ {%- endcomment -%}
<script>
(function(){
  'use strict';
  const HOME = {{ home_id | json }};
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Loader ── */
  const ld = document.getElementById(HOME + '-loader');
  if (ld) {
    const d = () => { ld.classList.add('is-hidden'); setTimeout(() => ld.remove(), 900); };
    setTimeout(d, 2400);
    window.addEventListener('click', d, { once: true });
    window.addEventListener('touchstart', d, { once: true });
  }

  /* ── Scroll Progress ── */
  const pb = document.getElementById(HOME + '-progress');
  const sb = document.getElementById(HOME + '-scroll');
  if (pb) window.addEventListener('scroll', () => {
    const p = document.documentElement.scrollHeight - window.innerHeight;
    pb.style.width = (p > 0 ? (window.scrollY / p) * 100 : 0) + '%';
  }, { passive: true });

  /* ── Split text — character-by-character blur reveal ── */
  document.querySelectorAll('[data-uh7-split]').forEach(el => {
    /* Preserve the shimmer overlay span if present */
    const shimmer = el.querySelector('.uh7-hero__title-shimmer');
    const txt = el.childNodes[0]?.textContent?.trim() || el.textContent.trim();
    el.innerHTML = ''; let ci = 0;
    for (let i = 0; i < txt.length; i++) {
      if (txt[i] === ' ') { el.appendChild(document.createTextNode(' ')); }
      else {
        const s = document.createElement('span'); s.className = 'uh7-char';
        s.textContent = txt[i]; s.style.animationDelay = (.8 + ci * .035) + 's';
        el.appendChild(s); ci++;
      }
    }
    /* Re-append shimmer overlay on top of split chars */
    if (shimmer) el.appendChild(shimmer);
  });





  /* ── Force single-line title across devices (auto-fit) ── */
  const fitHeroTitle = () => {
    const hero = document.getElementById(HOME + '-hero');
    if (!hero) return;
    const title = hero.querySelector('.uh7-hero__title');
    if (!title) return;
    const parent = title.parentElement;
    if (!parent) return;

    title.style.fontSize = '';
    let size = parseFloat(window.getComputedStyle(title).fontSize || '0');
    const min = window.innerWidth <= 749 ? 6 : 9;
    let guard = 0;

    while (title.scrollWidth > parent.clientWidth * 0.99 && size > min && guard < 220) {
      size -= 0.5;
      title.style.fontSize = size + 'px';
      guard += 1;
    }
  };

  fitHeroTitle();
  window.setTimeout(fitHeroTitle, 160);
  window.addEventListener('resize', () => window.requestAnimationFrame(fitHeroTitle), { passive: true });
  window.addEventListener('orientationchange', () => window.requestAnimationFrame(fitHeroTitle), { passive: true });
  /* ── IntersectionObserver — reveals ── */
  const ro = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-vis'); ro.unobserve(e.target); } });
  }, { threshold: .08, rootMargin: '0px 0px -50px 0px' });
  document.querySelectorAll('[data-uh7-reveal]').forEach(el => ro.observe(el));

  /* ── Defender hero — cinematic reveal ── */
  const defHero = document.getElementById('{{ home_id }}-def-hero');
  if (defHero) {
    const defObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          defObs.unobserve(e.target);
        }
      });
    }, { threshold: .15, rootMargin: '0px 0px -60px 0px' });
    defObs.observe(defHero);
  }

  /* ── Gallery — staggered reveal ── */
  const galGrid = document.getElementById('{{ home_id }}-gallery-grid');
  if (galGrid) {
    const galObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          galGrid.querySelectorAll('.uh7-gi').forEach(c => c.classList.add('is-visible'));
          galObs.unobserve(e.target);
        }
      });
    }, { threshold: .08, rootMargin: '0px 0px -30px 0px' });
    galObs.observe(galGrid);
  }

  /* ── Showcase Vimeo lazy-load on reveal ── */
  const scVidObserver = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        /* Load Vimeo iframe */
        const vimeo = e.target.querySelector('[data-uh7-vimeo]');
        if (vimeo && vimeo.dataset.src) {
          vimeo.src = vimeo.dataset.src;
          delete vimeo.dataset.src;
        }
        /* Also handle any direct video elements */
        const vid = e.target.querySelector('[data-uh7-sc-video]');
        if (vid && vid.dataset.src) {
          vid.src = vid.dataset.src;
          vid.load();
          vid.play().catch(() => {});
          delete vid.dataset.src;
        }
        scVidObserver.unobserve(e.target);
      }
    });
  }, { threshold: .15, rootMargin: '300px 0px' });
  document.querySelectorAll('.uh7-sc').forEach(el => scVidObserver.observe(el));

  /* ── 3D Tilt + Dual Light Refraction — world-class card system ── */
  if (!RM) {
    document.querySelectorAll('[data-uh7-tilt]').forEach(card => {
      const inner = card.querySelector('.uh7-card__inner');
      const light = card.querySelector('.uh7-card__light');
      const lightWarm = card.querySelector('.uh7-card__light-warm');
      const vid = card.querySelector('.uh7-card__vid');
      if (!inner) return;

      card.addEventListener('mouseenter', () => {
        inner.style.transition = 'transform .15s ease-out';
        /* Load video on hover */
        if (vid && vid.dataset.src) {
          vid.src = vid.dataset.src;
          vid.load();
          vid.play().then(() => vid.classList.add('is-loaded')).catch(() => {});
          delete vid.dataset.src;
        } else if (vid && vid.src) {
          vid.play().then(() => vid.classList.add('is-loaded')).catch(() => {});
        }
      });

      card.addEventListener('mousemove', e => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width;   /* 0→1 */
        const y = (e.clientY - r.top) / r.height;    /* 0→1 */

        /* 3D tilt — max 8 degrees (luxury = restraint) */
        const rx = ((0.5 - y) * 8).toFixed(2);
        const ry = ((x - 0.5) * 8).toFixed(2);
        inner.style.setProperty('--rx', rx + 'deg');
        inner.style.setProperty('--ry', ry + 'deg');

        /* Primary light follows cursor */
        if (light) {
          light.style.setProperty('--mx', (x * 100).toFixed(1) + '%');
          light.style.setProperty('--my', (y * 100).toFixed(1) + '%');
        }
        /* Secondary warm light — offset for dual-source studio feel */
        if (lightWarm) {
          lightWarm.style.setProperty('--mx2', ((1 - x) * 80 + 10).toFixed(1) + '%');
          lightWarm.style.setProperty('--my2', ((1 - y) * 70 + 15).toFixed(1) + '%');
        }
      });

      card.addEventListener('mouseleave', () => {
        inner.style.transition = 'transform .6s cubic-bezier(.34,1.56,.64,1)';
        inner.style.setProperty('--rx', '0deg');
        inner.style.setProperty('--ry', '0deg');
        if (vid) vid.classList.remove('is-loaded');
        setTimeout(() => { inner.style.transition = 'transform .15s ease-out'; }, 600);
      });
    });
  }

  /* ── Magnetic buttons ── */
  if (!RM) {
    document.querySelectorAll('.uh7-mag').forEach(btn => {
      btn.addEventListener('mousemove', e => {
        const r = btn.getBoundingClientRect();
        const dx = e.clientX - r.left - r.width / 2;
        const dy = e.clientY - r.top - r.height / 2;
        btn.style.transform = 'translate(' + (dx * .2) + 'px,' + (dy * .2) + 'px)';
      });
      btn.addEventListener('mouseleave', () => { btn.style.transform = 'translate(0,0)'; });
    });
  }

  /* ── Parallax — hero + showcases ── */
  if (!RM) {
    const hp = document.querySelector('[data-uh7-parallax="hero"]');
    const scImgs = document.querySelectorAll('[data-uh7-parallax="sc"]');
    let ticking = false;
    const onScroll = () => {
      if (ticking) return; ticking = true;
      requestAnimationFrame(() => {
        const sy = window.scrollY;
        if (hp) hp.style.transform = 'translateY(' + (sy * .3) + 'px)';
        scImgs.forEach(img => {
          const r = img.closest('.uh7-sc').getBoundingClientRect();
          const vh = window.innerHeight;
          if (r.bottom > 0 && r.top < vh) {
            const p = (vh - r.top) / (vh + r.height);
            img.style.transform = 'translateY(' + ((p - .5) * -80) + 'px)';
          }
        });
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  /* ── Showcase content parallax depth ── */
  if (!RM) {
    const scs = document.querySelectorAll('.uh7-sc');
    window.addEventListener('scroll', () => {
      scs.forEach(sc => {
        const r = sc.getBoundingClientRect();
        const vh = window.innerHeight;
        if (r.bottom > 0 && r.top < vh) {
          const prog = (vh - r.top) / (vh + r.height);
          const ct = sc.querySelector('.uh7-sc__content');
          if (ct) ct.style.transform = 'translateY(' + ((1 - prog) * 25) + 'px)';
        }
      });
    }, { passive: true });
  }

  /* ── Drag carousel ── */
  document.querySelectorAll('[data-uh7-drag]').forEach(wrap => {
    const track = wrap.querySelector('[data-uh7-drag-track]');
    if (!track) return;
    let isDown = false, startX, scrollLeft;
    wrap.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - wrap.offsetLeft; scrollLeft = wrap.scrollLeft; wrap.style.cursor = 'grabbing'; });
    wrap.addEventListener('mouseleave', () => { isDown = false; wrap.style.cursor = 'grab'; });
    wrap.addEventListener('mouseup', () => { isDown = false; wrap.style.cursor = 'grab'; });
    wrap.addEventListener('mousemove', e => {
      if (!isDown) return; e.preventDefault();
      wrap.scrollLeft = scrollLeft - ((e.pageX - wrap.offsetLeft - startX) * 1.5);
    });
    wrap.style.cursor = 'grab';
  });

  /* ── Gallery lightbox ── */
  const lb = document.getElementById(HOME + '-lb');
  if (lb) {
    const lbImg = lb.querySelector('img');
    const lbCl = lb.querySelector('.uh7-lb__close');
    document.querySelectorAll('[data-gallery-src]').forEach(item => {
      item.addEventListener('click', () => {
        const src = item.getAttribute('data-gallery-src');
        if (lbImg && src) { lbImg.src = src; lb.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
      });
    });
    const closeLb = () => { lb.classList.remove('is-open'); document.body.style.overflow = ''; setTimeout(() => { if (lbImg) lbImg.src = ''; }, 500); };
    if (lbCl) lbCl.addEventListener('click', closeLb);
    lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });
  }

  /* ── Hide scroll btn ── */
  if (sb && !RM) window.addEventListener('scroll', () => { sb.style.opacity = window.scrollY > 200 ? '0' : ''; }, { passive: true });

})();
</script>

</section>

{% schema %}
{
  "name": "Urban Home Signature",
  "tag": "section",
  "class": "section section-urban-home-signature",
  "enabled_on": {
    "templates": ["index"]
  },
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Hero Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (EN)", "default": "Urban Automotive" },
    { "type": "text", "id": "eyebrow_uk", "label": "Eyebrow (UK)", "default": "Urban Automotive" },
    { "type": "text", "id": "title", "label": "Title (EN)", "default": "Premium Icons. Redefined." },
    { "type": "text", "id": "title_uk", "label": "Title (UK)", "default": "Преміальні ікони. Переосмислені." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle (EN)", "default": "From the Audi RS6 and Rolls-Royce Cullinan to Defender and G-Wagon, explore Urban's most desirable premium programmes in one seamless experience." },
    { "type": "textarea", "id": "subtitle_uk", "label": "Subtitle (UK)", "default": "Від Audi RS6 і Rolls-Royce Cullinan до Defender та G-Wagon, досліджуйте найкращі преміальні програми Urban в одному цілісному досвіді." },
    { "type": "header", "content": "Hero Buttons" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button label (EN)", "default": "Explore Range" },
    { "type": "text", "id": "primary_button_label_uk", "label": "Primary button label (UK)", "default": "Переглянути модельний ряд" },
    { "type": "url", "id": "primary_button_link", "label": "Primary button link" },
    { "type": "checkbox", "id": "primary_button_new_tab", "label": "Open primary button in new tab", "default": false },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button label (EN)", "default": "Book Consultation" },
    { "type": "text", "id": "secondary_button_label_uk", "label": "Secondary button label (UK)", "default": "Забронювати консультацію" },
    { "type": "url", "id": "secondary_button_link", "label": "Secondary button link" },
    { "type": "checkbox", "id": "secondary_button_new_tab", "label": "Open secondary button in new tab", "default": false },
    { "type": "header", "content": "Hero Media" },
    { "type": "video", "id": "video", "label": "Uploaded video (Shopify file)" },
    { "type": "text", "id": "external_video_url", "label": "External direct video URL", "info": "MP4 URL or Shopify Files filename." },
    { "type": "text", "id": "external_video_embed_url", "label": "External video embed URL", "info": "Example: https://player.vimeo.com/video/123456789" },
    { "type": "image_picker", "id": "poster_image", "label": "Poster / fallback image" },
    { "type": "text", "id": "external_poster_url", "label": "External poster URL", "info": "Image URL or Shopify Files filename." },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "external_logo_url", "label": "External logo URL", "info": "Image URL or Shopify Files filename." },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 120, "max": 420, "step": 10, "unit": "px", "default": 220 },
    { "type": "header", "content": "Showcase" },
    { "type": "checkbox", "id": "show_featured_models", "label": "Show premium fleet cards", "default": true },
    { "type": "range", "id": "featured_limit", "label": "Fleet cards count", "min": 3, "max": 12, "step": 1, "default": 9 },
    { "type": "checkbox", "id": "show_horizontal_stories", "label": "Show horizontal model stories", "default": false },
    { "type": "checkbox", "id": "prioritize_rolls_first", "label": "Prioritize Rolls-Royce stories first", "default": true },
    { "type": "checkbox", "id": "show_runway", "label": "Show long runway blocks", "default": false },
    { "type": "checkbox", "id": "show_gallery", "label": "Show photo gallery", "default": true },
    { "type": "range", "id": "gallery_limit", "label": "Gallery items count", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "show_ticker", "label": "Show bottom ticker", "default": true },
    { "type": "range", "id": "ticker_duration", "label": "Ticker duration", "min": 12, "max": 60, "step": 2, "unit": "s", "default": 24 },
    { "type": "header", "content": "Style and Behavior" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#f5f5f3" },
