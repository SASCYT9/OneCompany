        {%- assign b = block.settings -%}
        {%- assign card_title = b.title -%}
        {%- if is_uk and b.title_uk != blank %}{% assign card_title = b.title_uk %}{% endif -%}
        {%- assign card_subtitle = b.subtitle -%}
        {%- if is_uk and b.subtitle_uk != blank %}{% assign card_subtitle = b.subtitle_uk %}{% endif -%}
        {%- assign card_badge = b.badge -%}
        {%- if is_uk and b.badge_uk != blank %}{% assign card_badge = b.badge_uk %}{% endif -%}
        {%- assign card_image_url = '' -%}
        {%- if b.image != blank -%}
          {%- assign card_image_url = b.image | image_url: width: 720 -%}
        {%- elsif b.external_image_url != blank -%}
          {%- assign ext_img = b.external_image_url | strip -%}
          {%- if ext_img contains '://' %}{% assign card_image_url = ext_img %}{% else %}{% assign card_image_url = ext_img | file_url %}{% endif -%}
        {%- endif -%}
        {%- assign card_video_url = '' -%}
        {%- if b.story_video_url != blank -%}
          {%- assign vurl = b.story_video_url | strip -%}
          {%- if vurl contains '://' %}{% assign card_video_url = vurl %}{% else %}{% assign card_video_url = vurl | file_url %}{% endif -%}
        {%- endif -%}

        {%- assign card_url = b.link | default: '#' -%}
        <a class="uh7-card" href="{{ card_url }}" {% if b.new_tab %}target="_blank" rel="noopener"{% endif %} data-uh7-tilt {{ block.shopify_attributes }}>
          <div class="uh7-card__inner">
            <div class="uh7-card__media">
              {%- if card_image_url != blank -%}<img src="{{ card_image_url }}" alt="{{ card_title | escape }}" loading="lazy" width="720" height="960">{%- endif -%}
            </div>
            {%- if card_video_url != blank -%}
              <video class="uh7-card__vid" data-src="{{ card_video_url }}" muted loop playsinline preload="none"></video>
            {%- endif -%}
            <div class="uh7-card__light"></div>
            <div class="uh7-card__light-warm"></div>
            <div class="uh7-card__holo"></div>
            <div class="uh7-card__gradient"></div>
            <div class="uh7-card__vignette"></div>
            <span class="uh7-card__shop">{% if is_uk %}Дослідити{% else %}Explore{% endif %}</span>
            <div class="uh7-card__content">
              {%- if card_badge != blank -%}<span class="uh7-card__badge">{{ card_badge }}</span>{%- endif -%}
              <h3 class="uh7-card__title">{{ card_title }}</h3>
              {%- if card_subtitle != blank -%}<p class="uh7-card__subtitle">{{ card_subtitle }}</p>{%- endif -%}
              {%- if b.tag_one != blank or b.tag_two != blank -%}
                <div class="uh7-card__tags">
                  {%- if b.tag_one != blank -%}<span class="uh7-card__tag">{{ b.tag_one }}</span>{%- endif -%}
                  {%- if b.tag_two != blank -%}<span class="uh7-card__tag">{{ b.tag_two }}</span>{%- endif -%}
                </div>
              {%- endif -%}
            </div>
            <div class="uh7-card__arrow"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{%- comment -%} ONE OF ONE section removed by request {%- endcomment -%}

