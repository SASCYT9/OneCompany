{% comment %}
  ULTIMATE EPIC VIDEO SHOWCASE - v5.10 (Footer Compatibility)
  
  - (v5.10) LAYOUT FIX: Додано padding-bottom та ensure footer doesn't overlap
  - (v5.9) JS FIX: Додано `window.scrollTo(0, 0)` та `history.scrollRestoration = 'manual'`,
    щоб при оновленні сторінки користувач не "застрягав" у позиції прокрутки без хедера.
  - (v5.9) CSS FIX: Явний `z-index: 1` для секції, щоб гарантувати, що вона під хедером.
  - (v5.8) CSS: Compact mode for laptops.
  - (v5.7) UX: Button position & Scroll lock.
{% endcomment %}

<style>
  /* ===== PLUGINS ===== */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap');

  /* ===== VARIABLES ===== */
  :root {
    --accent: {{ section.settings.accent_color | default: '#ffffff' }};
    --accent-rgb: 255, 255, 255; /* Fallback, JS will override */
    --description-font-size: {{ section.settings.description_font_size | default: 18 }}px;
  }

  /* ===== BASE ===== */
  .epic-showcase {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: #000;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    /* v5.10: Ensure proper z-indexing and footer separation */
    z-index: 1;
  }
  
  .epic-showcase.desktop-scroll-active {
    height: 100vh;
    overflow: hidden;
  }

  .epic-showcase * {
    box-sizing: border-box;
  }

  /* ===== PRELOADER ===== */
  .epic-preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .epic-preloader__logo {
    width: min(92vw, 640px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(10px, 2vw, 18px);
    margin-bottom: 30px;
    opacity: 0;
    animation: logoFade 1s ease forwards;
    padding: 0;
  }

  .epic-preloader__logo img {
    height: auto;
    display: block;
  }

  .epic-preloader__logo-one {
    width: min(48vw, 280px);
    max-width: 280px;
  }

  .epic-preloader__logo-urban {
    width: min(34vw, 220px);
    max-width: 220px;
  }

  .epic-preloader__logo-x {
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(14px, 2vw, 24px);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @keyframes logoFade {
    to { opacity: 1; }
  }

  .epic-preloader__bar {
    width: 300px;
    height: 2px;
    background: rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    max-width: 80%;
  }

  .epic-preloader__progress {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #fff);
    width: 0%;
    box-shadow: 0 0 20px var(--accent);
    transition: width 0.3s ease;
  }

  .epic-preloader__percent {
    margin-top: 20px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 4px;
  }

  /* ===== CUSTOM CURSOR ===== */
  .epic-cursor {
    position: fixed;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    pointer-events: none;
    z-index: 10001;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: width, height, background;
  }

  .epic-cursor-ring {
    position: fixed;
    width: 50px;
    height: 50px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: width, height, border;
  }

  .epic-cursor.magnetic {
    width: 80px;
    height: 80px;
    background: var(--accent);
    box-shadow: 0 0 40px var(--accent);
  }

  .epic-cursor-ring.magnetic {
    width: 120px;
    height: 120px;
    border-color: var(--accent);
    border-width: 2px;
  }

  .cursor-trail {
    position: fixed;
    width: 8px;
    height: 8px;
    background: rgba(var(--accent-rgb), 0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform, opacity;
  }

  /* ===== SLIDE STYLES ===== */
  .epic-intro,
  .epic-slide {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
    min-height: 600px;
    height: 100vh;
  }
  
  .epic-intro {
    justify-content: center;
    padding-top: 80px; 
  }

  .epic-intro__video,
  .epic-slide__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    object-fit: cover;
    filter: brightness(0.5) contrast(1.1);
    transform: scale(1.1);
    transform-origin: center center;
    transition: transform 10s ease-out;
  }

  .epic-intro__overlay,
  .epic-slide__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  
  .epic-intro__overlay {
    background: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.8) 100%
    );
  }
  
  .epic-slide__overlay {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.3) 50%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  .pause-indicator {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 80px;
    height: 80px;
    background: rgba(0,0,0,0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    pointer-events: none;
    opacity: 0;
    transition: all 0.3s ease;
  }
  .pause-indicator svg {
    width: 30px;
    height: 30px;
    fill: #fff;
  }
  .epic-intro.paused .pause-indicator,
  .epic-slide.paused .pause-indicator {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  @media (min-width: 1024px) {
    .epic-intro__overlay.spotlight-active {
      background: radial-gradient(
        circle 800px at var(--mouse-x, 50%) var(--mouse-y, 50%),
        rgba(0, 0, 0, 0.2) 0%,
        rgba(0, 0, 0, 0.8) 80%
      );
      transition: background 0.1s linear;
    }
    
    .epic-slide__overlay.spotlight-active {
      background: radial-gradient(
        circle 600px at var(--mouse-x, 50%) var(--mouse-y, 50%),
        rgba(0, 0, 0, 0.3) 0%,
        rgba(0, 0, 0, 0.85) 90%
      );
      transition: background 0.1s linear;
    }
  }

  .epic-intro__grain,
  .epic-slide__grain {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    z-index: 3;
    pointer-events: none;
    opacity: 0.08;
  }
  .epic-slide__grain { opacity: 0.05; }

  @keyframes grainMove {
    0%, 100% { transform: translate(0, 0); }
    10% { transform: translate(-5%, -10%); }
    20% { transform: translate(-15%, 5%); }
    30% { transform: translate(7%, -25%); }
    40% { transform: translate(-5%, 25%); }
    50% { transform: translate(-15%, 10%); }
    60% { transform: translate(15%, 0%); }
    70% { transform: translate(0%, 15%); }
    80% { transform: translate(3%, 25%); }
    90% { transform: translate(-10%, 10%); }
  }
  
  .epic-intro__grain {
    animation: grainMove 8s steps(10) infinite;
  }

  .epic-intro__particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
    pointer-events: none;
  }

  .epic-intro__content {
    position: relative;
    z-index: 6;
    text-align: center;
    padding: 0 5%;
    max-width: 1400px;
    width: 100%;
    pointer-events: none;
  }
  .epic-intro__content a, 
  .epic-intro__content button,
  .epic-intro__scroll {
    pointer-events: auto;
  }

  .epic-intro__brandbar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 1.5vw, 14px);
    padding: 10px clamp(14px, 2.2vw, 26px);
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(10px);
    margin-bottom: 22px;
    opacity: 0;
    transform: translateY(16px);
  }

  .epic-intro__brandbar-logo {
    height: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .epic-intro__brandbar-logo--one {
    width: clamp(108px, 11vw, 152px);
    filter: none;
  }

  .epic-intro__brandbar-logo--urban {
    width: clamp(84px, 9vw, 132px);
  }

  .epic-intro__brandbar-x {
    font-size: clamp(10px, 1.1vw, 14px);
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    font-weight: 500;
  }

  /* ===== CONTENT SPACING ===== */
  .epic-intro__label {
    font-size: 10px;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 30px;
    font-weight: 500;
    opacity: 0;
    position: relative;
    display: inline-block;
  }

  .epic-intro__label::before,
  .epic-intro__label::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 80px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent));
  }
  .epic-intro__label::before { right: calc(100% + 40px); transform: rotate(180deg); }
  .epic-intro__label::after { left: calc(100% + 40px); }

  .epic-intro__title {
    font-size: clamp(32px, 7vw, 100px);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    margin-bottom: 25px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: relative;
    text-wrap: balance;
  }

  .epic-intro__title-word {
    display: block;
    overflow: hidden;
    padding: 8px 0;
    perspective: 800px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .epic-intro__title-word {
      white-space: normal;
      overflow-wrap: break-word;
      word-break: break-word;
    }
  }

  .epic-intro__title-char {
    display: inline-block;
    transform: translateY(110%) rotateX(-20deg);
    opacity: 0;
    transform-origin: bottom center;
    text-shadow: 0 0 60px rgba(255, 255, 255, 0.1), 0 20px 40px rgba(0, 0, 0, 0.6);
    will-change: transform, opacity;
  }

  .epic-intro__subtitle {
    font-size: clamp(14px, 1.8vw, 20px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 4px;
    margin-bottom: 35px;
    opacity: 0;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
  }

  .epic-intro__about {
    width: min(78ch, 92vw);
    margin: 0 auto 32px;
    font-size: clamp(13px, 1.1vw, 17px);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.86);
    letter-spacing: 0.03em;
    opacity: 0;
    transform: translateY(10px);
    text-wrap: pretty;
  }

  .epic-intro__action {
    margin-top: 0;
    margin-bottom: 35px;
    opacity: 0;
    position: relative;
    z-index: 20;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  
  .epic-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    border: 1px solid var(--accent);
    color: #fff;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 14px;
    transition: all 0.3s ease;
    background: rgba(var(--accent-rgb), 0.1);
    backdrop-filter: blur(5px);
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  
  .epic-btn:hover {
    background: var(--accent);
    color: #000;
    box-shadow: 0 0 30px var(--accent);
    transform: translateY(-2px);
  }
  
  .epic-btn:active {
    transform: translateY(0);
  }

  .epic-btn--ghost {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.6);
    color: rgba(255, 255, 255, 0.95);
  }

  .epic-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
    box-shadow: none;
  }

  .epic-intro__stats {
    display: flex;
    justify-content: center;
    gap: clamp(60px, 10vw, 140px);
    opacity: 0;
  }

  .epic-stat {
    text-align: center;
    position: relative;
  }
  .epic-stat::after {
    content: '';
    position: absolute;
    bottom: -25px;
    left: 50%;
    transform: translateX(-50%);
    width: 0%;
    height: 1px;
    background: var(--accent);
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .epic-stat.active::after { width: 60%; }

  .epic-stat__number {
    font-size: clamp(36px, 5.5vw, 68px);
    font-weight: 700;
    color: var(--accent);
    display: block;
    margin-bottom: 18px;
    text-shadow: 0 0 30px rgba(var(--accent-rgb), 0.4);
  }
  .epic-stat__label {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  /* ===== COMPACT MODE ===== */
  @media (min-width: 1024px) and (max-height: 850px) {
    .epic-intro__brandbar { margin-bottom: 14px; }
    .epic-intro__label { margin-bottom: 15px; font-size: 9px; }
    .epic-intro__title { margin-bottom: 15px; font-size: clamp(30px, 5vw, 60px); }
    .epic-intro__subtitle { margin-bottom: 25px; font-size: 14px; }
    .epic-intro__about { margin-bottom: 24px; font-size: 13px; }
    .epic-intro__action { margin-bottom: 30px; }
    .epic-btn { padding: 12px 30px; font-size: 12px; }
    .epic-stat__number { font-size: 36px; margin-bottom: 10px; }
    .epic-stat::after { bottom: -15px; }
    .epic-intro__scroll { bottom: 30px; }
    .epic-intro { padding-top: 100px; } 
  }

  .epic-intro__scroll {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    z-index: 7;
    opacity: 0;
    cursor: pointer;
  }
  .epic-intro__scroll-text {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 20px;
    transition: color 0.3s ease;
    font-weight: 400;
  }
  .epic-intro__scroll:hover .epic-intro__scroll-text { color: var(--accent); }
  .epic-intro__scroll-line {
    width: 2px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    margin: 0 auto;
    position: relative;
  }
  .epic-intro__scroll-dot {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: scrollDot 2s infinite;
  }
  @keyframes scrollDot {
    0% { top: 0; opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ===== VIDEO SLIDES ===== */
  .epic-slide__content {
    position: relative;
    z-index: 4;
    padding: 0 10%;
    max-width: 800px;
    pointer-events: none; 
  }
  .epic-slide__content a, .epic-slide__content button { pointer-events: auto; }

  .epic-slide__number {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    margin-bottom: 35px;
    font-weight: 600;
    opacity: 0;
    display: flex;
    align-items: center;
    gap: 25px;
  }
  .epic-slide__number::after {
    content: '';
    width: 60px;
    height: 1px;
    background: var(--accent);
  }

  .epic-slide__title {
    font-size: clamp(26px, 7.5vw, 76px);
    font-weight: 900;
    color: #fff;
    line-height: 0.95;
    margin-bottom: 40px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
    text-wrap: balance;
    -webkit-hyphens: none;
    -moz-hyphens: none;
    -ms-hyphens: none;
  }

  .epic-slide__divider {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    margin-bottom: 40px;
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
  }

  .epic-slide__description {
    font-size: var(--description-font-size);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 300;
    letter-spacing: 0.3px;
    max-width: 600px;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  /* ===== UI ELEMENTS ===== */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: rgba(255, 255, 255, 0.05);
    z-index: 1000;
  }
  .progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #fff);
    width: 0%;
    box-shadow: 0 0 20px var(--accent);
    transition: width 0.1s linear;
  }

  .slide-counter {
    position: fixed;
    top: 50%;
    right: clamp(1.5rem, 5vw, 70px);
    transform: translateY(-50%);
    z-index: 100;
    text-align: right;
  }
  .slide-counter__current {
    font-size: 54px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    text-shadow: 0 0 25px rgba(var(--accent-rgb), 0.5);
  }
  .slide-counter__divider {
    width: 60px;
    height: 2px;
    background: rgba(255, 255, 255, 0.3);
    margin: 20px 0 20px auto;
  }
  .slide-counter__total {
    font-size: 24px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.4);
  }

  .nav-dots {
    position: fixed;
    left: clamp(1.5rem, 5vw, 70px);
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }
  .nav-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  .nav-dot::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 0;
    height: 0;
    background: var(--accent);
    border-radius: 50%;
    transition: all 0.4s ease;
    box-shadow: 0 0 20px var(--accent);
  }
  .nav-dot.active::before { width: 100%; height: 100%; }
  .nav-dot:hover { transform: scale(1.5); }
  
  .nav-tooltip {
    position: fixed;
    top: 0;
    left: 0;
    background: var(--accent);
    color: #000;
    font-weight: 600;
    font-size: 12px;
    padding: 8px 14px;
    border-radius: 4px;
    z-index: 10002;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.2s ease-out;
    will-change: transform, opacity;
  }
  .nav-tooltip.visible { opacity: 1; transform: scale(1); }

  /* ===== MOBILE ===== */
  @media (max-width: 1023px) {
    .epic-intro,
    .epic-slide {
      height: 100dvh;
      height: 100svh;
      min-height: -webkit-fill-available;
      touch-action: pan-y;
      cursor: pointer; /* Підказка, що можна клікнути */
    }

    .epic-intro__video,
    .epic-slide__video {
      transform: scale(1.05);
      transform-origin: center center;
    }

    .epic-slide__content {
      padding: 100px 8% 80px 8%;
      width: 100%;
    }
    
    .epic-slide__overlay {
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.6) 0%,
        rgba(0, 0, 0, 0.2) 40%,
        rgba(0, 0, 0, 0.85) 100%
      );
    }

    .slide-counter {
      right: 20px;
      top: 80px;
      transform: none;
    }
    .slide-counter__current { font-size: 22px; }
    .nav-dots { display: none; }
  }

  .epic-intro__title,
  .epic-slide__title,
  .epic-slide__description {
    overflow-wrap: break-word;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .epic-cursor, .epic-cursor-ring, .cursor-trail, .nav-tooltip { display: none !important; }
    .epic-intro__label::before, .epic-intro__label::after { display: none; }
    .epic-preloader__logo { gap: 8px; }
    .epic-preloader__logo-x { letter-spacing: 0.1em; }
    .epic-preloader__logo-one { width: min(48vw, 180px); }
    .epic-preloader__logo-urban { width: min(34vw, 130px); }
    .epic-intro__brandbar { margin-bottom: 14px; padding: 8px 12px; }
    .epic-intro__brandbar-logo--one { width: clamp(90px, 26vw, 130px); }
    .epic-intro__brandbar-logo--urban { width: clamp(72px, 22vw, 104px); }
    .epic-intro__label { letter-spacing: 3px; }
    .epic-intro__subtitle { letter-spacing: 1px; }
    .epic-intro__about { margin-bottom: 24px; font-size: 13px; line-height: 1.6; }
    .epic-stat__label { letter-spacing: 1.5px; }
    .epic-slide__number { letter-spacing: 2px; }
    .epic-intro__stats { flex-direction: column; gap: 30px; margin-bottom: 30px; }
    .epic-intro__scroll { bottom: 90px; }
    
    /* Ensure video is truly fullscreen on small mobile */
    .epic-intro,
    .epic-slide {
      min-height: 100dvh;
      min-height: -webkit-fill-available;
    }

    .epic-intro__video,
    .epic-slide__video {
      position: absolute;
      inset: -2px;
      width: calc(100% + 4px);
      height: calc(100% + 4px);
      transform: none;
    }

    /* FIX HEADER OVERLAP */
    .epic-intro__content { 
      padding-bottom: 80px;
      padding-top: 110px; 
    }
    .epic-slide__content { 
      padding: 100px 6% 80px 6%; 
      width: 100%; 
    }
    
    .epic-slide__title { font-size: clamp(32px, 10vw, 48px); margin-bottom: 25px; }
    .epic-slide__description {
      font-size: calc(var(--description-font-size) * 0.8);
      line-height: 1.6;
    }
    .slide-counter { top: 100px; right: 15px; }
    .slide-counter__current { font-size: 32px; }
    .slide-counter__divider { width: 30px; margin: 5px 0 5px auto; }
    .slide-counter__total { font-size: 16px; }
    .epic-intro__title { font-size: clamp(36px, 12vw, 60px); }
    
    .epic-btn {
      padding: 14px 30px;
      font-size: 12px;
    }
    .epic-intro__action {
      flex-direction: column;
      width: min(92vw, 360px);
      margin-left: auto;
      margin-right: auto;
    }
    .epic-intro__action .epic-btn {
      width: 100%;
    }
  }
</style>

{%- liquid
  assign is_uk = false
  if request.locale and request.locale.iso_code
    if request.locale.iso_code contains 'uk'
      assign is_uk = true
    endif
  endif

  assign intro_nav_text = 'INTRO'
  if is_uk
    assign intro_nav_text = 'ІНТРО'
  endif

  assign one_company_logo_url = section.settings.one_company_logo_url | strip
  if one_company_logo_url == blank
    assign one_company_logo_url = 'https://onecompany.global/branding/logo-light.svg'
  endif

  assign urban_logo_url = section.settings.urban_logo_url | strip
  if urban_logo_url == blank
    assign urban_logo_url = 'https://smgassets.blob.core.windows.net/customers/urban/dist/img/svgs/logo.svg'
  endif

  assign intro_label_text = section.settings.intro_label
  if is_uk and section.settings.intro_label_ua != blank
    assign intro_label_text = section.settings.intro_label_ua
  elsif section.settings.intro_label_en != blank
    assign intro_label_text = section.settings.intro_label_en
  endif

  assign intro_title_text = section.settings.intro_title
  if is_uk and section.settings.intro_title_ua != blank
    assign intro_title_text = section.settings.intro_title_ua
  elsif section.settings.intro_title_en != blank
    assign intro_title_text = section.settings.intro_title_en
  endif
  if is_uk and intro_title_text == 'ПОЗА|СТОК'
    assign intro_title_text = 'ПОЗА|СТАНДАРТАМИ'
  endif
  if intro_title_text == 'BEYOND|STOCK'
    assign intro_title_text = 'BEYOND|THE ORDINARY'
  endif

  assign intro_subtitle_text = section.settings.intro_subtitle
  if is_uk and section.settings.intro_subtitle_ua != blank
    assign intro_subtitle_text = section.settings.intro_subtitle_ua
  elsif section.settings.intro_subtitle_en != blank
    assign intro_subtitle_text = section.settings.intro_subtitle_en
  endif

  assign intro_about_text = section.settings.intro_about
  if is_uk and section.settings.intro_about_ua != blank
    assign intro_about_text = section.settings.intro_about_ua
  elsif section.settings.intro_about_en != blank
    assign intro_about_text = section.settings.intro_about_en
  endif

  assign catalog_label_text = section.settings.catalog_label
  if is_uk and section.settings.catalog_label_ua != blank
    assign catalog_label_text = section.settings.catalog_label_ua
  elsif section.settings.catalog_label_en != blank
    assign catalog_label_text = section.settings.catalog_label_en
  endif

  assign scroll_text = section.settings.scroll_text
  if is_uk and section.settings.scroll_text_ua != blank
    assign scroll_text = section.settings.scroll_text_ua
  elsif section.settings.scroll_text_en != blank
    assign scroll_text = section.settings.scroll_text_en
  endif

  assign secondary_label_text = section.settings.secondary_label
  if is_uk and section.settings.secondary_label_ua != blank
    assign secondary_label_text = section.settings.secondary_label_ua
  elsif section.settings.secondary_label_en != blank
    assign secondary_label_text = section.settings.secondary_label_en
  endif

  assign stat1_label_text = section.settings.stat1_label
  if is_uk and section.settings.stat1_label_ua != blank
    assign stat1_label_text = section.settings.stat1_label_ua
  elsif section.settings.stat1_label_en != blank
    assign stat1_label_text = section.settings.stat1_label_en
  endif

  assign stat2_label_text = section.settings.stat2_label
  if is_uk and section.settings.stat2_label_ua != blank
    assign stat2_label_text = section.settings.stat2_label_ua
  elsif section.settings.stat2_label_en != blank
    assign stat2_label_text = section.settings.stat2_label_en
  endif

  assign stat3_label_text = section.settings.stat3_label
  if is_uk and section.settings.stat3_label_ua != blank
    assign stat3_label_text = section.settings.stat3_label_ua
  elsif section.settings.stat3_label_en != blank
    assign stat3_label_text = section.settings.stat3_label_en
  endif
-%}

<div class="epic-showcase" data-section-id="{{ section.id }}">
  <!-- Preloader -->
  <div class="epic-preloader">
    <div class="epic-preloader__logo">
      <img class="epic-preloader__logo-one" src="{{ one_company_logo_url }}" alt="One Company" width="422" height="155" loading="eager">
      <span class="epic-preloader__logo-x" aria-hidden="true">×</span>
      <img class="epic-preloader__logo-urban" src="{{ urban_logo_url }}" alt="Urban Automotive" width="643" height="102" loading="eager">
    </div>
    <div class="epic-preloader__bar">
      <div class="epic-preloader__progress"></div>
    </div>
    <div class="epic-preloader__percent">0%</div>
  </div>

  <!-- Custom Cursor -->
  <div class="epic-cursor"></div>
  <div class="epic-cursor-ring"></div>
  <div class="nav-tooltip">Tooltip</div>

  <!-- Progress Bar -->
  <div class="progress-bar">
    <div class="progress-bar__fill"></div>
  </div>

  <!-- Slide Counter -->
  <div class="slide-counter">
    <div class="slide-counter__current">01</div>
    <div class="slide-counter__divider"></div>
    <div class="slide-counter__total">
      {%- assign total_slides = section.blocks.size | plus: 1 -%}
      {%- if total_slides < 10 -%}0{%- endif -%}{{ total_slides }}
    </div>
  </div>

  <!-- Navigation Dots -->
  <div class="nav-dots">
    <div class="nav-dot active" data-slide="0" data-title="{{ intro_nav_text }}"></div>
    {% for block in section.blocks %}
      {%- assign nav_title = block.settings.title -%}
      {%- if is_uk and block.settings.title_ua != blank -%}
        {%- assign nav_title = block.settings.title_ua -%}
      {%- elsif block.settings.title_en != blank -%}
        {%- assign nav_title = block.settings.title_en -%}
      {%- endif -%}
      <div class="nav-dot" data-slide="{{ forloop.index }}" data-title="{{ nav_title | escape }}"></div>
    {% endfor %}
  </div>

  <div class="epic-slides-wrapper">
    <!-- Epic Intro -->
    <div class="epic-intro" data-slide-index="0">
      {% if section.settings.intro_video != blank %}
        <video 
          class="epic-intro__video"
          autoplay
          muted 
          loop 
          playsinline
          preload="auto"
        >
          <source src="{{ section.settings.intro_video }}#t=20" type="video/mp4">
        </video>
      {% endif %}

      <div class="epic-intro__overlay"></div>
      <div class="epic-intro__grain"></div>
      <canvas class="epic-intro__particles"></canvas>
      
      <div class="pause-indicator">
        <svg viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </div>
      
      <div class="epic-intro__content">
        <div class="epic-intro__brandbar">
          <img class="epic-intro__brandbar-logo epic-intro__brandbar-logo--one" src="{{ one_company_logo_url }}" alt="One Company" width="422" height="155" loading="eager">
          <span class="epic-intro__brandbar-x">x</span>
          <img class="epic-intro__brandbar-logo epic-intro__brandbar-logo--urban" src="{{ urban_logo_url }}" alt="Urban Automotive" width="643" height="102" loading="eager">
        </div>
        <div class="epic-intro__label">{{ intro_label_text }}</div>
        <h1 class="epic-intro__title">
          {% assign lines = intro_title_text | split: '|' %}
          {% for line in lines %}
            <div class="epic-intro__title-word" data-text="{{ line | strip }}">
              {{ line | strip }}
            </div>
          {% endfor %}
        </h1>
        <div class="epic-intro__subtitle">{{ intro_subtitle_text }}</div>
        {% if intro_about_text != blank %}
          <div class="epic-intro__about">{{ intro_about_text }}</div>
        {% endif %}
        
        <!-- КНОПКА КАТАЛОГУ -->
        <div class="epic-intro__action no-swipe">
          <a href="{{ section.settings.catalog_url }}" class="epic-btn">
            {{ catalog_label_text }}
          </a>
          {% if secondary_label_text != blank and section.settings.secondary_url != blank %}
            <a
              href="{{ section.settings.secondary_url }}"
              class="epic-btn epic-btn--ghost"
              {% if section.settings.secondary_new_tab %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
            >
              {{ secondary_label_text }}
            </a>
          {% endif %}
        </div>

        <div class="epic-intro__stats">
          <div class="epic-stat" data-count="{{ section.settings.stat1_num }}">
            <span class="epic-stat__number">0</span>
            <span class="epic-stat__label">{{ stat1_label_text }}</span>
          </div>
          <div class="epic-stat" data-count="{{ section.settings.stat2_num }}">
            <span class="epic-stat__number">0</span>
            <span class="epic-stat__label">{{ stat2_label_text }}</span>
          </div>
          <div class="epic-stat" data-count="{{ section.settings.stat3_num }}">
            <span class="epic-stat__number">0</span>
            <span class="epic-stat__label">{{ stat3_label_text }}</span>
          </div>
        </div>

      </div>

      <div class="epic-intro__scroll">
        <div class="epic-intro__scroll-text">{{ scroll_text }}</div> 
        <div class="epic-intro__scroll-line">
          <div class="epic-intro__scroll-dot"></div>
        </div>
      </div>
    </div>

    <!-- Video Slides -->
    {% for block in section.blocks %}
      <div class="epic-slide" data-slide-index="{{ forloop.index }}" {{ block.shopify_attributes }}>
        {%- assign slide_title = block.settings.title -%}
        {%- assign slide_description = block.settings.description -%}
        {%- if is_uk -%}
          {%- if block.settings.title_ua != blank -%}{%- assign slide_title = block.settings.title_ua -%}{%- endif -%}
          {%- if block.settings.description_ua != blank -%}{%- assign slide_description = block.settings.description_ua -%}{%- endif -%}
        {%- else -%}
          {%- if block.settings.title_en != blank -%}{%- assign slide_title = block.settings.title_en -%}{%- endif -%}
          {%- if block.settings.description_en != blank -%}{%- assign slide_description = block.settings.description_en -%}{%- endif -%}
        {%- endif -%}
        {% if block.settings.video != blank %}
          <video 
            class="epic-slide__video"
            muted 
            loop 
            playsinline
            preload="metadata"
          >
            <source src="{{ block.settings.video }}#t=20" type="video/mp4">
          </video>
        {% endif %}

        <div class="epic-slide__overlay"></div>
        <div class="epic-slide__grain"></div>

        <div class="pause-indicator">
          <svg viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </div>

        <div class="epic-slide__content">
          <div class="epic-slide__number">
            {%- if forloop.index < 9 -%}0{%- endif -%}{{ forloop.index | plus: 1 }} / 
            {%- if total_slides < 10 -%}0{%- endif -%}{{ total_slides }}
          </div>
          {% if slide_title != blank %}
            <h2 class="epic-slide__title">{{ slide_title }}</h2>
          {% endif %}
          <div class="epic-slide__divider"></div>
          {% if slide_description != blank %}
            <p class="epic-slide__description">{{ slide_description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Observer.min.js"></script>

<script>
(function() {
  'use strict';

  // v5.9: Force scroll to top on load to prevent header disappearing
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }
  window.scrollTo(0, 0);

  const sectionEl = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!sectionEl) return;
  
  const isDesktop = window.matchMedia("(min-width: 1024px)").matches;

  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin, Observer);

  function updateAccentColor() {
    try {
      const accentHex = getComputedStyle(sectionEl).getPropertyValue('--accent').trim();
      let hex = accentHex.replace('#', '');
      if (hex.length === 3) hex = hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
      const r = parseInt(hex.substring(0, 2), 16);
      const g = parseInt(hex.substring(2, 4), 16);
      const b = parseInt(hex.substring(4, 6), 16);
      sectionEl.style.setProperty('--accent-rgb', `${r}, ${g}, ${b}`);
    } catch (e) { console.error('Accent color error', e); }
  }
  updateAccentColor();
  
  // ===== MOUSE PARALLAX =====
  function kineticParallax(e) {
    const relX = (e.clientX - window.innerWidth / 2) / window.innerWidth;
    const relY = (e.clientY - window.innerHeight / 2) / window.innerHeight;
    gsap.to('.epic-intro__content', { x: -relX * 50, y: -relY * 30, duration: 1, ease: 'power1.out' });
    
    const activeSlideContent = slides[currentSlide].querySelector('.epic-slide__content');
    if (activeSlideContent) {
      gsap.to(activeSlideContent, { x: -relX * 50, y: -relY * 30, duration: 1, ease: 'power1.out' });
    }
  }

  // ===== PRELOADER =====
  const preloader = sectionEl.querySelector('.epic-preloader');
  const preloaderProgress = sectionEl.querySelector('.epic-preloader__progress');
  const preloaderPercent = sectionEl.querySelector('.epic-preloader__percent');

  let progress = 0;
  const progressInterval = setInterval(() => {
    try {
      let randomAmount = progress < 70 ? Math.random() * 5 : Math.random() * 2;
      progress += randomAmount;
      if (progress > 100) progress = 100;
      
      if (preloaderProgress) preloaderProgress.style.width = progress + '%';
      if (preloaderPercent) preloaderPercent.textContent = Math.floor(progress) + '%';
      
      if (progress >= 100) {
        clearInterval(progressInterval);
        setTimeout(() => {
          gsap.to(preloader, {
            opacity: 0, duration: 0.8, ease: 'power3.inOut',
            onComplete: () => {
              if (preloader) preloader.style.display = 'none';
              initMobileScroll();
              startMainAnimations();
            }
          });
        }, 500);
      }
    } catch (e) {
      clearInterval(progressInterval);
      if (preloader) preloader.style.display = 'none';
      initMobileScroll();
      startMainAnimations();
    }
  }, 80);

  // ===== CURSOR =====
  const cursor = sectionEl.querySelector('.epic-cursor');
  const cursorRing = sectionEl.querySelector('.epic-cursor-ring');
  const trails = [];
  const trailCount = 8;
  let mouseX = 0, mouseY = 0;
  let cursorX = 0, cursorY = 0;
  let ringX = 0, ringY = 0;

  function animateCursor() {
    cursorX += (mouseX - cursorX) * 0.2;
    cursorY += (mouseY - cursorY) * 0.2;
    ringX += (mouseX - ringX) * 0.1;
    ringY += (mouseY - ringY) * 0.1;
    if (cursor) cursor.style.transform = `translate(${cursorX}px, ${cursorY}px) translate(-50%, -50%)`;
    if (cursorRing) cursorRing.style.transform = `translate(${ringX}px, ${ringY}px) translate(-50%, -50%)`;

    trails.forEach((trail, i) => {
      const targetX = i === 0 ? cursorX : trails[i - 1].x;
      const targetY = i === 0 ? cursorY : trails[i - 1].y;
      trail.x += (targetX - trail.x) * (0.1 - i * 0.01);
      trail.y += (targetY - trail.y) * (0.1 - i * 0.01);
      trail.element.style.transform = `translate(${trail.x}px, ${trail.y}px) translate(-50%, -50%) scale(${(trailCount - i) / trailCount})`;
      trail.element.style.opacity = (trailCount - i) / trailCount * 0.5;
    });
    requestAnimationFrame(animateCursor);
  }
  
  if (isDesktop && window.matchMedia("(pointer: fine)").matches) {
    const tooltip = sectionEl.querySelector('.nav-tooltip');
    for (let i = 0; i < trailCount; i++) {
      const trail = document.createElement('div');
      trail.className = 'cursor-trail';
      sectionEl.appendChild(trail);
      trails.push({ element: trail, x: 0, y: 0 });
    }
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (tooltip && tooltip.classList.contains('visible')) {
        tooltip.style.transform = `translate(${mouseX}px, ${mouseY}px) translate(20px, -40px) scale(1)`;
      }
    });
    animateCursor();
    
    sectionEl.querySelectorAll('a, button, .nav-dot, .epic-intro__scroll').forEach(el => {
      el.addEventListener('mouseenter', () => {
        if(cursor) cursor.classList.add('magnetic');
        if(cursorRing) cursorRing.classList.add('magnetic');
      });
      el.addEventListener('mouseleave', () => {
        if(cursor) cursor.classList.remove('magnetic');
        if(cursorRing) cursorRing.classList.remove('magnetic');
        gsap.to(el, { x: 0, y: 0, duration: 0.3, ease: 'power2.out' });
      });
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(el, { x: x * 0.3, y: y * 0.3, duration: 0.3, ease: 'power2.out' });
      });
    });
    
    if (tooltip) {
      sectionEl.querySelectorAll('.nav-dot').forEach(dot => {
        dot.addEventListener('mouseenter', (e) => {
          const title = dot.getAttribute('data-title');
          if (title) {
            tooltip.textContent = title;
            tooltip.classList.add('visible');
            tooltip.style.transform = `translate(${mouseX}px, ${mouseY}px) translate(20px, -40px) scale(1)`;
          }
        });
        dot.addEventListener('mouseleave', () => {
          tooltip.classList.remove('visible');
          tooltip.style.transform = `translate(${mouseX}px, ${mouseY}px) translate(20px, -40px) scale(0.8)`;
        });
      });
    }
    document.addEventListener('mousemove', kineticParallax);
  } else {
    if (cursor) cursor.remove();
    if (cursorRing) cursorRing.remove();
    if (sectionEl.querySelector('.nav-tooltip')) sectionEl.querySelector('.nav-tooltip').remove();
  }

  // ===== PARTICLES =====
  const canvasParticles = sectionEl.querySelector('.epic-intro__particles');
  const ctxParticles = canvasParticles ? canvasParticles.getContext('2d') : null;
  let particleAnimationId; 

  function resizeParticlesCanvas() {
    if (!canvasParticles) return;
    canvasParticles.width = sectionEl.clientWidth;
    canvasParticles.height = sectionEl.clientHeight;
  }
  resizeParticlesCanvas();
  new ResizeObserver(resizeParticlesCanvas).observe(sectionEl);

  const particles = [];
  const particleCount = 40; 

  class Particle {
    constructor() { this.reset(); }
    reset() {
      if (!canvasParticles) return;
      this.x = Math.random() * canvasParticles.width;
      this.y = Math.random() * canvasParticles.height;
      this.size = Math.random() * 2.5 + 0.5;
      this.speedX = (Math.random() - 0.5) * 0.4;
      this.speedY = (Math.random() - 0.5) * 0.4;
      this.opacity = Math.random() * 0.6 + 0.2;
      this.isAccent = Math.random() > 0.9;
    }
    update() {
      this.x += this.speedX;
      this.y += this.speedY;
      if (canvasParticles && (this.x < 0 || this.x > canvasParticles.width)) this.speedX *= -1;
      if (canvasParticles && (this.y < 0 || this.y > canvasParticles.height)) this.speedY *= -1;
      
      if (isDesktop) { 
        const dx = mouseX - this.x;
        const dy = mouseY - this.y;
        const distance = Math.sqrt(dx * dx + dy * dy);
        if (distance < 100) {
          this.x -= dx / distance * 2;
          this.y -= dy / distance * 2;
        }
      }
    }
    draw() {
      if (!ctxParticles) return;
      if (this.isAccent) ctxParticles.fillStyle = `rgba(var(--accent-rgb), ${this.opacity * 0.8})`;
      else ctxParticles.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
      ctxParticles.beginPath();
      ctxParticles.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctxParticles.fill();
    }
  }
  
  if (canvasParticles) {
    for (let i = 0; i < particleCount; i++) particles.push(new Particle());
  }

  function animateParticles() {
    if (!ctxParticles || !canvasParticles) {
       particleAnimationId = requestAnimationFrame(animateParticles);
       return;
    }
    ctxParticles.clearRect(0, 0, canvasParticles.width, canvasParticles.height);
    particles.forEach(p => { p.update(); p.draw(); });
    particles.forEach((p1, i) => {
      particles.slice(i + 1).forEach(p2 => {
        const dx = p1.x - p2.x;
        const dy = p1.y - p2.y;
        const distance = Math.sqrt(dx * dx + dy * dy);
        if (distance < 120) {
          if (p1.isAccent || p2.isAccent) ctxParticles.strokeStyle = `rgba(var(--accent-rgb), ${0.1 * (1 - distance / 120)})`;
          else ctxParticles.strokeStyle = `rgba(255, 255, 255, ${0.15 * (1 - distance / 120)})`;
          ctxParticles.lineWidth = 0.5;
          ctxParticles.beginPath();
          ctxParticles.moveTo(p1.x, p1.y);
          ctxParticles.lineTo(p2.x, p2.y);
          ctxParticles.stroke();
        }
      });
    });
    particleAnimationId = requestAnimationFrame(animateParticles);
  }

  // ===== ANIMATIONS =====
  function startMainAnimations() {
    const titleWords = sectionEl.querySelectorAll('.epic-intro__title-word');
    titleWords.forEach(word => {
      const text = word.getAttribute('data-text');
      if (text) {
        word.innerHTML = '';
        text.split('').forEach(char => {
          const span = document.createElement('span');
          span.className = 'epic-intro__title-char';
          span.textContent = char === ' ' ? '\u00A0' : char;
          word.appendChild(span);
        });
      }
    });

    const introTl = gsap.timeline({ delay: 0.3 });
    introTl
      .to('.epic-intro__brandbar', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
      .to('.epic-intro__label', { opacity: 1, duration: 1, ease: 'power3.out' })
      .to('.epic-intro__title-char', {
        y: '0%', rotateX: 0, opacity: 1, stagger: { each: 0.03, from: 'start' }, duration: 1.2, ease: 'power4.out'
      }, '-=0.5')
      .to('.epic-intro__subtitle', { opacity: 1, duration: 1, ease: 'power3.out' }, '-=0.8')
      .to('.epic-intro__about', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.6')
      .to('.epic-intro__action', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.4')
      .to('.epic-intro__stats', { opacity: 1, duration: 1, ease: 'power3.out' }, '-=0.3')
      .add(() => animateCounters(), '-=0.3')
      .to('.epic-intro__scroll', { opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.3');
      
    if (isDesktop) {
      introTl.to('.epic-intro__scroll', {
        scale: 1.05, repeat: -1, yoyo: true, duration: 1.5, ease: 'power1.inOut'
      }, '-=1');
    }
  }

  function animateCounters() {
    sectionEl.querySelectorAll('.epic-stat').forEach((stat, index) => {
      const numberEl = stat.querySelector('.epic-stat__number');
      const target = stat.getAttribute('data-count');
      if (!numberEl || !target) return;
      const targetNum = parseInt(target.replace('+', '')) || 0;
      const hasPlus = target.includes('+');
      let counter = { value: 0 };
      gsap.to(counter, {
        value: targetNum, duration: 2.5, ease: 'power3.out', delay: index * 0.1,
        onUpdate: () => { numberEl.textContent = Math.floor(counter.value) + (hasPlus ? '+' : ''); }
      });
      gsap.to(stat, {
        scrollTrigger: {
          trigger: stat, start: 'top 90%', toggleActions: 'play none none none',
          scroller: isDesktop ? sectionEl : window, 
        },
        onComplete: () => stat.classList.add('active'),
        delay: index * 0.2
      });
    });
  }

  // ===== SLIDES LOGIC =====
  const slides = gsap.utils.toArray(".epic-intro, .epic-slide");
  const wrapper = sectionEl.querySelector(".epic-slides-wrapper");
  const progressFill = sectionEl.querySelector('.progress-bar__fill');
  const counterCurrent = sectionEl.querySelector('.slide-counter__current');
  const navDots = sectionEl.querySelectorAll('.nav-dot');
  const totalSlides = slides.length;
  let currentSlide = 0;
  let isAnimating = false;
  let observerInstance = null;
  let hasReleasedScroll = false;

  // Click to Pause Logic
  sectionEl.querySelectorAll('.epic-intro, .epic-slide').forEach(slide => {
    slide.addEventListener('click', (e) => {
      if (e.target.closest('a, button, .epic-intro__scroll, .nav-dot, .epic-btn')) return;
      
      const video = slide.querySelector('video');
      if (video) {
        if (video.paused) {
          video.play();
          slide.classList.remove('paused');
        } else {
          video.pause();
          slide.classList.add('paused');
        }
      }
    });
  });

  function initDesktopScroll() {
    sectionEl.querySelectorAll('.epic-intro__overlay, .epic-slide__overlay').forEach(el => {
      el.classList.add('spotlight-active');
    });

    gsap.set(wrapper, { y: 0 });

    function releaseToPageScroll() {
      if (hasReleasedScroll) return;
      hasReleasedScroll = true;
      sectionEl.classList.remove('desktop-scroll-active');
      if (observerInstance) observerInstance.disable();
    }

    function lockToSection() {
      if (!hasReleasedScroll) return;
      hasReleasedScroll = false;
      sectionEl.classList.add('desktop-scroll-active');
      if (observerInstance) observerInstance.enable();
    }

    function gotoSlide(index) {
      index = gsap.utils.clamp(0, totalSlides - 1, index);
      if (isAnimating || index === currentSlide) return;
      isAnimating = true;
      const targetY = -index * window.innerHeight;

      gsap.to(wrapper, {
        y: targetY, duration: 1.4, ease: 'power3.inOut',
        onComplete: () => { isAnimating = false; }
      });
      updateSlideUI(index);
    }

    observerInstance = Observer.create({
      target: window,
      type: "wheel,touch,pointer",
      wheelSpeed: -1,
      onUp: () => {
        if (isAnimating) return;
        if (currentSlide >= totalSlides - 1) {
          releaseToPageScroll();
          return;
        }
        gotoSlide(currentSlide + 1);
      },
      onDown: () => {
        if (isAnimating) return;
        if (currentSlide <= 0) return;
        gotoSlide(currentSlide - 1);
      },
      onWheel: (self) => {
        if (isAnimating) return;
        if (self.deltaY > 0) {
          if (currentSlide >= totalSlides - 1) {
            releaseToPageScroll();
            return;
          }
          gotoSlide(currentSlide + 1);
        } else if (self.deltaY < 0) {
          if (currentSlide <= 0) return;
          gotoSlide(currentSlide - 1);
        }
      },
      tolerance: 10,
      preventDefault: true
    });
    
    const noSwipeElements = sectionEl.querySelectorAll('.no-swipe');
    noSwipeElements.forEach(el => {
      el.addEventListener('mouseenter', () => {
        if(observerInstance) observerInstance.disable();
      });
      el.addEventListener('mouseleave', () => {
        if(observerInstance) observerInstance.enable();
      });
    });

    document.addEventListener('keydown', (e) => {
      if (isAnimating) return;
      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        e.preventDefault();
        gotoSlide(currentSlide + 1);
      } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        e.preventDefault();
        gotoSlide(currentSlide - 1);
      }
    });

    navDots.forEach((dot, index) => {
      dot.addEventListener('click', () => gotoSlide(index));
    });

    const introScroll = sectionEl.querySelector('.epic-intro__scroll');
    if (introScroll) {
      introScroll.addEventListener('click', () => gotoSlide(1));
    }
    
    ScrollTrigger.create({
      trigger: sectionEl, start: "top top", end: "bottom bottom",
      onRefresh: () => { if (!isAnimating) gsap.set(wrapper, { y: -currentSlide * window.innerHeight }); }
    });

    ScrollTrigger.create({
      trigger: sectionEl,
      start: "top top",
      end: "bottom top",
      onEnter: () => {
        if (hasReleasedScroll) lockToSection();
      },
      onEnterBack: () => {
        lockToSection();
      },
      onLeave: () => {
        if (observerInstance) observerInstance.disable();
      },
      onLeaveBack: () => {
        if (observerInstance) observerInstance.disable();
      }
    });
    
    if (slides.length > 0) triggerSlideAnimations(slides[0]);
  }

  function initMobileScroll() {
    ScrollTrigger.create({
      trigger: wrapper, start: "top top", end: "bottom bottom",
      onUpdate: (self) => { gsap.to(progressFill, { width: self.progress * 100 + '%', ease: 'none' }); }
    });
    
    slides.forEach((slide, index) => {
      const video = slide.querySelector('.epic-intro__video, .epic-slide__video');
      if (video) {
        gsap.fromTo(video,
          { opacity: 0.2, scale: 1.08 },
          {
            opacity: 1,
            scale: 1,
            duration: 1,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: slide,
              start: 'top 80%',
              end: 'top 40%',
              toggleActions: 'play none none reverse'
            }
          }
        );
        gsap.to(video, {
          yPercent: -20, ease: "none",
          scrollTrigger: {
            trigger: slide, start: "top bottom", end: "bottom top", scrub: true
          }
        });
      }
      
      if (slide.classList.contains('epic-intro')) {
        gsap.to('.epic-intro__content', {
          opacity: 0, ease: "none",
          scrollTrigger: { trigger: slide, start: "top top", end: "50% top", scrub: true }
        });
      } else {
        const content = slide.querySelector('.epic-slide__content');
        if (content) {
          gsap.fromTo(content,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.9,
              ease: 'power2.out',
              scrollTrigger: { trigger: slide, start: 'top 70%', toggleActions: 'play none none reverse' }
            }
          );
        }
      }

      const number = slide.querySelector('.epic-slide__number');
      const title = slide.querySelector('.epic-slide__title');
      const divider = slide.querySelector('.epic-slide__divider');
      const description = slide.querySelector('.epic-slide__description');
      
      if (title) {
        const contentTl = gsap.timeline({
          scrollTrigger: { trigger: slide, start: "top 60%", toggleActions: "play none none none" }
        });
        gsap.set(number, { opacity: 0, y: 20 });
        gsap.set(title, { opacity: 1, y: 50, clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
        gsap.set(description, { opacity: 1, y: 20, clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
        gsap.set(divider, { opacity: 0, scaleX: 0 });

        contentTl
          .to(number, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
          .to(title, { y: 0, clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)', duration: 1, ease: 'power4.out' }, '-=0.5')
          .to(divider, { opacity: 1, scaleX: 1, duration: 1.2, ease: 'elastic.out(1, 0.5)' }, '-=0.7')
          .to(description, { y: 0, clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)', duration: 1, ease: 'power3.out' }, '-=0.5');
      }

      ScrollTrigger.create({
        trigger: slide, start: "top 50%", end: "bottom 50%",
        onEnter: () => updateSlideUI(index), onEnterBack: () => updateSlideUI(index)
      });
    });

    navDots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        gsap.to(window, { scrollTo: { y: slides[index], offsetY: 0 }, duration: 1.2, ease: 'power3.inOut' });
      });
    });

    const introScroll = sectionEl.querySelector('.epic-intro__scroll');
    if (introScroll) {
      introScroll.addEventListener('click', () => {
        gsap.to(window, { scrollTo: { y: slides[1], offsetY: 0 }, duration: 1.2, ease: 'power3.inOut' });
      });
    }
    if (slides.length > 0) triggerSlideAnimations(slides[0]);
  }


  function updateSlideUI(index) {
    if (currentSlide === index && !isDesktop) return;
    if (isDesktop && currentSlide === index) return;
    
    currentSlide = index;

    if (isDesktop) {
      if (index >= totalSlides - 1) {
        if (typeof releaseToPageScroll === 'function') {
          releaseToPageScroll();
        }
      } else if (hasReleasedScroll) {
        if (typeof lockToSection === 'function') {
          lockToSection();
        }
      }
    }

    const displayIndex = index + 1;
    if (counterCurrent) counterCurrent.textContent = displayIndex < 10 ? '0' + displayIndex : displayIndex;

    navDots.forEach((dot, i) => dot.classList.toggle('active', i === index));

    if (isDesktop) {
      gsap.to(progressFill, { width: (index / (totalSlides - 1)) * 100 + '%', duration: 0.5, ease: 'power2.out' });
    }
    
    if (isDesktop && slides.length > currentSlide) {
      gsap.to('.epic-slide__content', { x: 0, y: 0, duration: 0.5, ease: 'power1.out' });
    }
    
    if (slides.length > index) triggerSlideAnimations(slides[index]);
  }

  function triggerSlideAnimations(slide) {
    if (!slide) return;
    sectionEl.querySelectorAll('video').forEach(v => {
      v.pause();
      gsap.set(v, { scale: 1.1, duration: 0.1 });
      v.closest('.epic-intro, .epic-slide').classList.remove('paused');
    });
    
    if (slide.classList.contains('epic-intro')) {
      if (!particleAnimationId && canvasParticles) animateParticles();
    } else {
      if (particleAnimationId) {
        cancelAnimationFrame(particleAnimationId);
        particleAnimationId = null;
      }
    }
    
    const activeVideo = slide.querySelector('video');
    if (activeVideo) {
      if (activeVideo.readyState >= 3) {
       const playPromise = activeVideo.play();
       if (playPromise !== undefined) playPromise.catch(e => {});
       gsap.to(activeVideo, { scale: 1, duration: 10, ease: 'none' });
      } else {
       activeVideo.addEventListener('canplay', () => {
         const playPromise = activeVideo.play();
         if (playPromise !== undefined) playPromise.catch(e => {});
         gsap.to(activeVideo, { scale: 1, duration: 10, ease: 'none' });
       }, { once: true });
      }
    }

    if (isDesktop) {
      const number = slide.querySelector('.epic-slide__number');
      const title = slide.querySelector('.epic-slide__title');
      const divider = slide.querySelector('.epic-slide__divider');
      const description = slide.querySelector('.epic-slide__description');

      if (title) {
        gsap.set(number, { opacity: 0, y: 20 });
        gsap.set(title, { opacity: 1, y: 50, clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
        gsap.set(description, { opacity: 1, y: 20, clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
        gsap.set(divider, { opacity: 0, scaleX: 0 });
        
        const contentTl = gsap.timeline({ delay: 0.5 });
        contentTl
          .to(number, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
          .to(title, { y: 0, clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)', duration: 1, ease: 'power4.out' }, '-=0.5')
          .to(divider, { opacity: 1, scaleX: 1, duration: 1.2, ease: 'elastic.out(1, 0.5)' }, '-=0.7')
          .to(description, { y: 0, clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)', duration: 1, ease: 'power3.out' }, '-=0.5');
      }
    }
  }

  sectionEl.querySelectorAll('video').forEach(video => {
    video.muted = true;
  });

})();
</script>

