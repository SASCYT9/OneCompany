{% liquid
  assign carousel_id = 'UrbanGallery-' | append: section.id
  assign is_uk = false
  if request.locale and request.locale.iso_code
    if request.locale.iso_code contains 'uk'
      assign is_uk = true
    endif
  endif
%}

<section id="{{ carousel_id }}" class="urban-gallery">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;600&display=swap');

    #{{ carousel_id }} {
      --gallery-bg: {{ section.settings.background_color }};
      --gallery-border: {{ section.settings.border_color }};
      --gallery-padding-top: {{ section.settings.padding_top }}px;
      --gallery-padding-bottom: {{ section.settings.padding_bottom }}px;
      background: var(--gallery-bg);
      padding-top: var(--gallery-padding-top);
      padding-bottom: var(--gallery-padding-bottom);
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      overflow: hidden;
      position: relative;
    }

    #{{ carousel_id }} .urban-gallery__header {
      max-width: min(1600px, 92vw);
      margin: 0 auto clamp(20px, 3vw, 40px);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
      padding: 0 clamp(16px, 2vw, 24px);
    }

    #{{ carousel_id }} .urban-gallery__label {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      font-size: clamp(11px, 1vw, 13px);
      color: rgba(255, 255, 255, 0.6);
      font-weight: 500;
    }

    #{{ carousel_id }} .urban-gallery__nav {
      display: flex;
      gap: 8px;
    }

    #{{ carousel_id }} .urban-gallery__arrow {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: transparent;
      color: #fff;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.25s ease, border-color 0.25s ease;
    }

    #{{ carousel_id }} .urban-gallery__arrow:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.5);
    }

    #{{ carousel_id }} .urban-gallery__arrow:disabled {
      opacity: 0.3;
      cursor: default;
    }

    #{{ carousel_id }} .urban-gallery__arrow svg {
      width: 18px;
      height: 18px;
    }

    #{{ carousel_id }} .urban-gallery__track-wrapper {
      position: relative;
      cursor: grab;
    }

    #{{ carousel_id }} .urban-gallery__track-wrapper.is-dragging {
      cursor: grabbing;
    }

    #{{ carousel_id }} .urban-gallery__track {
      display: flex;
      gap: clamp(8px, 1.2vw, 16px);
      padding: 0 clamp(16px, 3vw, 48px);
      transition: transform 0.55s cubic-bezier(0.25, 1, 0.5, 1);
      will-change: transform;
    }

    #{{ carousel_id }} .urban-gallery__track-wrapper.is-dragging .urban-gallery__track {
      transition: none;
    }

    #{{ carousel_id }} .urban-gallery__slide {
      flex: 0 0 auto;
      width: clamp(280px, 42vw, 720px);
      position: relative;
      overflow: hidden;
      border: 1px solid var(--gallery-border);
    }

    #{{ carousel_id }} .urban-gallery__slide img {
      width: 100%;
      height: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      display: block;
      transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
      pointer-events: none;
    }

    #{{ carousel_id }} .urban-gallery__slide:hover img {
      transform: scale(1.04);
    }

    /* Reveal animation */
    #{{ carousel_id }} .urban-gallery__slide {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    #{{ carousel_id }}.is-visible .urban-gallery__slide {
      opacity: 1;
      transform: translateY(0);
    }

    {% for i in (1..20) %}
    #{{ carousel_id }}.is-visible .urban-gallery__slide:nth-child({{ i }}) {
      transition-delay: {{ i | minus: 1 | times: 0.08 | at_most: 0.6 }}s;
    }
    {% endfor %}

    /* Progress bar */
    #{{ carousel_id }} .urban-gallery__progress {
      max-width: min(1600px, 92vw);
      margin: clamp(16px, 2vw, 28px) auto 0;
      padding: 0 clamp(16px, 2vw, 24px);
    }

    #{{ carousel_id }} .urban-gallery__progress-track {
      height: 1px;
      background: rgba(255, 255, 255, 0.12);
      position: relative;
      overflow: hidden;
    }

    #{{ carousel_id }} .urban-gallery__progress-bar {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      background: rgba(255, 255, 255, 0.6);
      transition: width 0.45s cubic-bezier(0.25, 1, 0.5, 1);
      will-change: width;
    }

    @media (max-width: 749px) {
      #{{ carousel_id }} .urban-gallery__slide {
        width: 82vw;
      }

      #{{ carousel_id }} .urban-gallery__header {
        padding: 0 16px;
      }

      #{{ carousel_id }} .urban-gallery__label {
        letter-spacing: 0.12em;
      }
    }

    #{{ carousel_id }} .urban-gallery__label {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ carousel_id }} .urban-gallery__slide,
      #{{ carousel_id }} .urban-gallery__track,
      #{{ carousel_id }} .urban-gallery__slide img {
        transition: none;
      }
    }
  </style>

  {% if section.blocks.size > 0 %}
    <div class="urban-gallery__header">
      {% if section.settings.label != blank %}
        <p class="urban-gallery__label">
          {%- if is_uk and section.settings.label_uk != blank -%}
            {{ section.settings.label_uk }}
          {%- else -%}
            {{ section.settings.label }}
          {%- endif -%}
        </p>
      {% endif %}
      <div class="urban-gallery__nav">
        <button class="urban-gallery__arrow urban-gallery__arrow--prev" type="button" aria-label="{% if is_uk %}Попередній{% else %}Previous{% endif %}" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <button class="urban-gallery__arrow urban-gallery__arrow--next" type="button" aria-label="{% if is_uk %}Наступний{% else %}Next{% endif %}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div class="urban-gallery__track-wrapper" data-carousel-wrapper>
      <div class="urban-gallery__track" data-carousel-track>
        {% for block in section.blocks %}
          {% liquid
            assign external_url = block.settings.external_image_url | strip
            assign resolved_url = ''
            if external_url != blank
              if external_url contains '://'
                assign resolved_url = external_url
              else
                assign resolved_url = external_url | file_url
              endif
            endif
          %}
          <div class="urban-gallery__slide" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1600 }}"
                alt="{{ block.settings.image.alt | default: block.settings.caption | default: 'Галерея' | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif resolved_url != blank %}
              <img
                src="{{ resolved_url }}"
                alt="{{ block.settings.caption | default: 'Галерея' | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'collection-apparel-2' | placeholder_svg_tag: 'urban-gallery__placeholder' }}
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="urban-gallery__progress">
      <div class="urban-gallery__progress-track">
        <div class="urban-gallery__progress-bar" data-progress-bar style="width: 0%"></div>
      </div>
    </div>
  {% endif %}

  <script>
    (() => {
      const root = document.getElementById('{{ carousel_id }}');
      if (!root || root.dataset.init === '1') return;
      root.dataset.init = '1';

      const wrapper = root.querySelector('[data-carousel-wrapper]');
      const track = root.querySelector('[data-carousel-track]');
      const prevBtn = root.querySelector('.urban-gallery__arrow--prev');
      const nextBtn = root.querySelector('.urban-gallery__arrow--next');
      const progressBar = root.querySelector('[data-progress-bar]');
      if (!wrapper || !track) return;

      let isDragging = false;
      let startX = 0;
      let scrollLeft = 0;
      let currentTranslate = 0;
      let targetTranslate = 0;

      const getMaxScroll = () => track.scrollWidth - wrapper.clientWidth;

      const updateProgress = () => {
        const max = getMaxScroll();
        if (max <= 0) {
          if (progressBar) progressBar.style.width = '100%';
          return;
        }
        const pct = Math.min(Math.abs(currentTranslate) / max * 100, 100);
        if (progressBar) progressBar.style.width = pct + '%';
      };

      const updateButtons = () => {
        const max = getMaxScroll();
        if (prevBtn) prevBtn.disabled = Math.abs(currentTranslate) < 2;
        if (nextBtn) nextBtn.disabled = Math.abs(currentTranslate) >= max - 2;
      };

      const clampTranslate = (val) => {
        const max = getMaxScroll();
        return Math.max(-max, Math.min(0, val));
      };

      const applyTranslate = (val, animate = true) => {
        currentTranslate = clampTranslate(val);
        if (!animate) track.style.transition = 'none';
        track.style.transform = `translate3d(${currentTranslate}px, 0, 0)`;
        if (!animate) requestAnimationFrame(() => { track.style.transition = ''; });
        updateProgress();
        updateButtons();
      };

      /* Arrow navigation */
      const scrollStep = () => wrapper.clientWidth * 0.7;

      if (prevBtn) prevBtn.addEventListener('click', () => {
        targetTranslate = clampTranslate(currentTranslate + scrollStep());
        applyTranslate(targetTranslate);
      });

      if (nextBtn) nextBtn.addEventListener('click', () => {
        targetTranslate = clampTranslate(currentTranslate - scrollStep());
        applyTranslate(targetTranslate);
      });

      /* Drag */
      const pointerDown = (e) => {
        isDragging = true;
        startX = (e.touches ? e.touches[0] : e).clientX;
        scrollLeft = currentTranslate;
        wrapper.classList.add('is-dragging');
      };

      const pointerMove = (e) => {
        if (!isDragging) return;
        const x = (e.touches ? e.touches[0] : e).clientX;
        const delta = x - startX;
        applyTranslate(scrollLeft + delta, false);
      };

      const pointerUp = () => {
        if (!isDragging) return;
        isDragging = false;
        wrapper.classList.remove('is-dragging');
        currentTranslate = clampTranslate(currentTranslate);
        applyTranslate(currentTranslate);
      };

      wrapper.addEventListener('mousedown', pointerDown);
      wrapper.addEventListener('mousemove', pointerMove);
      window.addEventListener('mouseup', pointerUp);
      wrapper.addEventListener('touchstart', pointerDown, { passive: true });
      wrapper.addEventListener('touchmove', pointerMove, { passive: true });
      window.addEventListener('touchend', pointerUp);

      /* Prevent image drag */
      wrapper.addEventListener('dragstart', (e) => e.preventDefault());

      /* Intersection observer for reveal */
      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          root.classList.add('is-visible');
          observer.disconnect();
        }
      }, { threshold: 0.15 });
      observer.observe(root);

      /* Initial state */
      updateProgress();
      updateButtons();
    })();
  </script>
</section>

{% schema %}
{
  "name": "Urban Gallery Carousel",
  "tag": "section",
  "class": "section section-urban-gallery-carousel",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Gallery"
    },
    {
      "type": "text",
      "id": "label_uk",
      "label": "Section label (UA)",
      "default": "Галерея"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#1b1b1b"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "external_image_url",
          "label": "External image URL",
          "info": "Full URL or Shopify filename"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Alt text / caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Urban Gallery Carousel"
    }
  ]
}
{% endschema %}
