{%- assign is_uk = false -%}
{%- if request.locale.iso_code == 'uk' -%}{%- assign is_uk = true -%}{%- endif -%}

{% liquid
  assign overview_id = 'UrbanOverview-' | append: section.id
  assign external_image_url = section.settings.external_image_url | strip
  assign resolved_external_image_url = ''
  if external_image_url != blank
    if external_image_url contains '://'
      assign resolved_external_image_url = external_image_url
    else
      assign resolved_external_image_url = external_image_url | file_url
    endif
  endif
%}

<section id="{{ overview_id }}" class="urban-overview">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;600&display=swap');

    #{{ overview_id }} {
      --overview-bg: {{ section.settings.background_color }};
      --overview-border: {{ section.settings.border_color }};
      --overview-copy: {{ section.settings.copy_color }};
      background: var(--overview-bg);
      color: #fff;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    #{{ overview_id }} .urban-overview__container {
      max-width: min(1600px, 96vw);
      margin: 0 auto;
      border: 1px solid var(--overview-border);
      background: rgba(255, 255, 255, 0.02);
      overflow: hidden;
    }

    #{{ overview_id }} .urban-overview__grid {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 990px) {
      #{{ overview_id }} .urban-overview__grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    #{{ overview_id }} .urban-overview__copy {
      padding: clamp(18px, 4vw, 72px);
    }

    #{{ overview_id }} .urban-overview__eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      font-size: clamp(11px, 1vw, 13px);
      color: rgba(255, 255, 255, 0.78);
      font-weight: 500;
    }

    #{{ overview_id }} .urban-overview__title {
      margin: 12px 0 0;
      text-transform: uppercase;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-size: clamp(36px, 8vw, 112px);
      line-height: 0.94;
      letter-spacing: 0.05em;
      font-weight: 500;
      text-wrap: balance;
    }

    #{{ overview_id }} .urban-overview__badge {
      display: inline-flex;
      margin-top: 16px;
      background: #fff;
      color: #111;
      padding: 5px 12px;
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 0.16em;
      font-weight: 700;
    }

    #{{ overview_id }} .urban-overview__subtitle {
      margin: 20px 0 0;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: clamp(12px, 1.2vw, 15px);
      color: rgba(255, 255, 255, 0.78);
    }

    #{{ overview_id }} .urban-overview__description {
      margin: 18px 0 0;
      color: var(--overview-copy);
      line-height: 1.75;
      font-size: clamp(14px, 1.25vw, 18px);
      max-width: 72ch;
    }

    #{{ overview_id }} .urban-overview__highlights {
      margin-top: 24px;
      display: grid;
      gap: 10px;
    }

    #{{ overview_id }} .urban-overview__highlight {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: clamp(12px, 1vw, 14px);
      color: rgba(255, 255, 255, 0.88);
      padding-left: 16px;
      position: relative;
    }

    #{{ overview_id }} .urban-overview__highlight::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.58em;
      width: 6px;
      height: 6px;
      transform: rotate(45deg);
      background: #fff;
    }

    #{{ overview_id }} .urban-overview__cta {
      margin-top: 26px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 11px 20px;
      border: 1px solid #fff;
      background: #fff;
      color: #111;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 11px;
      font-weight: 700;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

    #{{ overview_id }} .urban-overview__cta:hover {
      transform: translateY(-2px);
      background: transparent;
      color: #fff;
    }

    #{{ overview_id }} .urban-overview__media {
      position: relative;
      min-height: clamp(320px, 55vw, 980px);
      background: #0a0a0a;
      border-left: 1px solid var(--overview-border);
    }

    #{{ overview_id }} .urban-overview__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #{{ overview_id }} .urban-overview__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(0deg, rgba(0, 0, 0, 0.45), transparent 45%);
      pointer-events: none;
    }

    @media (max-width: 989px) {
      #{{ overview_id }} .urban-overview__media {
        border-left: 0;
        border-top: 1px solid var(--overview-border);
      }
    }

    /* ── Mobile text adaptation ── */
    @media (max-width: 749px) {
      #{{ overview_id }} .urban-overview__eyebrow { letter-spacing: 0.12em; }
      #{{ overview_id }} .urban-overview__badge { letter-spacing: 0.08em; }
      #{{ overview_id }} .urban-overview__cta { letter-spacing: 0.08em; font-size: 10px; }
      #{{ overview_id }} .urban-overview__stat-label { letter-spacing: 0.1em; }
    }

    #{{ overview_id }} .urban-overview__title,
    #{{ overview_id }} .urban-overview__subtitle {
      overflow-wrap: break-word;
      word-break: break-word;
    }
  </style>

  <div class="urban-overview__container">
    <div class="urban-overview__grid">
      <div class="urban-overview__copy">
        {% if section.settings.eyebrow != blank %}
          <p class="urban-overview__eyebrow">{% if is_uk and section.settings.eyebrow_uk != blank %}{{ section.settings.eyebrow_uk }}{% else %}{{ section.settings.eyebrow }}{% endif %}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="urban-overview__title">{% if is_uk and section.settings.title_uk != blank %}{{ section.settings.title_uk }}{% else %}{{ section.settings.title }}{% endif %}</h2>
        {% endif %}

        {% if section.settings.badge != blank %}
          <span class="urban-overview__badge">{% if is_uk and section.settings.badge_uk != blank %}{{ section.settings.badge_uk }}{% else %}{{ section.settings.badge }}{% endif %}</span>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <p class="urban-overview__subtitle">{% if is_uk and section.settings.subtitle_uk != blank %}{{ section.settings.subtitle_uk }}{% else %}{{ section.settings.subtitle }}{% endif %}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="urban-overview__description">{% if is_uk and section.settings.description_uk != blank %}{{ section.settings.description_uk }}{% else %}{{ section.settings.description }}{% endif %}</p>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="urban-overview__highlights">
            {% for block in section.blocks %}
              {% if block.settings.text != blank %}
                <p class="urban-overview__highlight" {{ block.shopify_attributes }}>{% if is_uk and block.settings.text_uk != blank %}{{ block.settings.text_uk }}{% else %}{{ block.settings.text }}{% endif %}</p>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a
            class="urban-overview__cta"
            href="{{ section.settings.button_link }}"
            {% if section.settings.button_new_tab %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            {% if is_uk and section.settings.button_label_uk != blank %}{{ section.settings.button_label_uk }}{% else %}{{ section.settings.button_label }}{% endif %}
          </a>
        {% endif %}
      </div>

      <div class="urban-overview__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 2400 }}"
            alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        {% elsif resolved_external_image_url != blank %}
          <img
            src="{{ resolved_external_image_url }}"
            alt="{{ section.settings.title | escape }}"
            loading="lazy"
          >
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'urban-overview__placeholder' }}
        {% endif %}
        <div class="urban-overview__overlay" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Urban Model Overview",
  "tag": "section",
  "class": "section section-urban-model-overview",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Urban Range"
    },
    {
      "type": "text",
      "id": "eyebrow_uk",
      "label": "Eyebrow (UK)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Model Name"
    },
    {
      "type": "text",
      "id": "title_uk",
      "label": "Title (UK)"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "2020+"
    },
    {
      "type": "text",
      "id": "badge_uk",
      "label": "Badge (UK)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Redefined by Urban"
    },
    {
      "type": "text",
      "id": "subtitle_uk",
      "label": "Subtitle (UK)"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Bespoke styling programme designed and hand-assembled with high-quality components."
    },
    {
      "type": "textarea",
      "id": "description_uk",
      "label": "Description (UK)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enquire"
    },
    {
      "type": "text",
      "id": "button_label_uk",
      "label": "Button label (UK)"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_new_tab",
      "label": "Open button in new tab",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "external_image_url",
      "label": "External image URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#1b1b1b"
    },
    {
      "type": "color",
      "id": "copy_color",
      "label": "Body text color",
      "default": "#cfcfcf"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Premium visual carbon components"
        },
        {
          "type": "text",
          "id": "text_uk",
          "label": "Text (UK)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Urban Model Overview",
      "blocks": [
        {
          "type": "highlight"
        },
        {
          "type": "highlight"
        }
      ]
    }
  ]
}
{% endschema %}
