{%- assign is_uk = false -%}
{%- if request.locale.iso_code == 'uk' -%}{%- assign is_uk = true -%}{%- endif -%}

{% liquid
  assign vp_id = 'UrbanVideoPointer-' | append: section.id
  assign video_url = section.settings.video_url | strip
%}

{% if video_url != blank %}
<section id="{{ vp_id }}" class="urban-vp">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Sora:wght@200;300;400;500;600&display=swap');

    #{{ vp_id }} {
      --vp-bg: {{ section.settings.background_color }};
      position: relative;
      width: 100%;
      background: var(--vp-bg);
      overflow: hidden;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #{{ vp_id }} .urban-vp__wrapper {
      position: relative;
      width: 100%;
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: #000;
    }

    #{{ vp_id }} .urban-vp__wrapper.is-full {
      max-width: 100%;
    }

    #{{ vp_id }} .urban-vp__iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 120%;
      height: 120%;
      transform: translate(-50%, -50%);
      border: 0;
      pointer-events: none;
    }

    /* Overlay gradient (optional) */
    #{{ vp_id }} .urban-vp__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, {{ section.settings.overlay_top | divided_by: 100.0 }}) 0%,
        rgba(0, 0, 0, 0) 25%,
        rgba(0, 0, 0, 0) 75%,
        rgba(0, 0, 0, {{ section.settings.overlay_bottom | divided_by: 100.0 }}) 100%
      );
      pointer-events: none;
      z-index: 2;
    }

    /* Optional caption bar */
    #{{ vp_id }} .urban-vp__caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 3;
      text-align: center;
      padding: clamp(16px, 3vw, 40px) clamp(16px, 2vw, 24px);
    }

    #{{ vp_id }} .urban-vp__caption-eyebrow {
      margin: 0 0 6px;
      text-transform: uppercase;
      letter-spacing: 0.35em;
      font-family: 'Sora', sans-serif;
      font-size: clamp(9px, 0.75vw, 11px);
      font-weight: 400;
      color: rgba(255, 255, 255, 0.55);
    }

    #{{ vp_id }} .urban-vp__caption-title {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(18px, 3vw, 42px);
      font-weight: 300;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #fff;
    }

    /* Scroll-reveal */
    #{{ vp_id }} .urban-vp__wrapper {
      opacity: 0;
      transform: scale(0.97);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    #{{ vp_id }}.is-visible .urban-vp__wrapper {
      opacity: 1;
      transform: scale(1);
    }

    #{{ vp_id }} .urban-vp__caption-title {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    /* ── Mobile adaptation ── */
    @media (max-width: 749px) {
      #{{ vp_id }} .urban-vp__wrapper {
        aspect-ratio: 9 / 16;
      }

      #{{ vp_id }} .urban-vp__caption-eyebrow {
        letter-spacing: 0.18em;
      }

      #{{ vp_id }} .urban-vp__iframe {
        width: 100%;
        height: 100%;
        min-width: 300%;
        min-height: 100%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
    }

    @media (min-width: 750px) and (max-width: 989px) {
      #{{ vp_id }} .urban-vp__wrapper {
        aspect-ratio: 4 / 3;
      }

      #{{ vp_id }} .urban-vp__iframe {
        min-width: 180%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ vp_id }} .urban-vp__wrapper {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <div class="urban-vp__wrapper{% if section.settings.full_width %} is-full{% endif %}">
    <iframe
      class="urban-vp__iframe"
      src="{{ video_url }}"
      allow="autoplay; fullscreen; picture-in-picture"
      loading="lazy"
      title="{{ section.settings.caption_title | default: 'Urban Automotive Video' | escape }}"
    ></iframe>

    {% if section.settings.overlay_top > 0 or section.settings.overlay_bottom > 0 %}
      <div class="urban-vp__overlay"></div>
    {% endif %}

    {% if section.settings.caption_title != blank %}
      <div class="urban-vp__caption">
        {% if section.settings.caption_eyebrow != blank %}
          <p class="urban-vp__caption-eyebrow">{% if is_uk and section.settings.caption_eyebrow_uk != blank %}{{ section.settings.caption_eyebrow_uk }}{% else %}{{ section.settings.caption_eyebrow }}{% endif %}</p>
        {% endif %}
        <h3 class="urban-vp__caption-title">{% if is_uk and section.settings.caption_title_uk != blank %}{{ section.settings.caption_title_uk }}{% else %}{{ section.settings.caption_title }}{% endif %}</h3>
      </div>
    {% endif %}
  </div>

  <script>
    (() => {
      const root = document.getElementById('{{ vp_id }}');
      if (!root || root.dataset.init === '1') return;
      root.dataset.init = '1';

      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          root.classList.add('is-visible');
          observer.disconnect();
        }
      }, { threshold: 0.15 });
      observer.observe(root);
    })();
  </script>
</section>
{% endif %}

{% schema %}
{
  "name": "Urban Video Pointer",
  "tag": "section",
  "class": "section section-urban-video-pointer",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Vimeo embed URL",
      "info": "Full player.vimeo.com/video/… URL with autoplay & background params"
    },
    {
      "type": "text",
      "id": "caption_eyebrow",
      "label": "Caption eyebrow"
    },
    {
      "type": "text",
      "id": "caption_eyebrow_uk",
      "label": "Caption eyebrow (UK)"
    },
    {
      "type": "text",
      "id": "caption_title",
      "label": "Caption title"
    },
    {
      "type": "text",
      "id": "caption_title_uk",
      "label": "Caption title (UK)"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width (edge-to-edge)",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 900,
      "max": 2400,
      "step": 100,
      "unit": "px",
      "default": 1900,
      "info": "Only applies when full width is off"
    },
    {
      "type": "range",
      "id": "overlay_top",
      "label": "Top overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "overlay_bottom",
      "label": "Bottom overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Urban Video Pointer"
    }
  ]
}
{% endschema %}
