{%- assign is_uk = false -%}
{%- if request.locale.iso_code == 'uk' -%}{%- assign is_uk = true -%}{%- endif -%}

{% liquid
  assign stack_id = 'UrbanStack-' | append: section.id
%}

<section id="{{ stack_id }}" class="urban-stack">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Oswald:wght@400;500;600&display=swap');

    #{{ stack_id }} {
      --stack-overlay-alpha: {{ section.settings.overlay_opacity | times: 0.01 }};
      --stack-height-mobile: {{ section.settings.mobile_height }}svh;
      --stack-height-desktop: {{ section.settings.desktop_height }}svh;
      --stack-border-color: {{ section.settings.border_color }};
      background: #000;
      color: #fff;
    }

    #{{ stack_id }} .urban-stack__item {
      position: relative;
      min-height: var(--stack-height-mobile);
      border-top: 1px solid var(--stack-border-color);
      overflow: hidden;
      isolation: isolate;
    }

    #{{ stack_id }} .urban-stack__item:last-child {
      border-bottom: 1px solid var(--stack-border-color);
    }

    @media (min-width: 990px) {
      #{{ stack_id }} .urban-stack__item {
        min-height: var(--stack-height-desktop);
      }
    }

    #{{ stack_id }} .urban-stack__media,
    #{{ stack_id }} .urban-stack__media::after {
      position: absolute;
      inset: 0;
    }

    #{{ stack_id }} .urban-stack__media::after {
      content: '';
      z-index: 2;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.68) 80%, rgba(0, 0, 0, 0.9) 100%),
        rgba(0, 0, 0, var(--stack-overlay-alpha));
      pointer-events: none;
    }

    #{{ stack_id }} .urban-stack__image,
    #{{ stack_id }} .urban-stack__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scale(1.24);
      transition: transform 1.25s cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }

    #{{ stack_id }} .urban-stack__veil {
      position: absolute;
      inset: 0;
      z-index: 4;
      background: #000;
      transform: translate3d(0, 0, 0);
      transition: transform 1.05s cubic-bezier(0.22, 1, 0.36, 1);
    }

    #{{ stack_id }} .urban-stack__item.animate .urban-stack__veil {
      transform: translate3d(0, -105%, 0);
    }

    #{{ stack_id }} .urban-stack__item.animate .urban-stack__image,
    #{{ stack_id }} .urban-stack__item.animate .urban-stack__video {
      transform: scale(1);
    }

    #{{ stack_id }} .urban-stack__content {
      position: relative;
      z-index: 5;
      min-height: inherit;
      display: flex;
      align-items: flex-end;
      padding: clamp(18px, 3vw, 48px);
      max-width: min(780px, 100%);
    }

    #{{ stack_id }} .urban-stack__caption {
      transform: translate3d(0, 42px, 0);
      opacity: 0;
      transition: transform 0.85s ease, opacity 0.85s ease;
      transition-delay: 0.15s;
    }

    #{{ stack_id }} .urban-stack__item.animate .urban-stack__caption {
      transform: translate3d(0, 0, 0);
      opacity: 1;
    }

    #{{ stack_id }} .urban-stack__eyebrow {
      margin: 0 0 8px;
      text-transform: uppercase;
      letter-spacing: 0.24em;
      font-size: clamp(11px, 1vw, 13px);
      font-weight: 500;
      opacity: 0.86;
    }

    #{{ stack_id }} .urban-stack__title {
      margin: 0;
      text-transform: uppercase;
      font-family: 'Oswald', 'Montserrat', sans-serif;
      font-size: clamp(31px, 6vw, 88px);
      line-height: 0.94;
      letter-spacing: 0.05em;
      text-wrap: balance;
      font-weight: 500;
    }

    #{{ stack_id }} .urban-stack__subtitle {
      margin: 14px 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-size: clamp(13px, 1.2vw, 18px);
      line-height: 1.55;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 400;
    }

    #{{ stack_id }} .urban-stack__button {
      margin-top: 22px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 11px 20px;
      border: 1px solid #fff;
      background: #fff;
      color: #111;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 11px;
      font-weight: 700;
      transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
    }

    #{{ stack_id }} .urban-stack__button:hover {
      background: transparent;
      color: #fff;
      transform: translateY(-2px);
    }

    #{{ stack_id }} .urban-stack__placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.4;
    }

    /* ── Mobile text adaptation ── */
    @media (max-width: 749px) {
      #{{ stack_id }} .urban-stack__subtitle { letter-spacing: 0.1em; font-size: 9px; }
      #{{ stack_id }} .urban-stack__button { letter-spacing: 0.12em; font-size: 10px; }
    }

    #{{ stack_id }} .urban-stack__title {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    @media (prefers-reduced-motion: reduce) {
      #{{ stack_id }} .urban-stack__caption,
      #{{ stack_id }} .urban-stack__veil,
      #{{ stack_id }} .urban-stack__image,
      #{{ stack_id }} .urban-stack__video {
        transition: none;
      }
    }
  </style>

  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      {% liquid
        assign use_video = false
        if block.settings.media_type == 'video'
          assign use_video = true
        endif

        assign external_image_url = block.settings.external_image_url | strip
        assign resolved_external_image_url = ''
        if external_image_url != blank
          if external_image_url contains '://'
            assign resolved_external_image_url = external_image_url
          else
            assign resolved_external_image_url = external_image_url | file_url
          endif
        endif

        assign external_video_url = block.settings.external_video_url | strip
        assign resolved_external_video_url = ''
        if external_video_url != blank
          if external_video_url contains '://'
            assign resolved_external_video_url = external_video_url
          else
            assign resolved_external_video_url = external_video_url | file_url
          endif
        endif
      %}
      <article
        class="urban-stack__item{% if forloop.first %} animate{% endif %}"
        data-urban-slide
        {{ block.shopify_attributes }}
      >
        <div class="urban-stack__media">
          {% if use_video %}
            {% if block.settings.video != blank %}
              <video
                class="urban-stack__video"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                {% if block.settings.image != blank %}
                  poster="{{ block.settings.image | image_url: width: 2400 }}"
                {% endif %}
              >
                {% for source in block.settings.video.sources %}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {% endfor %}
              </video>
            {% elsif resolved_external_video_url != blank %}
              <video
                class="urban-stack__video"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                {% if block.settings.image != blank %}
                  poster="{{ block.settings.image | image_url: width: 2400 }}"
                {% endif %}
              >
                <source src="{{ resolved_external_video_url }}" type="video/mp4">
              </video>
            {% elsif block.settings.image != blank %}
              <img
                class="urban-stack__image"
                src="{{ block.settings.image | image_url: width: 2800 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif resolved_external_image_url != blank %}
              <img
                class="urban-stack__image"
                src="{{ resolved_external_image_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'urban-stack__placeholder' }}
            {% endif %}
          {% else %}
            {% if block.settings.image != blank %}
              <img
                class="urban-stack__image"
                src="{{ block.settings.image | image_url: width: 2800 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif resolved_external_image_url != blank %}
              <img
                class="urban-stack__image"
                src="{{ resolved_external_image_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'urban-stack__placeholder' }}
            {% endif %}
          {% endif %}
        </div>

        <div class="urban-stack__veil" aria-hidden="true"></div>

        <div class="urban-stack__content">
          <div class="urban-stack__caption" data-urban-fade>
            {% if block.settings.eyebrow != blank %}
              <p class="urban-stack__eyebrow">{% if is_uk and block.settings.eyebrow_uk != blank %}{{ block.settings.eyebrow_uk }}{% else %}{{ block.settings.eyebrow }}{% endif %}</p>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="urban-stack__title">{% if is_uk and block.settings.title_uk != blank %}{{ block.settings.title_uk }}{% else %}{{ block.settings.title }}{% endif %}</h3>
            {% endif %}

            {% if block.settings.subtitle != blank %}
              <p class="urban-stack__subtitle">{% if is_uk and block.settings.subtitle_uk != blank %}{{ block.settings.subtitle_uk }}{% else %}{{ block.settings.subtitle }}{% endif %}</p>
            {% endif %}

            {% if block.settings.button_label != blank and block.settings.button_link != blank %}
              <a
                href="{{ block.settings.button_link }}"
                class="urban-stack__button"
                {% if block.settings.button_new_tab %}
                  target="_blank" rel="noopener noreferrer"
                {% endif %}
              >
                {% if is_uk and block.settings.button_label_uk != blank %}{{ block.settings.button_label_uk }}{% else %}{{ block.settings.button_label }}{% endif %}
              </a>
            {% endif %}
          </div>
        </div>
      </article>
    {% endfor %}
  {% else %}
    <article class="urban-stack__item animate">
      <div class="urban-stack__media">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'urban-stack__placeholder' }}
      </div>
      <div class="urban-stack__veil" aria-hidden="true"></div>
      <div class="urban-stack__content">
        <div class="urban-stack__caption">
          <h3 class="urban-stack__title">Add banner blocks</h3>
          <p class="urban-stack__subtitle">Configure this section in the theme editor.</p>
        </div>
      </div>
    </article>
  {% endif %}

  <script>
    (() => {
      const root = document.getElementById('{{ stack_id }}');
      if (!root || root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const items = root.querySelectorAll('[data-urban-slide]');
      if (!items.length) return;

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('animate'));
        return;
      }

      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('animate');
          obs.unobserve(entry.target);
        });
      }, {
        threshold: 0.18,
        rootMargin: '0px 0px -8% 0px'
      });

      items.forEach((item, index) => {
        if (index === 0) return;
        observer.observe(item);
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Urban Banner Stack",
  "tag": "section",
  "class": "section section-urban-banner-stack",
  "settings": [
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile slide height",
      "min": 45,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop slide height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Slide border color",
      "default": "#1c1c1c"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "default": "image",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (uploaded)"
        },
        {
          "type": "text",
          "id": "external_image_url",
          "label": "External image URL"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (uploaded)"
        },
        {
          "type": "text",
          "id": "external_video_url",
          "label": "External video URL (mp4)"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Redefined by Urban"
        },
        {
          "type": "text",
          "id": "eyebrow_uk",
          "label": "Eyebrow (UK)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vehicle Title"
        },
        {
          "type": "text",
          "id": "title_uk",
          "label": "Title (UK)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Limited build"
        },
        {
          "type": "text",
          "id": "subtitle_uk",
          "label": "Subtitle (UK)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Build Yours"
        },
        {
          "type": "text",
          "id": "button_label_uk",
          "label": "Button label (UK)"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Urban Banner Stack",
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}
