  @@index([status, priority, createdAt], map: "ShopKnowledgeReviewTask_status_priority_idx")
  @@index([knowledgeId, status], map: "ShopKnowledgeReviewTask_knowledge_status_idx")
  @@index([productId, status], map: "ShopKnowledgeReviewTask_product_status_idx")
  @@index([assignedToId, status], map: "ShopKnowledgeReviewTask_assignee_status_idx")
  @@index([aiRunId], map: "ShopKnowledgeReviewTask_aiRun_idx")
