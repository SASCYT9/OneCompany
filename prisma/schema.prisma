// ═══════════════════════════════════════════════════════════════════════════

enum CreditType {
  RETURN_REFUND // issued from a return/RMA
  GOODWILL // manual goodwill adjustment
  PROMOTIONAL // marketing-driven promo credit
  ADJUSTMENT // manual correction
}

enum CreditStatus {
  ACTIVE // available for redemption
  PARTIALLY_USED
  FULLY_USED
  EXPIRED
  VOIDED
}

model ShopCustomerCredit {
  id              String       @id @default(cuid())
  customerId      String
  type            CreditType   @default(GOODWILL)
  status          CreditStatus @default(ACTIVE)
  amount          Decimal      @db.Decimal(12, 2) // total issued
  amountUsed      Decimal      @default(0) @db.Decimal(12, 2)
  currency        String
  reason          String?
  relatedOrderId  String?
  relatedReturnId String?
  expiresAt       DateTime?
  issuedBy        String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  customer    ShopCustomer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  redemptions ShopCustomerCreditRedemption[]

  @@index([customerId, status])
  @@index([currency])
  @@index([expiresAt])
}

model ShopCustomerCreditRedemption {
  id         String   @id @default(cuid())
  creditId   String
  orderId    String?
  amount     Decimal  @db.Decimal(12, 2)
  currency   String
  note       String?
  redeemedBy String?
  redeemedAt DateTime @default(now())

  credit ShopCustomerCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([creditId])
  @@index([orderId])
  @@index([redeemedAt])
}

