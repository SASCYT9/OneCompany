model OpsProject {
  id                String                @id @default(cuid())
  externalId        String                @unique
  title             String
  description       String?
  status            OpsProjectStatus      @default(ACTIVE)
  ownerId           String?
  priority          OpsPriority           @default(NORMAL)
  startDate         DateTime?
  dueDate           DateTime?
  nextAction        String?
  version           Int                   @default(1)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  archivedAt        DateTime?
  owner             AdminUser?            @relation("OpsProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks             OpsTask[]
  comments          OpsComment[]
  knowledgeArticles OpsKnowledgeArticle[]
  telegramContexts  OpsTelegramContext[]

  @@index([status, archivedAt])
  @@index([ownerId, status])
  @@index([priority, dueDate])
}

model OpsTask {
  id                  String                 @id @default(cuid())
  number              Int                    @unique @default(autoincrement())
  externalId          String                 @unique
  projectId           String?
  shopOrderId         String?
  parentTaskId        String?
  title               String
  description         String?
  tags                String[]               @default([])
  status              OpsTaskStatus          @default(INBOX)
  priority            OpsPriority            @default(NORMAL)
  assigneeId          String?
  isShared            Boolean                @default(false)
  executorType        OpsExecutorType        @default(HUMAN)
  dueAt               DateTime?
  nextAction          String?
  definitionOfDone    String?
  blockerType         OpsBlockerType?
  blockerDescription  String?
  retryAt             DateTime?
  attemptCount        Int                    @default(0)
  rank                Decimal                @default(0) @db.Decimal(20, 8)
  sourceType          OpsTaskSourceType      @default(ADMIN)
  sourceId            String?
  sourceKey           String?                @unique
  createdById         String
  version             Int                    @default(1)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  completedAt         DateTime?
  archivedAt          DateTime?
  project             OpsProject?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  shopOrder           ShopOrder?             @relation(fields: [shopOrderId], references: [id], onDelete: SetNull)
  parent              OpsTask?               @relation("OpsTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children            OpsTask[]              @relation("OpsTaskHierarchy")
  assignee            AdminUser?             @relation("OpsTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy           AdminUser              @relation("OpsTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  events              OpsTaskEvent[]
  comments            OpsComment[]
  attachments         OpsTaskAttachment[]
  knowledgeLinks      OpsTaskKnowledgeLink[]
  automationRuns      OpsAutomationRun[]
  approvals           OpsApproval[]
  jobs                OpsJob[]
  telegramDeliveries  OpsTelegramDelivery[]
  opsTelegramContexts OpsTelegramContext[]

  @@index([status, archivedAt, rank])
  @@index([assigneeId, status, dueAt])
  @@index([projectId, status])
  @@index([shopOrderId])
  @@index([parentTaskId])
  @@index([sourceType, sourceId])
}

model OpsTaskEvent {
  id             String            @id @default(cuid())
  taskId         String
  type           OpsTaskEventType
  actorId        String?
  sourceType     OpsTaskSourceType @default(ADMIN)
  sourceId       String?
  idempotencyKey String?
  payload        Json              @default("{}")
  createdAt      DateTime          @default(now())
  task           OpsTask           @relation(fields: [taskId], references: [id], onDelete: Restrict)
  actor          AdminUser?        @relation("OpsTaskEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId, createdAt])
  @@index([sourceType, sourceId])
}

model OpsComment {
  id                String       @id @default(cuid())
  taskId            String?
  projectId         String?
  shopOrderId       String?
  authorId          String
  text              String
  telegramSourceId  String?
  correctsCommentId String?
  createdAt         DateTime     @default(now())
  task              OpsTask?     @relation(fields: [taskId], references: [id], onDelete: Restrict)
  project           OpsProject?  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  shopOrder         ShopOrder?   @relation(fields: [shopOrderId], references: [id], onDelete: Restrict)
  author            AdminUser    @relation("OpsCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  correctsComment   OpsComment?  @relation("OpsCommentCorrection", fields: [correctsCommentId], references: [id], onDelete: Restrict)
  corrections       OpsComment[] @relation("OpsCommentCorrection")

  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
  @@index([shopOrderId, createdAt])
  @@index([authorId, createdAt])
}

model OpsAttachment {
  id                      String              @id @default(cuid())
  inboxItemId             String?
  storageKey              String              @unique
  checksum                String
  mimeType                String
  sizeBytes               BigInt
  fileName                String?
  telegramFileId          String?
  telegramFileUniqueId    String?
  transcription           String?
  transcriptionLanguage   String?
  transcriptionConfidence String?
  transcriptionModel      String?
  state                   OpsAttachmentState  @default(PENDING)
  retentionAt             DateTime?
  pinned                  Boolean             @default(false)
  quarantineReason        String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  inboxItem               OpsInboxItem?       @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)
  tasks                   OpsTaskAttachment[]

  @@index([inboxItemId])
  @@index([checksum])
  @@index([state, retentionAt])
  @@index([telegramFileId])
}

model OpsTaskAttachment {
  taskId       String
  attachmentId String
  attachedById String?
  createdAt    DateTime      @default(now())
  task         OpsTask       @relation(fields: [taskId], references: [id], onDelete: Restrict)
  attachment   OpsAttachment @relation(fields: [attachmentId], references: [id], onDelete: Restrict)
  attachedBy   AdminUser?    @relation("OpsTaskAttachmentActor", fields: [attachedById], references: [id], onDelete: SetNull)

  @@id([taskId, attachmentId])
  @@index([attachmentId])
}

model OpsKnowledgeArticle {
  id                String                 @id @default(cuid())
  slug              String                 @unique
  projectId         String?
  title             String
  excerpt           String?
  contentMarkdown   String
  locale            String                 @default("ru")
  category          String
  brandKey          String?
  tags              String[]               @default([])
  searchText        String                 @default("")
  status            OpsKnowledgeStatus     @default(DRAFT)
  authorId          String
  publishedById     String?
  publishedRevision Int?
  publishedAt       DateTime?
  version           Int                    @default(1)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  archivedAt        DateTime?
  project           OpsProject?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  author            AdminUser              @relation("OpsKnowledgeAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  publishedBy       AdminUser?             @relation("OpsKnowledgePublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  revisions         OpsKnowledgeRevision[]
  taskLinks         OpsTaskKnowledgeLink[]

  @@index([status, locale, category])
  @@index([brandKey, status])
  @@index([updatedAt])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin, map: "OpsKnowledgeArticle_searchText_trgm_idx")
}

model OpsKnowledgeRevision {
  id              String              @id @default(cuid())
  articleId       String
  revision        Int
  status          OpsKnowledgeStatus
  title           String
  excerpt         String?
  contentMarkdown String
  locale          String
  category        String
  brandKey        String?
  tags            String[]            @default([])
  changeNote      String?
  changedById     String
  createdAt       DateTime            @default(now())
  article         OpsKnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Restrict)
  changedBy       AdminUser           @relation("OpsKnowledgeRevisionActor", fields: [changedById], references: [id], onDelete: Restrict)

  @@unique([articleId, revision])
  @@index([articleId, createdAt])
}

model OpsTaskKnowledgeLink {
  taskId    String
  articleId String
  createdAt DateTime            @default(now())
  task      OpsTask             @relation(fields: [taskId], references: [id], onDelete: Restrict)
  article   OpsKnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Restrict)

  @@id([taskId, articleId])
  @@index([articleId])
}

model OpsTelegramUpdate {
  id                 String                @id @default(cuid())
  telegramUpdateId   BigInt                @unique
  chatId             BigInt
  telegramUserId     BigInt?
  messageId          Int?
  messageThreadId    Int?
  updateType         String
  rawUpdate          Json
  isUntrustedForward Boolean               @default(false)
  receivedAt         DateTime              @default(now())
  inboxItem          OpsInboxItem?
  batchItem          OpsTelegramBatchItem?

  @@index([chatId, messageThreadId, receivedAt])
  @@index([telegramUserId, receivedAt])
}

model OpsInboxItem {
  id                  String                   @id @default(cuid())
  telegramUpdateId    String                   @unique
  originalMessage     String?
  transcription       String?
  extractionStatus    OpsInboxExtractionStatus @default(RECEIVED)
  reviewStatus        OpsInboxReviewStatus     @default(PENDING)
  confidence          Decimal?                 @db.Decimal(4, 3)
  summary             String?
  ambiguities         String[]                 @default([])
  requiresApproval    Boolean                  @default(false)
  processingErrorType String?
  processingError     String?
  appliedTaskIds      String[]                 @default([])
  undoExpiresAt       DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  processedAt         DateTime?
  reviewedAt          DateTime?
  telegramUpdate      OpsTelegramUpdate        @relation(fields: [telegramUpdateId], references: [id], onDelete: Restrict)
  telegramBatch       OpsTelegramBatch?
  proposals           OpsInboxProposal[]
  attachments         OpsAttachment[]
  jobs                OpsJob[]
  deliveries          OpsTelegramDelivery[]

  @@index([reviewStatus, createdAt])
  @@index([extractionStatus, createdAt])
}

model OpsTelegramBatch {
  id               String                 @id @default(cuid())
  scopeKey         String                 @unique
  actorAdminUserId String
  chatId           BigInt
  telegramUserId   BigInt
  status           OpsTelegramBatchStatus @default(OPEN)
  mode             OpsTelegramBatchMode?
  itemCount        Int                    @default(0)
  statusMessageId  Int?
  inboxItemId      String?                @unique
  expiresAt        DateTime
  finalizedAt      DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  actor            AdminUser              @relation("OpsTelegramBatchActor", fields: [actorAdminUserId], references: [id], onDelete: Restrict)
  inboxItem        OpsInboxItem?          @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)
  items            OpsTelegramBatchItem[]

  @@index([telegramUserId, status, updatedAt])
  @@index([status, expiresAt])
}

model OpsTelegramBatchItem {
  id               String            @id @default(cuid())
  batchId          String
  telegramUpdateId String            @unique
  ordinal          Int
  createdAt        DateTime          @default(now())
  batch            OpsTelegramBatch  @relation(fields: [batchId], references: [id], onDelete: Restrict)
  telegramUpdate   OpsTelegramUpdate @relation(fields: [telegramUpdateId], references: [id], onDelete: Restrict)

  @@unique([batchId, ordinal])
  @@index([batchId, createdAt])
}

model OpsInboxProposal {
  id            String            @id @default(cuid())
  inboxItemId   String
  kind          OpsProposalKind
  ordinal       Int               @default(0)
  payload       Json
  payloadHash   String
  confidence    Decimal?          @db.Decimal(4, 3)
  status        OpsProposalStatus @default(PENDING)
  appliedTaskId String?
  createdAt     DateTime          @default(now())
  appliedAt     DateTime?
  inboxItem     OpsInboxItem      @relation(fields: [inboxItemId], references: [id], onDelete: Restrict)

  @@unique([inboxItemId, payloadHash])
  @@index([inboxItemId, status, ordinal])
}

model OpsTelegramContext {
  id              String      @id @default(cuid())
  chatId          BigInt
  messageThreadId Int?
  telegramUserId  BigInt?
  projectId       String?
  taskId          String?
  shopOrderId     String?
  active          Boolean     @default(true)
  lastMessageId   Int?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  project         OpsProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task            OpsTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  shopOrder       ShopOrder?  @relation(fields: [shopOrderId], references: [id], onDelete: SetNull)

  @@unique([chatId, messageThreadId, telegramUserId])
  @@index([taskId, active])
  @@index([projectId, active])
  @@index([expiresAt])
}

model OpsTelegramDelivery {
  id                String        @id @default(cuid())
  inboxItemId       String?
  taskId            String?
  chatId            BigInt
  telegramMessageId Int
  kind              String
  createdAt         DateTime      @default(now())
  inboxItem         OpsInboxItem? @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)
  task              OpsTask?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@unique([chatId, telegramMessageId])
  @@index([inboxItemId])
  @@index([taskId])
}

model OpsJob {
  id                String        @id @default(cuid())
  idempotencyKey    String        @unique
  inboxItemId       String?
  taskId            String?
  type              String
  status            OpsJobStatus  @default(QUEUED)
  stage             OpsJobStage   @default(INGEST)
  payload           Json          @default("{}")
  result            Json?
  errorType         String?
  errorMessage      String?
  attempts          Int           @default(0)
  maxAttempts       Int           @default(4)
  availableAt       DateTime      @default(now())
  leaseOwner        String?
  leaseExpiresAt    DateTime?
  heartbeatAt       DateTime?
  cancelRequestedAt DateTime?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  inboxItem         OpsInboxItem? @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)
  task              OpsTask?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([leaseExpiresAt])
  @@index([inboxItemId, status])
  @@index([taskId, status])
}

model OpsIdempotencyRecord {
  id           String   @id @default(cuid())
  scope        String
  key          String
  requestHash  String
  responseBody Json
  statusCode   Int
  resourceType String?
  resourceId   String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([scope, key])
  @@index([expiresAt])
  @@index([resourceType, resourceId])
}

model OpsAutomationRun {
  id             String              @id @default(cuid())
  taskId         String
  automationType String
  status         OpsAutomationStatus @default(QUEUED)
  stage          String?
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(4)
  inputSnapshot  Json
  result         Json?
  errorType      String?
  errorMessage   String?
  requestedById  String?
  budget         Json                @default("{}")
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  task           OpsTask             @relation(fields: [taskId], references: [id], onDelete: Restrict)
  requestedBy    AdminUser?          @relation("OpsAutomationRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([status, createdAt])
}

model OpsApproval {
  id           String            @id @default(cuid())
  taskId       String
  action       String
  payload      Json
  payloadHash  String
  requesterId  String
  approverId   String?
  status       OpsApprovalStatus @default(PENDING)
  decisionNote String?
  expiresAt    DateTime
  approvedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  task         OpsTask           @relation(fields: [taskId], references: [id], onDelete: Restrict)
  requester    AdminUser         @relation("OpsApprovalRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  approver     AdminUser?        @relation("OpsApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])
  @@index([taskId, createdAt])
  @@index([approverId, status])
}

model OpsUsageBucket {
  id             String   @id @default(cuid())
  month          DateTime
  feature        String
  inputTokens    BigInt   @default(0)
  outputTokens   BigInt   @default(0)
  audioSeconds   Int      @default(0)
  costMicros     BigInt   @default(0)
  storageBytes   BigInt   @default(0)
  warningMicros  BigInt   @default(1500000)
  hardStopMicros BigInt   @default(2000000)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([month, feature])
  @@index([month])
}
