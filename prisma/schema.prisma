generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Message {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userName      String
  userEmail     String
  messageText   String
  status        Status         @default(NEW)
  category      Category?
  metadata      Json?
  contactMethod ContactMethod?
  userPhone     String?
  replies       Reply[]

  @@index([createdAt])
}

model Reply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  replyText String
  messageId String
  sentVia   String?  @default("email")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model TelegramUser {
  id            String                 @id @default(cuid())
  telegramId    BigInt                 @unique
  username      String?
  firstName     String?
  lastName      String?
  languageCode  String                 @default("uk")
  isAdmin       Boolean                @default(false)
  isBlocked     Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  lastActiveAt  DateTime               @default(now())
  conversations TelegramConversation[]
  sessions      TelegramSession?

  @@index([telegramId])
}

model TelegramSession {
  id         String       @id @default(cuid())
  telegramId BigInt       @unique
  data       Json         @default("{}")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       TelegramUser @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId])
}

model TelegramConversation {
  id               String       @id @default(cuid())
  telegramId       BigInt
  chatId           BigInt
  messageId        Int?
  conversationType String       @default("general")
  state            Json         @default("{}")
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             TelegramUser @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId])
  @@index([chatId])
}

model TelegramAdmin {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  username    String?
  name        String
  role        String   @default("admin")
  permissions Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([telegramId])
}

model AdminUser {
  id                       String                 @id @default(cuid())
  email                    String                 @unique
  name                     String?
  isActive                 Boolean                @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  passwordHash             String?
  auditLogs                AdminAuditLog[]
  roles                    AdminUserRole[]
  opsProfile               OpsMemberProfile?
  opsProjects              OpsProject[]           @relation("OpsProjectOwner")
  opsTasksCreated          OpsTask[]              @relation("OpsTaskCreator")
  opsTasksAssigned         OpsTask[]              @relation("OpsTaskAssignee")
  opsTaskEvents            OpsTaskEvent[]         @relation("OpsTaskEventActor")
  opsComments              OpsComment[]           @relation("OpsCommentAuthor")
  opsTaskAttachments       OpsTaskAttachment[]    @relation("OpsTaskAttachmentActor")
  opsKnowledgeArticles     OpsKnowledgeArticle[]  @relation("OpsKnowledgeAuthor")
  opsKnowledgePublications OpsKnowledgeArticle[]  @relation("OpsKnowledgePublisher")
  opsKnowledgeRevisions    OpsKnowledgeRevision[] @relation("OpsKnowledgeRevisionActor")
  opsAutomationRuns        OpsAutomationRun[]     @relation("OpsAutomationRequester")
  opsApprovalRequests      OpsApproval[]          @relation("OpsApprovalRequester")
  opsApprovalDecisions     OpsApproval[]          @relation("OpsApprovalApprover")
  opsTelegramBatches       OpsTelegramBatch[]     @relation("OpsTelegramBatchActor")

  @@index([isActive])
}

model AdminRole {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  permissions String[]        @default([])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       AdminUserRole[]

  @@index([key])
}

model AdminUserRole {
  userId     String
  roleId     String
  assignedAt DateTime  @default(now())
  role       AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AdminAuditLog {
  id         String     @id @default(cuid())
  actorId    String?
  actorEmail String
  actorName  String?
  scope      String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime   @default(now())
  actor      AdminUser? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([scope, createdAt])
  @@index([entityType, entityId])
}

model RequestRateLimit {
  key         String   @id
  count       Int      @default(0)
  bucketStart DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
  @@index([bucketStart])
}

model ShopProduct {
  id                       String                      @id @default(cuid())
  slug                     String                      @unique
  sku                      String?
  scope                    String                      @default("auto")
  brand                    String?
  titleUa                  String
  titleEn                  String
  categoryUa               String?
  categoryEn               String?
  shortDescUa              String?
  shortDescEn              String?
  longDescUa               String?
  longDescEn               String?
  leadTimeUa               String?
  leadTimeEn               String?
  stock                    String                      @default("inStock")
  collectionUa             String?
  collectionEn             String?
  priceEur                 Decimal?                    @db.Decimal(12, 2)
  priceEurEurope           Decimal?                    @db.Decimal(12, 2)
  priceUsd                 Decimal?                    @db.Decimal(12, 2)
  priceUah                 Decimal?                    @db.Decimal(12, 2)
  compareAtEur             Decimal?                    @db.Decimal(12, 2)
  compareAtUsd             Decimal?                    @db.Decimal(12, 2)
  compareAtUah             Decimal?                    @db.Decimal(12, 2)
  image                    String?
  gallery                  Json?
  highlights               Json?
  isPublished              Boolean                     @default(true)
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  vendor                   String?
  productType              String?
  productCategory          String?
  tags                     String[]                    @default([])
  status                   ShopCatalogStatus           @default(ACTIVE)
  bodyHtmlUa               String?
  bodyHtmlEn               String?
  seoTitleUa               String?
  seoTitleEn               String?
  seoDescriptionUa         String?
  seoDescriptionEn         String?
  publishedAt              DateTime?
  categoryId               String?
  compareAtEurB2b          Decimal?                    @db.Decimal(12, 2)
  compareAtUahB2b          Decimal?                    @db.Decimal(12, 2)
  compareAtUsdB2b          Decimal?                    @db.Decimal(12, 2)
  priceEurB2b              Decimal?                    @db.Decimal(12, 2)
  priceUahB2b              Decimal?                    @db.Decimal(12, 2)
  priceUsdB2b              Decimal?                    @db.Decimal(12, 2)
  airtableRecordId         String?
  airtableSyncedAt         DateTime?
  height                   Float?
  isDimensionsEstimated    Boolean                     @default(false)
  length                   Float?
  originCountry            String?
  supplier                 String?
  weight                   Float?
  width                    Float?
  bundle                   ShopBundle?
  bundleComponentItems     ShopBundleItem[]            @relation("ShopBundleComponentProduct")
  cartItems                ShopCartItem[]
  orderItems               ShopOrderItem[]
  category                 ShopCategory?               @relation(fields: [categoryId], references: [id])
  collections              ShopProductCollection[]
  media                    ShopProductMedia[]
  metafields               ShopProductMetafield[]
  knowledge                ShopProductKnowledge?
  knowledgeAttributeValues ShopProductAttributeValue[]
  knowledgeChunks          ShopKnowledgeChunk[]
  knowledgeEvidence        ShopKnowledgeEvidence[]
  knowledgeOutboxEvents    ShopKnowledgeOutbox[]
  knowledgeReviewTasks     ShopKnowledgeReviewTask[]
  knowledgeRevisions       ShopKnowledgeRevision[]
  variantKnowledge         ShopVariantKnowledge[]
  vehicleApplications      ShopVehicleApplication[]
  options                  ShopProductOption[]
  variants                 ShopProductVariant[]

  @@index([scope])
  @@index([isPublished])
  @@index([status])
  @@index([categoryId])
  @@index([brand])
  @@index([vendor])
  @@index([slug], map: "ShopProduct_slug_idx")
}

model ShopProductKnowledge {
  id                  String                      @id @default(cuid())
  productId           String                      @unique
  schemaVersion       Int                         @default(1)
  revision            Int                         @default(1)
  activeRevision      Int                         @default(1)
  status              ShopKnowledgeStatus         @default(PENDING)
  completenessScore   Float                       @default(0)
  qualityFlags        String[]                    @default([])
  sourceUpdatedAt     DateTime?
  statusChangedAt     DateTime                    @default(now())
  readyAt             DateTime?
  failedAt            DateTime?
  failureReason       String?                     @db.Text
  vehicleType         String                      @default("unknown")
  makes               String[]                    @default([])
  models              String[]                    @default([])
  chassisCodes        String[]                    @default([])
  yearRanges          Json                        @default("[]")
  engines             String[]                    @default([])
  bodyStyles          String[]                    @default([])
  markets             String[]                    @default([])
  categoryGroup       String?
  powerGainHp         Int?
  torqueGainNm        Int?
  material            String?
  opfGpf              String?
  installationType    String?
  fitmentStatus       String                      @default("needs_review")
  fitmentSource       String                      @default("automatic")
  applications        Json                        @default("[]")
  facts               Json                        @default("{}")
  searchText          String                      @db.Text
  contentHash         String
  embeddingModel      String?
  embedding           Unsupported("vector(768)")?
  indexedAt           DateTime                    @default(now())
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  product             ShopProduct                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues     ShopProductAttributeValue[]
  chunks              ShopKnowledgeChunk[]
  evidence            ShopKnowledgeEvidence[]
  outboxEvents        ShopKnowledgeOutbox[]
  reviewTasks         ShopKnowledgeReviewTask[]
  revisions           ShopKnowledgeRevision[]
  variantKnowledge    ShopVariantKnowledge[]
  vehicleApplications ShopVehicleApplication[]

  @@index([schemaVersion])
  @@index([status, sourceUpdatedAt], map: "ShopProductKnowledge_status_sourceUpdated_idx")
  @@index([status, updatedAt], map: "ShopProductKnowledge_status_updated_idx")
  @@index([vehicleType])
  @@index([categoryGroup])
  @@index([fitmentStatus])
  @@index([contentHash])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin, map: "ShopProductKnowledge_searchText_trgm_idx")
}

model ShopAiConversation {
  id              String           @id @default(cuid())
  locale          String           @default("ua")
  currency        String           @default("EUR")
  state           Json             @default("{}")
  shownProductIds String[]         @default([])
  expiresAt       DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  feedback        ShopAiFeedback[]
  runs            ShopAiRun[]

  @@index([expiresAt])
}

model ShopVehicleApplication {
  id                  String                          @id @default(cuid())
  applicationKey      String
  knowledgeId         String
  productId           String
  variantId           String?
  variantKnowledgeId  String?
  vehicleGenerationId String?
  scope               String                          @default("auto")
  make                String?
  model               String?
  generation          String?
  chassisCode         String?
  yearFrom            Int?
  yearTo              Int?
  engine              String?
  fuel                String?
  bodyStyle           String?
  drivetrain          String?
  transmission        String?
  market              String?
  opfGpf              String?
  categoryGroup       String?
  productKind         String?
  material            String?
  isUniversal         Boolean                         @default(false)
  verificationStatus  ShopKnowledgeVerificationStatus @default(EXTRACTED)
  source              ShopKnowledgeSource             @default(CATEGORY_ADAPTER)
  sourcePriority      Int                             @default(5)
  confidence          Float                           @default(0)
  revision            Int                             @default(1)
  isActive            Boolean                         @default(true)
  verifiedById        String?
  verifiedAt          DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  knowledge           ShopProductKnowledge            @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product             ShopProduct                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant             ShopProductVariant?             @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantKnowledge    ShopVariantKnowledge?           @relation(fields: [variantKnowledgeId], references: [id], onDelete: SetNull)
  vehicleGeneration   VehicleGeneration?              @relation(fields: [vehicleGenerationId], references: [id], onDelete: SetNull, map: "ShopVehicleApplication_generationId_fkey")
  evidence            ShopKnowledgeEvidence[]
  reviewTasks         ShopKnowledgeReviewTask[]

  @@unique([applicationKey, revision])
  @@index([knowledgeId, isActive], map: "ShopVehicleApplication_knowledge_active_idx")
  @@index([productId, isActive], map: "ShopVehicleApplication_product_active_idx")
  @@index([variantId, isActive], map: "ShopVehicleApplication_variant_active_idx")
  @@index([vehicleGenerationId], map: "ShopVehicleApplication_generation_idx")
  @@index([scope, make, model, chassisCode], map: "ShopVehicleApplication_scope_vehicle_idx")
  @@index([make, model, yearFrom, yearTo], map: "ShopVehicleApplication_years_idx")
  @@index([categoryGroup, productKind], map: "ShopVehicleApplication_category_kind_idx")
  @@index([verificationStatus, isActive], map: "ShopVehicleApplication_verification_active_idx")
  @@index([opfGpf, isActive], map: "ShopVehicleApplication_opf_active_idx")
}

model ShopVariantKnowledge {
  id                String                      @id @default(cuid())
  knowledgeId       String
  productId         String
  variantId         String
  sku               String?
  optionValues      Json                        @default("{}")
  facts             Json                        @default("{}")
  searchText        String                      @db.Text
  contentHash       String
  schemaVersion     Int                         @default(2)
  revision          Int                         @default(1)
  status            ShopKnowledgeStatus         @default(PENDING)
  completenessScore Float                       @default(0)
  qualityFlags      String[]                    @default([])
  isActive          Boolean                     @default(true)
  sourceUpdatedAt   DateTime?
  indexedAt         DateTime                    @default(now())
  readyAt           DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  knowledge         ShopProductKnowledge        @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product           ShopProduct                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ShopProductVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
  applications      ShopVehicleApplication[]
  attributeValues   ShopProductAttributeValue[]
  chunks            ShopKnowledgeChunk[]
  evidence          ShopKnowledgeEvidence[]

  @@unique([knowledgeId, variantId, revision], map: "ShopVariantKnowledge_knowledge_variant_revision_key")
  @@index([knowledgeId, status], map: "ShopVariantKnowledge_knowledge_status_idx")
  @@index([productId, isActive], map: "ShopVariantKnowledge_product_active_idx")
  @@index([sku])
  @@index([contentHash])
}

model ShopKnowledgeChunk {
  id                 String                      @id @default(cuid())
  chunkKey           String
  knowledgeId        String
  productId          String
  variantKnowledgeId String?
  locale             String
  sourceField        String
  ordinal            Int
  content            String                      @db.Text
  contentHash        String
  tokenCount         Int?
  embeddingModel     String?
  embedding          Unsupported("vector(768)")?
  revision           Int                         @default(1)
  isActive           Boolean                     @default(true)
  embeddedAt         DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  knowledge          ShopProductKnowledge        @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product            ShopProduct                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantKnowledge   ShopVariantKnowledge?       @relation(fields: [variantKnowledgeId], references: [id], onDelete: SetNull)

  @@unique([chunkKey, revision])
  @@index([knowledgeId, revision, isActive], map: "ShopKnowledgeChunk_knowledge_revision_active_idx")
  @@index([productId, locale, isActive], map: "ShopKnowledgeChunk_product_locale_active_idx")
  @@index([variantKnowledgeId, isActive], map: "ShopKnowledgeChunk_variant_active_idx")
  @@index([locale, sourceField], map: "ShopKnowledgeChunk_locale_source_idx")
  @@index([contentHash])
  @@index([embeddingModel, embeddedAt], map: "ShopKnowledgeChunk_embedding_model_idx")
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, map: "ShopKnowledgeChunk_content_trgm_idx")
}

model ShopProductAttributeDefinition {
  id               String                        @id @default(cuid())
  key              String                        @unique
  nameUa           String
  nameEn           String
  categoryGroups   String[]                      @default([])
  valueType        ShopProductAttributeValueType
  unit             String?
  allowedValues    Json                          @default("[]")
  aliases          Json                          @default("{}")
  isHardConstraint Boolean                       @default(false)
  isFilterable     Boolean                       @default(false)
  isRequired       Boolean                       @default(false)
  isActive         Boolean                       @default(true)
  schemaVersion    Int                           @default(1)
  sortOrder        Int                           @default(0)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  values           ShopProductAttributeValue[]

  @@index([isActive, isFilterable], map: "ShopProductAttributeDefinition_active_filter_idx")
  @@index([isHardConstraint, isRequired], map: "ShopProductAttributeDefinition_hard_required_idx")
}

model ShopProductAttributeValue {
  id                 String                          @id @default(cuid())
  valueKey           String
  definitionId       String
  knowledgeId        String
  productId          String
  variantId          String?
  variantKnowledgeId String?
  valueText          String?
  valueNumber        Decimal?                        @db.Decimal(18, 6)
  valueBoolean       Boolean?
  valueJson          Json?
  normalizedValue    String?
  unit               String?
  source             ShopKnowledgeSource             @default(CATEGORY_ADAPTER)
  verificationStatus ShopKnowledgeVerificationStatus @default(EXTRACTED)
  confidence         Float                           @default(0)
  revision           Int                             @default(1)
  isActive           Boolean                         @default(true)
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt
  definition         ShopProductAttributeDefinition  @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  knowledge          ShopProductKnowledge            @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product            ShopProduct                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant            ShopProductVariant?             @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantKnowledge   ShopVariantKnowledge?           @relation(fields: [variantKnowledgeId], references: [id], onDelete: SetNull)
  evidence           ShopKnowledgeEvidence[]
  reviewTasks        ShopKnowledgeReviewTask[]

  @@unique([valueKey, revision])
  @@index([definitionId, normalizedValue, isActive], map: "ShopProductAttributeValue_definition_value_idx")
  @@index([knowledgeId, revision, isActive], map: "ShopProductAttributeValue_knowledge_revision_idx")
  @@index([productId, isActive], map: "ShopProductAttributeValue_product_active_idx")
  @@index([variantId, isActive], map: "ShopProductAttributeValue_variant_active_idx")
  @@index([verificationStatus, isActive], map: "ShopProductAttributeValue_verification_idx")
}

model VehicleGeneration {
  id             String                   @id @default(cuid())
  generationKey  String                   @unique
  scope          String                   @default("auto")
  make           String
  model          String
  generationName String?
  chassisCode    String?
  yearFrom       Int?
  yearTo         Int?
  bodyStyles     String[]                 @default([])
  markets        String[]                 @default([])
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  aliases        VehicleAlias[]
  applications   ShopVehicleApplication[]

  @@index([scope, make, model])
  @@index([chassisCode])
  @@index([yearFrom, yearTo])
}

model VehicleAlias {
  id                  String              @id @default(cuid())
  vehicleGenerationId String
  alias               String
  normalizedAlias     String
  aliasType           String
  locale              String?
  source              ShopKnowledgeSource @default(CATEGORY_ADAPTER)
  confidence          Float               @default(1)
  isActive            Boolean             @default(true)
  verifiedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vehicleGeneration   VehicleGeneration   @relation(fields: [vehicleGenerationId], references: [id], onDelete: Cascade)

  @@unique([vehicleGenerationId, normalizedAlias], map: "VehicleAlias_generation_alias_key")
  @@index([normalizedAlias, isActive], map: "VehicleAlias_normalizedAlias_active_idx")
  @@index([aliasType, isActive], map: "VehicleAlias_aliasType_active_idx")
}

model ShopKnowledgeEvidence {
  id                   String                     @id @default(cuid())
  evidenceKey          String
  knowledgeId          String
  productId            String
  variantKnowledgeId   String?
  vehicleApplicationId String?
  attributeValueId     String?
  fieldPath            String
  source               ShopKnowledgeSource
  sourceRef            String?
  excerpt              String?                    @db.Text
  sourceHash           String
  confidence           Float                      @default(0)
  extractorVersion     String?
  isManagerVerified    Boolean                    @default(false)
  verifiedById         String?
  verifiedAt           DateTime?
  revision             Int                        @default(1)
  isActive             Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  knowledge            ShopProductKnowledge       @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product              ShopProduct                @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantKnowledge     ShopVariantKnowledge?      @relation(fields: [variantKnowledgeId], references: [id], onDelete: SetNull)
  vehicleApplication   ShopVehicleApplication?    @relation(fields: [vehicleApplicationId], references: [id], onDelete: SetNull)
  attributeValue       ShopProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)

  @@unique([evidenceKey, revision])
  @@index([knowledgeId, fieldPath, isActive], map: "ShopKnowledgeEvidence_knowledge_field_idx")
  @@index([productId, revision], map: "ShopKnowledgeEvidence_product_revision_idx")
  @@index([vehicleApplicationId], map: "ShopKnowledgeEvidence_application_idx")
  @@index([attributeValueId], map: "ShopKnowledgeEvidence_attribute_idx")
  @@index([source, isManagerVerified], map: "ShopKnowledgeEvidence_source_verified_idx")
}

model ShopKnowledgeRevision {
  id            String               @id @default(cuid())
  knowledgeId   String
  productId     String
  revision      Int
  schemaVersion Int                  @default(2)
  status        ShopKnowledgeStatus
  changeType    String
  source        ShopKnowledgeSource
  snapshot      Json
  diff          Json?
  reason        String?              @db.Text
  changedById   String?
  activatedAt   DateTime?
  createdAt     DateTime             @default(now())
  knowledge     ShopProductKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  product       ShopProduct          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([knowledgeId, revision], map: "ShopKnowledgeRevision_knowledge_revision_key")
  @@index([productId, createdAt], map: "ShopKnowledgeRevision_product_created_idx")
  @@index([status, createdAt], map: "ShopKnowledgeRevision_status_created_idx")
}

model ShopKnowledgeCatalogState {
  id          String   @id
  revision    BigInt   @default(0)
  fingerprint String   @db.VarChar(64)
  updatedAt   DateTime @default(now()) @updatedAt
}

model ShopKnowledgeOutbox {
  id          String                    @id @default(cuid())
  dedupeKey   String                    @unique
  knowledgeId String?
  productId   String
  variantId   String?
  eventType   String
  payload     Json                      @default("{}")
  status      ShopKnowledgeOutboxStatus @default(PENDING)
  attempts    Int                       @default(0)
  maxAttempts Int                       @default(8)
  availableAt DateTime                  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  processedAt DateTime?
  lastError   String?                   @db.Text
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  knowledge   ShopProductKnowledge?     @relation(fields: [knowledgeId], references: [id], onDelete: SetNull)
  product     ShopProduct               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ShopProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([status, availableAt], map: "ShopKnowledgeOutbox_status_available_idx")
  @@index([productId, status], map: "ShopKnowledgeOutbox_product_status_idx")
  @@index([variantId, status], map: "ShopKnowledgeOutbox_variant_status_idx")
  @@index([lockedAt])
}

model ShopKnowledgeReviewTask {
  id                   String                      @id @default(cuid())
  knowledgeId          String?
  productId            String?
  variantId            String?
  vehicleApplicationId String?
  attributeValueId     String?
  aiRunId              String?
  feedbackId           String?                     @unique
  taskType             String
  status               ShopKnowledgeReviewStatus   @default(OPEN)
  priority             ShopKnowledgeReviewPriority @default(MEDIUM)
  title                String
  details              Json                        @default("{}")
  reasonCodes          String[]                    @default([])
  assignedToId         String?
  resolvedById         String?
  resolution           Json?
  dueAt                DateTime?
  resolvedAt           DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  knowledge            ShopProductKnowledge?       @relation(fields: [knowledgeId], references: [id], onDelete: SetNull)
  product              ShopProduct?                @relation(fields: [productId], references: [id], onDelete: SetNull)
