generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Message {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userName      String
  userEmail     String
  messageText   String
  status        Status         @default(NEW)
  category      Category?
  metadata      Json?
  contactMethod ContactMethod?
  userPhone     String?
  replies       Reply[]

  @@index([createdAt])
}

model Reply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  replyText String
  messageId String
  sentVia   String?  @default("email")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model TelegramUser {
  id            String                 @id @default(cuid())
  telegramId    BigInt                 @unique
  username      String?
  firstName     String?
  lastName      String?
  languageCode  String                 @default("uk")
  isAdmin       Boolean                @default(false)
  isBlocked     Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  lastActiveAt  DateTime               @default(now())
  conversations TelegramConversation[]
  sessions      TelegramSession?

  @@index([telegramId])
}

model TelegramSession {
  id         String       @id @default(cuid())
  telegramId BigInt       @unique
  data       Json         @default("{}")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       TelegramUser @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId])
}

model TelegramConversation {
  id               String       @id @default(cuid())
  telegramId       BigInt
  chatId           BigInt
  messageId        Int?
  conversationType String       @default("general")
  state            Json         @default("{}")
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             TelegramUser @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)

  @@index([telegramId])
  @@index([chatId])
}

model TelegramAdmin {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  username    String?
  name        String
  role        String   @default("admin")
  permissions Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([telegramId])
}

model AdminUser {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  passwordHash String?
  auditLogs    AdminAuditLog[]
  roles        AdminUserRole[]

  @@index([isActive])
}

model AdminRole {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  permissions String[]        @default([])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       AdminUserRole[]

  @@index([key])
}

model AdminUserRole {
  userId     String
  roleId     String
  assignedAt DateTime  @default(now())
  role       AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AdminAuditLog {
  id         String     @id @default(cuid())
  actorId    String?
  actorEmail String
  actorName  String?
  scope      String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime   @default(now())
  actor      AdminUser? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([scope, createdAt])
  @@index([entityType, entityId])
}

model ShopProduct {
  id                   String                  @id @default(cuid())
  slug                 String                  @unique
  sku                  String?
  scope                String                  @default("auto")
  brand                String?
  titleUa              String
  titleEn              String
  categoryUa           String?
  categoryEn           String?
  shortDescUa          String?
  shortDescEn          String?
  longDescUa           String?
  longDescEn           String?
  leadTimeUa           String?
  leadTimeEn           String?
  stock                String                  @default("inStock")
  collectionUa         String?
  collectionEn         String?
  priceEur             Decimal?                @db.Decimal(12, 2)
  priceUsd             Decimal?                @db.Decimal(12, 2)
  priceUah             Decimal?                @db.Decimal(12, 2)
  compareAtEur         Decimal?                @db.Decimal(12, 2)
  compareAtUsd         Decimal?                @db.Decimal(12, 2)
  compareAtUah         Decimal?                @db.Decimal(12, 2)
  image                String?
  gallery              Json?
  highlights           Json?
  isPublished          Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  bodyHtmlEn           String?
  bodyHtmlUa           String?
  categoryId           String?
  compareAtEurB2b      Decimal?                @db.Decimal(12, 2)
  compareAtUahB2b      Decimal?                @db.Decimal(12, 2)
  compareAtUsdB2b      Decimal?                @db.Decimal(12, 2)
  priceEurB2b          Decimal?                @db.Decimal(12, 2)
  priceUahB2b          Decimal?                @db.Decimal(12, 2)
  priceUsdB2b          Decimal?                @db.Decimal(12, 2)
  productCategory      String?
  productType          String?
  publishedAt          DateTime?
  seoDescriptionEn     String?
  seoDescriptionUa     String?
  seoTitleEn           String?
  seoTitleUa           String?
  status               ShopCatalogStatus       @default(ACTIVE)
  tags                 String[]                @default([])
  vendor               String?
  weight               Float?
  length               Float?
  width                Float?
  height               Float?
  isDimensionsEstimated Boolean @default(false)
  supplier             String?
  originCountry        String?
  airtableRecordId     String?
  airtableSyncedAt     DateTime?
  bundle               ShopBundle?
  bundleComponentItems ShopBundleItem[]        @relation("ShopBundleComponentProduct")
  cartItems            ShopCartItem[]
  orderItems           ShopOrderItem[]
  category             ShopCategory?           @relation(fields: [categoryId], references: [id])
  collections          ShopProductCollection[]
  media                ShopProductMedia[]
  metafields           ShopProductMetafield[]
  options              ShopProductOption[]
  variants             ShopProductVariant[]

  @@index([slug])
  @@index([scope])
  @@index([isPublished])
  @@index([status])
  @@index([categoryId])
}

model ShopBrandLogistics {
  id                 String   @id @default(cuid())
  brandName          String   @unique
  originZone         String   @default("USA") // Where does this brand ship from? (USA, EU, etc)
  ratePerKg          Float    @default(0)     // Base cost per kg
  volumetricDivisor  Float    @default(5000)  // 5000 for air, 4000 for ground maybe
  volSurchargePerKg  Float    @default(0)     // Penalty for volumetric vs actual difference
  baseFee            Float    @default(0)     // Flat handling fee per brand item
  isActive           Boolean  @default(true) // Should custom rule apply?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@index([brandName])
  @@index([isActive])
}

model ShopCollection {
  id            String                  @id @default(cuid())
  handle        String                  @unique
  titleUa       String
  titleEn       String
  brand         String?
  descriptionUa String?
  descriptionEn String?
  heroImage     String?
  isPublished   Boolean                 @default(true)
  isUrban       Boolean                 @default(false)
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  products      ShopProductCollection[]

  @@index([handle])
  @@index([isUrban, sortOrder])
  @@index([isPublished])
}

model ShopCategory {
  id            String         @id @default(cuid())
  slug          String         @unique
  titleUa       String
  titleEn       String
  descriptionUa String?
  descriptionEn String?
  parentId      String?
  isPublished   Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        ShopCategory?  @relation("ShopCategoryTree", fields: [parentId], references: [id])
  children      ShopCategory[] @relation("ShopCategoryTree")
  products      ShopProduct[]

  @@index([slug])
  @@index([parentId, sortOrder])
  @@index([isPublished, sortOrder])
}

model ShopProductCollection {
  productId    String
  collectionId String
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  collection   ShopCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      ShopProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, sortOrder])
}

model ShopProductMedia {
  id        String        @id @default(cuid())
  productId String
  mediaType ShopMediaType @default(IMAGE)
  src       String
  altText   String?
  position  Int           @default(1)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  product   ShopProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, position])
}

model ShopProductOption {
  id        String      @id @default(cuid())
  productId String
  name      String
  position  Int
  values    String[]    @default([])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position])
  @@index([productId])
}

model ShopProductVariant {
  id                   String              @id @default(cuid())
  productId            String
  title                String?
  sku                  String?
  position             Int                 @default(1)
  option1Value         String?
  option1LinkedTo      String?
  option2Value         String?
  option2LinkedTo      String?
  option3Value         String?
  option3LinkedTo      String?
  grams                Int?
  inventoryTracker     String?
  inventoryQty         Int                 @default(0)
  inventoryPolicy      ShopInventoryPolicy @default(CONTINUE)
  fulfillmentService   String?
  priceEur             Decimal?            @db.Decimal(12, 2)
  priceUsd             Decimal?            @db.Decimal(12, 2)
  priceUah             Decimal?            @db.Decimal(12, 2)
  priceEurB2b          Decimal?            @db.Decimal(12, 2)
  priceUsdB2b          Decimal?            @db.Decimal(12, 2)
  priceUahB2b          Decimal?            @db.Decimal(12, 2)
  compareAtEur         Decimal?            @db.Decimal(12, 2)
  compareAtUsd         Decimal?            @db.Decimal(12, 2)
  compareAtUah         Decimal?            @db.Decimal(12, 2)
  compareAtEurB2b      Decimal?            @db.Decimal(12, 2)
  compareAtUsdB2b      Decimal?            @db.Decimal(12, 2)
  compareAtUahB2b      Decimal?            @db.Decimal(12, 2)
  requiresShipping     Boolean             @default(true)
  taxable              Boolean             @default(true)
  barcode              String?
  image                String?
  weightUnit           String?
  taxCode              String?
  costPerItem          Decimal?            @db.Decimal(12, 2)
  isDefault            Boolean             @default(false)
  weight               Float?
  length               Float?
  width                Float?
  height               Float?
  isDimensionsEstimated Boolean @default(false)
  originCountry        String?
  airtableRecordId     String?
  airtableSyncedAt     DateTime?
  turn14Id             String?             @unique
  turn14Hash           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  bundleComponentItems ShopBundleItem[]
  cartItems            ShopCartItem[]
  product              ShopProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position])
  @@index([productId])
  @@index([sku])
}

model ShopBundle {
  id        String           @id @default(cuid())
  productId String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  product   ShopProduct      @relation(fields: [productId], references: [id], onDelete: Cascade)
  items     ShopBundleItem[]

  @@index([createdAt])
}

model ShopBundleItem {
  id                 String              @id @default(cuid())
  bundleId           String
  componentProductId String
  componentVariantId String?
  quantity           Int                 @default(1)
  position           Int                 @default(1)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bundle             ShopBundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  componentProduct   ShopProduct         @relation("ShopBundleComponentProduct", fields: [componentProductId], references: [id])
  componentVariant   ShopProductVariant? @relation(fields: [componentVariantId], references: [id])

  @@unique([bundleId, position])
  @@index([bundleId, position])
  @@index([componentProductId])
  @@index([componentVariantId])
}

model ShopProductMetafield {
  id        String      @id @default(cuid())
  productId String
  namespace String
  key       String
  value     String
  valueType String      @default("single_line_text_field")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, namespace, key])
  @@index([productId])
}

model ShopSettings {
  key                       String   @id
  b2bVisibilityMode         String   @default("approved_only")
  defaultB2bDiscountPercent Decimal? @db.Decimal(5, 2)
  defaultCurrency           String   @default("EUR")
  enabledCurrencies         String[] @default(["EUR", "USD", "UAH"])
  currencyRates             Json     @default("{\"EUR\": 1, \"UAH\": 1, \"USD\": 1}")
  shippingZones             Json     @default("[]")
  brandShippingRules        Json?    @default("[]")
  taxRegions                Json     @default("[]")
  orderNotificationEmail    String?
  b2bNotes                  String?
  fopCompanyName            String?
  fopIban                   String?
  fopBankName               String?
  fopEdrpou                 String?
  fopDetails                String?
  stripeEnabled             Boolean  @default(false)
  whiteBitEnabled           Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  regionalPricingRules      Json     @default("[]")
  showTaxesIncludedNotice   Boolean  @default(false)
}

model ShopCustomer {
  id                 String                @id @default(cuid())
  email              String                @unique
  firstName          String
  lastName           String
  phone              String?
  companyName        String?
  vatNumber          String?
  group              CustomerGroup         @default(B2C)
  b2bDiscountPercent Decimal?              @db.Decimal(5, 2)
  isActive           Boolean               @default(true)
  notes              String?
  preferredLocale    String                @default("en")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  carts              ShopCart[]
  account            ShopCustomerAccount?
  addresses          ShopCustomerAddress[]
  orders             ShopOrder[]

  @@index([group, isActive])
  @@index([createdAt])
}

model ShopCustomerAccount {
  id              String       @id @default(cuid())
  customerId      String       @unique
  passwordHash    String
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  plainPassword   String?
  customer        ShopCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model ShopCustomerAddress {
  id                String       @id @default(cuid())
  customerId        String
  label             String
  line1             String
  line2             String?
  city              String
  region            String?
  postcode          String?
  country           String
  isDefaultShipping Boolean      @default(false)
  isDefaultBilling  Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  customer          ShopCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model ShopCart {
  id         String         @id @default(cuid())
  token      String         @unique
  customerId String?
  currency   String         @default("EUR")
  locale     String         @default("en")
  expiresAt  DateTime
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  customer   ShopCustomer?  @relation(fields: [customerId], references: [id])
  items      ShopCartItem[]

  @@index([customerId])
  @@index([expiresAt])
}

model ShopCartItem {
  id          String              @id @default(cuid())
  cartId      String
  productId   String?
  variantId   String?
  productSlug String
  quantity    Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  cart        ShopCart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     ShopProduct?        @relation(fields: [productId], references: [id])
  variant     ShopProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model ShopOrder {
  id                      String                 @id @default(cuid())
  orderNumber             String                 @unique
  status                  OrderStatus            @default(PENDING_REVIEW)
  email                   String
  customerName            String
  phone                   String?
  shippingAddress         Json
  currency                String
  subtotal                Decimal                @db.Decimal(12, 2)
  shippingCost            Decimal                @db.Decimal(12, 2)
  taxAmount               Decimal                @db.Decimal(12, 2)
  total                   Decimal                @db.Decimal(12, 2)
  viewToken               String                 @unique
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  customerGroupSnapshot   CustomerGroup          @default(B2C)
  customerId              String?
  paymentMethod           String                 @default("FOP")
  pricingSnapshot         Json?
  stripeCheckoutSessionId String?
  amountPaid              Float                  @default(0)
  deliveryMethod          String?
  invoiceGenerated        Boolean                @default(false)
  invoiceUrl              String?
  paymentStatus           String                 @default("UNPAID")
  shippingCalculatedCost  Float?
  ttnNumber               String?
  hutkoPaymentId          String?
  customer                ShopCustomer?          @relation(fields: [customerId], references: [id])
  items                   ShopOrderItem[]
  events                  ShopOrderStatusEvent[]
  shipments               ShopShipment[]

  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model ShopOrderItem {
  id          String       @id @default(cuid())
  orderId     String
  productSlug String
  productId   String?
  title       String
  quantity    Int          @default(1)
  price       Decimal      @db.Decimal(12, 2)
  total       Decimal      @db.Decimal(12, 2)
  image       String?
  createdAt   DateTime     @default(now())
  variantId   String?
  order       ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     ShopProduct? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model ShopOrderStatusEvent {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  actorType  String       @default("admin")
  actorName  String?
  note       String?
  createdAt  DateTime     @default(now())
  order      ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([toStatus])
}

model ShopShipment {
  id             String         @id @default(cuid())
  orderId        String
  carrier        String
  serviceLevel   String?
  trackingNumber String
  trackingUrl    String?
  status         ShipmentStatus @default(LABEL_CREATED)
  notes          String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          ShopOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([status])
  @@index([trackingNumber])
}

model ShopImportTemplate {
  id                  String                 @id @default(cuid())
  name                String
  supplierName        String?
  sourceType          String                 @default("shopify_csv")
  notes               String?
  fieldMapping        Json?
  defaultConflictMode ShopImportConflictMode @default(UPDATE)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  jobs                ShopImportJob[]

  @@index([sourceType, createdAt])
}

model ShopImportJob {
  id               String                 @id @default(cuid())
  sourceType       String                 @default("shopify_csv")
  sourceFilename   String?
  supplierName     String?
  templateId       String?
  action           ShopImportAction
  status           ShopImportStatus
  conflictMode     ShopImportConflictMode @default(UPDATE)
  actorEmail       String
  actorName        String?
  totalRows        Int                    @default(0)
  productsCount    Int                    @default(0)
  variantsCount    Int                    @default(0)
  validProducts    Int                    @default(0)
  createdCount     Int                    @default(0)
  updatedCount     Int                    @default(0)
  skippedCount     Int                    @default(0)
  errorCount       Int                    @default(0)
  columns          Json?
  templateSnapshot Json?
  summary          Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  template         ShopImportTemplate?    @relation(fields: [templateId], references: [id])
  rowErrors        ShopImportRowError[]

  @@index([action, createdAt])
  @@index([status, createdAt])
  @@index([sourceType, createdAt])
  @@index([templateId])
}

model ShopImportRowError {
  id        String        @id @default(cuid())
  jobId     String
  rowNumber Int
  handle    String?
  message   String
  payload   Json?
  createdAt DateTime      @default(now())
  job       ShopImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowNumber])
}

model Turn14BrandMarkup {
  id           String    @id @default(cuid())
  brandId      String    @unique
  brandName    String
  markupPct    Float     @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncAt   DateTime?
  syncMessage  String?
  syncProgress Int       @default(0)
  syncStatus   String    @default("idle")
  syncTotal    Int       @default(0)

  @@index([brandName])
}

model Turn14Item {
  id          String          @id
  partNumber  String
  brand       String
  brandId     String?
  name        String
  category    String?
  subcategory String?
  price       Float
  inStock     Boolean         @default(false)
  thumbnail   String?
  attributes  Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  fitments    Turn14Fitment[]

  @@index([brand])
  @@index([category])
  @@index([partNumber])
  @@index([name])
}

model Turn14Fitment {
  id       String     @id @default(cuid())
  itemId   String
  year     String
  make     String
  model    String
  submodel String?
  item     Turn14Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([make])
  @@index([year, make, model])
}

model CustomerMarkup {
  id           String   @id @default(cuid())
  customerId   String   @unique
  customerName String
  markupPct    Float    @default(25)
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerName])
}

model CrmCustomer {
  id            String     @id @default(cuid())
  airtableId    String     @unique
  name          String
  businessName  String?
  tags          String[]   @default([])
  totalProfit   Float      @default(0)
  totalSales    Float      @default(0)
  totalPayments Float      @default(0)
  balance       Float      @default(0)
  whoOwes       String?
  syncedAt      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  email         String?
  orders        CrmOrder[]

  @@index([name])
}

model CrmOrder {
  id              String         @id @default(cuid())
  airtableId      String         @unique
  number          Int
  name            String
  orderStatus     String         @default("")
  paymentStatus   String         @default("")
  orderDate       DateTime?
  completionDate  DateTime?
  purchaseCost    Float          @default(0)
  additionalCosts Float          @default(0)
  fullCost        Float          @default(0)
  totalAmount     Float          @default(0)
  clientTotal     Float          @default(0)
  profit          Float          @default(0)
  marginality     Float          @default(0)
  tag             String         @default("")
  allShipped      String         @default("Нет")
  itemCount       Int            @default(0)
  syncedAt        DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  customerId      String?
  customer        CrmCustomer?   @relation(fields: [customerId], references: [id])
  items           CrmOrderItem[]

  @@index([number])
  @@index([orderStatus])
  @@index([customerId])
}

model CrmOrderItem {
  id                 String    @id @default(cuid())
  airtableId         String    @unique
  positionNumber     Int       @default(0)
  productName        String    @default("")
  brand              String    @default("")
  category           String    @default("")
  quantity           Int       @default(1)
  rrpPerUnit         Float     @default(0)
  clientPricePerUnit Float     @default(0)
  clientTotal        Float     @default(0)
  actualSalePrice    Float     @default(0)
  actualSaleTotal    Float     @default(0)
  purchasePrice      Float     @default(0)
  purchaseTotal      Float     @default(0)
  profitPerItem      Float     @default(0)
  marginality        Float     @default(0)
  status             String    @default("")
  source             String    @default("")
  productId          String?
  sku                String?
  imageUrl           String?
  syncedAt           DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  orderId            String?
  order              CrmOrder? @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model StockProduct {
  id          String   @id @default(cuid())
  distributor String
  partNumber  String
  name        String
  brand       String   @default("")
  category    String   @default("")
  description String   @default("")
  price       Float?
  retailPrice Float?
  markupPct   Float    @default(25)
  inStock     Boolean  @default(true)
  thumbnail   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([distributor, partNumber])
  @@index([distributor])
  @@index([brand])
  @@index([name])
}

