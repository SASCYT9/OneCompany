// ═══════════════════════════════════════════════════════════════════════════
// Discount Engine — codes, conditions, scope, usage tracking
// ═══════════════════════════════════════════════════════════════════════════

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum DiscountScope {
  CART
  PRODUCT
  COLLECTION
  SHIPPING
}

enum DiscountStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

model ShopDiscount {
  id          String         @id @default(cuid())
  code        String         @unique
  description String?
  type        DiscountType
  scope       DiscountScope  @default(CART)
  status      DiscountStatus @default(DRAFT)

  // Value: percentage 0–100 OR fixed amount in currency, OR free-shipping flag (value ignored)
  value    Decimal @default(0) @db.Decimal(12, 2)
  currency String? // null = applies to all currencies (percentage); set for FIXED_AMOUNT

  // Conditions (all optional — null = no constraint)
  minOrderValue  Decimal? @db.Decimal(12, 2)
  customerGroups Json? // Array<CustomerGroup> | null
  productIds     Json? // Array<string> for PRODUCT scope
  collectionIds  Json? // Array<string> for COLLECTION scope
  excludeOnSale  Boolean  @default(false)

  // Buy-X-Get-Y rules (only used when type = BUY_X_GET_Y)
  buyQuantity    Int?
  getQuantity    Int?
  getDiscountPct Decimal? @db.Decimal(5, 2)

  // Usage limits
  usageLimit        Int? // total redemptions across all customers
  usageLimitPerUser Int? // per-customer cap
  usageCount        Int  @default(0)

  // Validity window
  validFrom  DateTime?
  validUntil DateTime?

  // Author/admin metadata
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions ShopDiscountRedemption[]

  @@index([status])
  @@index([validFrom, validUntil])
  @@index([code])
}

model ShopDiscountRedemption {
  id         String   @id @default(cuid())
  discountId String
  orderId    String? // nullable: null while in cart, set on order creation
  customerId String?
  email      String? // for guest tracking
  amount     Decimal  @db.Decimal(12, 2) // how much value the discount removed
  currency   String
  redeemedAt DateTime @default(now())

  discount ShopDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@index([discountId])
  @@index([orderId])
  @@index([customerId])
  @@index([redeemedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// Returns / RMA Workflow — request → approve → in-transit → received → inspected → refunded
// ═══════════════════════════════════════════════════════════════════════════

enum ReturnStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  INSPECTED
  REFUNDED
  REJECTED
}

enum ReturnReason {
  WRONG_ITEM
  DAMAGED
  DEFECTIVE
  NOT_AS_DESCRIBED
  CHANGED_MIND
  ORDERING_ERROR
  OTHER
}

enum ReturnRefundMethod {
  STRIPE_REFUND
  STORE_CREDIT
  BANK_TRANSFER
  REPLACEMENT
  NONE
}

model ShopOrderReturn {
  id               String             @id @default(cuid())
  rmaNumber        String             @unique
  orderId          String
  status           ReturnStatus       @default(REQUESTED)
  reason           ReturnReason       @default(OTHER)
  reasonNote       String?
  refundMethod     ReturnRefundMethod @default(NONE)
  refundAmount     Decimal            @default(0) @db.Decimal(12, 2)
  currency         String
  restockOnReceive Boolean            @default(true)
  customerNote     String?
  adminNote        String?

  // External refund reference (Stripe charge id, etc.)
  externalRefundId String?
  refundedAt       DateTime?

  // Workflow timestamps
  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  inTransitAt DateTime?
  receivedAt  DateTime?
  inspectedAt DateTime?
  rejectedAt  DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order ShopOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items ShopOrderReturnItem[]

  @@index([orderId])
  @@index([status])
  @@index([rmaNumber])
  @@index([createdAt])
}

model ShopOrderReturnItem {
  id                String        @id @default(cuid())
  returnId          String
  orderItemId       String
  productSlug       String
  variantId         String?
  title             String
  quantity          Int           @default(1)
  unitPrice         Decimal       @db.Decimal(12, 2)
  refundAmount      Decimal       @db.Decimal(12, 2)
  reason            ReturnReason?
  conditionNote     String?
  restockedAt       DateTime?
  restockLocationId String?

  return ShopOrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
}

