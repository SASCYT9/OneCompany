{
	"nodes":[
		{"id":"hub","type":"text","text":"# 🏢 One Company SHOP\n\n**Загальний прогрес: 85%**\n4/6 фаз завершено\n\n`B2B + B2C` · `Next.js` · `Prisma` · `PostgreSQL`\n\n🔗 [[Home]]","x":-190,"y":-90,"width":380,"height":180,"color":"6"},
		{"id":"cat-phases","type":"text","text":"## 📋 Фази Розробки\n6 фаз · A→F","x":-110,"y":-330,"width":220,"height":70,"color":"5"},
