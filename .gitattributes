# Only track files larger than 100MB with LFS
public/videos/fi-exhaust.mp4 filter=lfs diff=lfs merge=lfs -text
# Track 3D models with LFS
*.glb filter=lfs diff=lfs merge=lfs -text
# Treat other mp4s as binary but NOT LFS
*.mp4 binary

# Prisma stores migration checksums byte-for-byte. Keep SQL line endings stable
# across Windows workstations so Git does not create false checksum drift.
prisma/migrations/**/migration.sql text eol=lf

