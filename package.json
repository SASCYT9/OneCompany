{
  "name": "onecompany-3d",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true, force:true}); console.log('.next removed');\"",
    "dev": "next dev",
    "prisma:generate": "prisma generate && node scripts/cleanup-prisma-temp-engines.js",
    "build": "tsx scripts/prebuild-shop-snapshot.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm run prisma:generate",
    "db:migrate": "prisma migrate deploy",
    "test:shop:unit": "tsx --test tests/shop/unit/**/*.test.ts",
    "test:shop:integration": "tsx --test tests/shop/integration/**/*.test.ts",
    "test:shop:e2e": "tsx --test tests/shop/e2e/**/*.test.ts",
    "test:shop": "npm run test:shop:unit && npm run test:shop:integration && npm run test:shop:e2e",
    "predeploy-check": "node scripts/predeploy-check.js",
    "deploy:prod": "npm run predeploy-check && vercel --prod",
    "bot": "node scripts/telegram-bot-polling.js",
    "translate:gemini-custom": "tsx scripts/gemini-translate-cli.ts",
    "gemini": "gemini",
    "shop:translate-atomic-en:dry": "node scripts/translate-atomic-products-en.js --dry-run",
    "shop:translate-atomic-en": "node scripts/translate-atomic-products-en.js --commit",
    "shop:urban:reconcile:dry": "tsx scripts/reconcile-urban-catalog.ts --dry-run",
    "shop:urban:reconcile": "tsx scripts/reconcile-urban-catalog.ts --commit",
    "shop:urban:gp-only:dry": "tsx scripts/reconcile-urban-catalog.ts --dry-run --gp-only",
    "shop:urban:gp-only": "tsx scripts/reconcile-urban-catalog.ts --commit --gp-only",
    "shop:urban:ua-copy:dry": "tsx scripts/curate-urban-ua-copy.ts --dry-run",
    "shop:urban:ua-copy": "tsx scripts/curate-urban-ua-copy.ts --commit",
    "media:migrate:dry": "tsx scripts/migrate-runtime-media-to-blob.ts --dry-run",
    "media:migrate": "tsx scripts/migrate-runtime-media-to-blob.ts --commit",
    "shop:brabus:images-to-blob:dry": "tsx --env-file=.env.local scripts/migrate-brabus-images-to-blob.ts",
    "shop:brabus:images-to-blob": "tsx --env-file=.env.local scripts/migrate-brabus-images-to-blob.ts --commit",
    "shop:ipe:import:dry": "tsx scripts/import-ipe-catalog.ts --dry-run",
    "shop:ipe:import": "tsx scripts/import-ipe-catalog.ts --commit",
    "seo:structure-check": "tsx scripts/seo-structure-audit.ts --baseUrl=https://onecompany.global --locales=ua,en --maxDepth=4",
    "fetch:logos": "tsx scripts/fetch-brand-logos.ts",
    "fetch:logos:js": "node scripts/fetch-brand-logos.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,yml,yaml,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,yml,yaml,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "download-logos": "tsx scripts/download-logos.ts",
    "download-logos-free": "tsx scripts/download-logos-free.ts",
    "download-logos-advanced": "tsx scripts/download-logos-advanced.ts",
    "download-missing-logos": "tsx scripts/download-missing-logos.ts",
    "check-missing-logos": "tsx scripts/check-missing-logos.ts",
    "upgrade-all-small-logos": "tsx scripts/upgrade-all-small-logos.ts",
    "sync:instagram-blog": "node scripts/sync-instagram-blog.mjs"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@google/generative-ai": "^0.24.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/hydrate": "^1.6.0",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/parse-mode": "^2.3.0",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@gsap/react": "^2.1.2",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@react-spring/three": "^10.0.3",
    "@react-spring/web": "^10.0.3",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.6.1",
