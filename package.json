    "@react-three/rapier": "^2.1.0",
    "@studio-freight/lenis": "^1.0.42",
    "@types/animejs": "^3.1.13",
    "@use-gesture/react": "^10.3.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.3",
    "animejs": "^4.4.1",
    "axios": "^1.15.0",
    "camera-controls": "^3.1.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "framer-motion": "^12.38.0",
    "grammy": "^1.42.0",
    "gsap": "^3.15.0",
    "immer": "^10.2.0",
    "lenis": "^1.3.23",
    "leva": "^0.10.1",
    "lucide-react": "^0.553.0",
    "maath": "^0.10.8",
    "next": "^16.2.4",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "p-limit": "^4.0.0",
    "papaparse": "^5.5.3",
    "postprocessing": "^6.39.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-email": "^5.0.4",
    "react-facebook-pixel": "^1.0.4",
    "react-hook-form": "^7.66.0",
    "react-spring": "^10.0.3",
    "resend": "^6.4.2",
    "sass": "^1.99.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.0",
    "tunnel-rat": "^0.1.2",
    "valtio": "^2.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@google/gemini-cli": "^0.35.1",
    "@types/node": "^25",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19",
    "@types/three": "^0.181.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.20",
    "canvas": "^3.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "image-size": "^2.0.2",
    "lint-staged": "^15.2.10",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.41",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@isaacs/brace-expansion": "5.0.1",
    "follow-redirects": "1.16.0",
    "glob": "13.0.6",
    "immutable": "5.1.5",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4",
    "preact": "10.29.1",
    "socket.io-parser": "4.2.6"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 90",
    "Safari >= 14",
    "Edge >= 90",
    "not dead",
    "not op_mini all"
  ]
}
