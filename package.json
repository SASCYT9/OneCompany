{
  "name": "onecompany-3d",
  "version": "0.1.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true, force:true}); console.log('.next removed');\"",
    "dev": "next dev",
    "prisma:generate": "prisma generate && node scripts/cleanup-prisma-temp-engines.js",
    "build": "node scripts/build-site.mjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm run prisma:generate",
    "db:migrate": "prisma migrate deploy",
    "ops:phase0:audit": "tsx scripts/operations/phase0-audit.ts",
    "ops:phase0:backup": "tsx scripts/operations/create-phase0-backup.ts",
    "ops:phase0:verify-restore": "tsx scripts/operations/verify-phase0-restore.ts",
    "ops:migrations:replay": "tsx scripts/operations/verify-migration-replay.ts",
    "ops:test:persistence": "tsx scripts/operations/verify-migration-replay.ts --integration",
    "ops:demo": "node scripts/operations/start-local-demo.mjs",
    "ops:lab:prepare": "node scripts/operations/prepare-local-lab-env.mjs",
    "ops:lab:seed": "tsx --env-file=.env.ops-lab.local scripts/operations/seed-local-lab.ts",
    "ops:lab:dev": "node scripts/operations/start-local-lab.mjs",
    "ops:lab:webhook-gateway": "node --env-file=.env.ops-lab.local scripts/operations/start-local-webhook-gateway.mjs",
    "ops:lab:resume-inbox": "tsx --env-file=.env.ops-lab.local scripts/operations/resume-local-lab-inbox.ts",
    "ops:blob:verify": "tsx --env-file=.env.ops-lab.local scripts/operations/verify-ops-blob.ts",
    "ops:state:verify": "tsx --env-file=.env.ops-lab.local scripts/operations/verify-local-ops-state.ts",
    "ops:prod:check": "node scripts/operations/check-production-readiness.mjs --mode=prepare",
    "ops:prod:check:canary": "node scripts/operations/check-production-readiness.mjs --mode=canary",
    "ops:prod:check:live": "node scripts/operations/check-production-readiness.mjs --mode=live",
    "test:ops": "tsx --test tests/shop/unit/adminAccess.test.ts tests/shop/unit/adminAuthCurrentAccess.test.ts tests/shop/unit/adminEntityPermissions.test.ts tests/shop/unit/adminLegacyRoutePermissions.test.ts tests/shop/unit/adminLogin.test.ts tests/shop/unit/adminNavigation.test.ts tests/shop/unit/adminProductEditorContext.test.ts tests/shop/unit/adminProxyAuth.test.ts tests/shop/unit/adminRouteAccess.test.ts tests/shop/unit/adminUsersOpsProfile.test.ts tests/shop/unit/adminUsersPermissions.test.ts tests/shop/unit/adminUsersRoute.test.ts tests/shop/unit/operationsAutomationApprovalApi.test.ts tests/shop/unit/operationsCore.test.ts tests/shop/unit/operationsJobsAiMedia.test.ts tests/shop/unit/operationsMigrationContracts.test.ts tests/shop/unit/operationsSystem.test.ts tests/shop/unit/operationsTelegramIntake.test.ts tests/shop/unit/operationsUi.test.ts tests/shop/unit/proxySourceContract.test.ts tests/shop/unit/shopKnowledgeV2CatalogState.test.ts",
    "test:shop:unit": "tsx --test tests/shop/unit/**/*.test.ts",
    "test:seo:contracts": "tsx --test tests/shop/unit/shopStorefrontRouting.test.ts tests/shop/unit/pagedListingMetadata.test.ts tests/shop/unit/shopSeoAudit.test.ts tests/shop/unit/shopCatalogOutageSemantics.test.ts",
    "verify:seo:artifacts": "tsx scripts/verify-seo-build-artifacts.ts",
    "test:shop:integration": "tsx --test tests/shop/integration/**/*.test.ts",
    "test:shop:e2e": "tsx --test tests/shop/e2e/**/*.test.ts",
    "test:shop": "npm run test:shop:unit && npm run test:shop:integration && npm run test:shop:e2e",
    "predeploy-check": "node scripts/predeploy-check.js",
    "deploy:prod": "npm run predeploy-check && vercel --prod",
    "bot": "node scripts/telegram-bot-polling.js",
    "translate:gemini-custom": "tsx scripts/gemini-translate-cli.ts",
    "gemini": "gemini",
    "shop:translate-atomic-en:dry": "node scripts/translate-atomic-products-en.js --dry-run",
    "shop:translate-atomic-en": "node scripts/translate-atomic-products-en.js --commit",
    "shop:atomic-eu-prices:dry": "tsx scripts/sync-atomic-eu-prices.ts --dry-run",
    "shop:atomic-eu-prices": "tsx scripts/sync-atomic-eu-prices.ts --commit",
    "shop:akrapovic-ducati-prices:dry": "tsx scripts/sync-amsducati-akrapovic-prices.ts",
    "shop:akrapovic-ducati-prices": "tsx scripts/sync-amsducati-akrapovic-prices.ts --commit",
    "shop:akrapovic-ducati-catalog:dry": "tsx scripts/sync-amsducati-akrapovic-catalog.ts",
    "shop:akrapovic-ducati-catalog": "tsx scripts/sync-amsducati-akrapovic-catalog.ts --commit",
    "shop:urban:reconcile:dry": "tsx scripts/reconcile-urban-catalog.ts --dry-run",
    "shop:urban:reconcile": "tsx scripts/reconcile-urban-catalog.ts --commit",
    "shop:urban:gp-only:dry": "tsx scripts/reconcile-urban-catalog.ts --dry-run --gp-only",
    "shop:urban:gp-only": "tsx scripts/reconcile-urban-catalog.ts --commit --gp-only",
    "shop:urban:ua-copy:dry": "tsx scripts/curate-urban-ua-copy.ts --dry-run",
    "shop:urban:ua-copy": "tsx scripts/curate-urban-ua-copy.ts --commit",
    "shop:fitment:audit": "tsx --env-file=.env.local scripts/audit-shop-fitment.ts",
    "shop:search:benchmark": "tsx --env-file=.env.local scripts/benchmark-shop-vehicle-search.ts",
    "shop:knowledge:dry": "tsx --env-file=.env.local scripts/sync-shop-product-knowledge.ts",
    "shop:knowledge:sync": "tsx --env-file=.env.local scripts/sync-shop-product-knowledge.ts --commit",
    "shop:knowledge:embed:dry": "tsx --env-file=.env.local scripts/embed-shop-product-knowledge.ts",
    "shop:knowledge:embed": "tsx --env-file=.env.local scripts/embed-shop-product-knowledge.ts --commit",
    "shop:knowledge:v2:dry": "tsx --env-file=.env.local scripts/backfill-shop-knowledge-v2.ts",
    "shop:knowledge:v2:backfill": "tsx --env-file=.env.local scripts/backfill-shop-knowledge-v2.ts --commit",
    "shop:knowledge:v2:embed:dry": "tsx --env-file=.env.local scripts/embed-shop-knowledge-chunks.ts",
    "shop:knowledge:v2:embed": "tsx --env-file=.env.local scripts/embed-shop-knowledge-chunks.ts --commit",
    "shop:knowledge:v2:embed:recover": "tsx --env-file=.env.local scripts/embed-shop-knowledge-chunks.ts --commit",
    "shop:ai:eval": "tsx --env-file=.env.local scripts/eval-shop-ai.ts",
    "shop:ai:eval:release": "tsx --env-file=.env.local scripts/eval-shop-ai.ts --release-gate",
    "shop:ai:release-guard": "tsx scripts/check-shop-ai-v2-release-activation.ts",
    "media:migrate:dry": "tsx scripts/migrate-runtime-media-to-blob.ts --dry-run",
    "media:migrate": "tsx scripts/migrate-runtime-media-to-blob.ts --commit",
    "shop:brabus:images-to-blob:dry": "tsx --env-file=.env.local scripts/migrate-brabus-images-to-blob.ts",
    "shop:brabus:images-to-blob": "tsx --env-file=.env.local scripts/migrate-brabus-images-to-blob.ts --commit",
    "shop:ipe:import:dry": "tsx scripts/import-ipe-catalog.ts --dry-run",
    "shop:ipe:import": "tsx scripts/import-ipe-catalog.ts --commit",
    "seo:structure-check": "tsx scripts/seo-structure-audit.ts --baseUrl=https://onecompany.global --locales=ua,en --maxDepth=4",
    "fetch:logos": "tsx scripts/fetch-brand-logos.ts",
    "fetch:logos:js": "node scripts/fetch-brand-logos.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,yml,yaml,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,mdx,yml,yaml,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "download-logos": "tsx scripts/download-logos.ts",
    "download-logos-free": "tsx scripts/download-logos-free.ts",
    "download-logos-advanced": "tsx scripts/download-logos-advanced.ts",
    "download-missing-logos": "tsx scripts/download-missing-logos.ts",
    "check-missing-logos": "tsx scripts/check-missing-logos.ts",
    "upgrade-all-small-logos": "tsx scripts/upgrade-all-small-logos.ts",
    "sync:instagram-blog": "node scripts/sync-instagram-blog.mjs"
  },
