# Environment variables for OneCompany (do NOT commit your real secrets)
# Copy this file to .env.local and fill in values.
# .env.local is git-ignored by default.
#
# Quickest way for OneCompany contributors: `vercel env pull .env.local`
# (after `vercel link` to sascyt9s-projects/one-company).

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL via Prisma)
# ─────────────────────────────────────────────────────────────────────────────
# Pooled connection URL — used at runtime by the app
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL=
# Direct (non-pooled) URL — required by Prisma migrations and several scripts
# in scripts/ that bypass the pooler. If unset, prisma.config.ts falls back to DATABASE_URL.
DIRECT_URL=

# ─────────────────────────────────────────────────────────────────────────────
# ADMIN PANEL & API
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=                 # Password for /admin panel (use a strong one in production)
ADMIN_SESSION_SECRET=           # Random 32+ char string for signing admin session cookies
NEXTAUTH_SECRET=                # NextAuth signing key — REQUIRED in production

# Two distinct admin secrets — they protect DIFFERENT endpoints, do not merge:
ADMIN_API_SECRET=               # Bearer for /api/telegram/setup, /admins, /webhook-grammy?action=set
ADMIN_SECRET=                   # Bearer for media admin (mediaStore), /telegram/cron, /telegram/analytics

# Default admin identity (used when DB has no user override)
ADMIN_EMAIL=                    # default: admin@onecompany.local
ADMIN_NAME=                     # default: One Company Admin

# Cron secret (used by /api/telegram/cron and Vercel-cron-triggered routes)
CRON_SECRET=

# Admin local backup retention (days). Optional; default is hardcoded.
ADMIN_LOCAL_BACKUP_RETENTION=

# Dev-only — DO NOT set in production
ALLOW_DEV_ADMIN_PASSWORD_FALLBACK=
ENABLE_DEV_AUTH_BYPASS=

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT
# ─────────────────────────────────────────────────────────────────────────────
# Create bot via @BotFather: /newbot -> obtain token
# Forward any message from your chat to @userinfobot to get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                              # Main chat ID for user messages forwarding (e.g., -1001234567890)
TELEGRAM_AUTO_CHAT_ID=                         # Chat ID for auto inquiries from contact form
TELEGRAM_MOTO_CHAT_ID=                         # Chat ID for moto inquiries from contact form
TELEGRAM_SHOP_ORDERS_CHAT_ID=                  # Chat ID for shop order notifications
TELEGRAM_CONTACT_TOPIC_CHAT_ID=                # Optional: forum group to mirror contact form messages
TELEGRAM_CONTACT_TOPIC_THREAD_ID=              # Optional: forum topic (message_thread_id), e.g. 3 for "Контакт"
TELEGRAM_ADMIN_IDS=                            # Comma-separated Telegram user IDs treated as superadmins
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=            # Optional: TWA init-data freshness window (default 86400)

# Webhook protection (highly recommended): long random string, configured with secret_token
TELEGRAM_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SITE / PUBLIC URLs
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=                          # Your domain without protocol (e.g., onecompany.global)
NEXT_PUBLIC_SITE_URL=https://onecompany.global # Full site URL for sharing (used in Telegram /dashboard command)

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS & SEO
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=          # GSC verification code (just the value from <meta>)
NEXT_PUBLIC_GA_ID=G-1CQVYW3WK7                 # Google Analytics 4 Measurement ID
NEXT_PUBLIC_CLARITY_ID=                        # Microsoft Clarity ID
NEXT_PUBLIC_FB_PIXEL_ID=                       # Facebook Pixel ID (optional)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=onecompany.example # Optional Plausible analytics

# Google Analytics 4 Data API (server-side, used by /admin dashboard KPI cards)
# Steps:
#   1. In Google Cloud Console, enable "Google Analytics Data API".
#   2. Create a service account, generate a JSON key.
#   3. In GA4 → Admin → Property Access Management, grant the service-account email "Viewer".
#   4. Paste the entire JSON key (single line) into GOOGLE_APPLICATION_CREDENTIALS_JSON.
#   5. Set GA4_PROPERTY_ID to the numeric property id (Admin → Property Settings).
# Both vars are required; if either is missing, the dashboard falls back to "—".
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────────────────────────────────────
# Sign up at resend.com, verify domain, get API key
RESEND_API_KEY=
RESEND_FROM_EMAIL=                             # Optional: overrides EMAIL_FROM for shop emails
EMAIL_FROM=contact@onecompany.com              # Sender address (must be verified in Resend)
EMAIL_AUTO=auto@onecompany.com                 # Recipient for auto inquiries
EMAIL_MOTO=moto@onecompany.com                 # Recipient for moto inquiries

# ─────────────────────────────────────────────────────────────────────────────
# SHOP — payments & orders
# ─────────────────────────────────────────────────────────────────────────────
WHITEPAY_SLUG=onecompany                       # Whitepay merchant slug
WHITEPAY_TOKEN=                                # Whitepay API token (server-side)
WHITEPAY_WEBHOOK_TOKEN=                        # Whitepay webhook signature token

# ─────────────────────────────────────────────────────────────────────────────
# SHOPIFY (mirrored storefront)
# ─────────────────────────────────────────────────────────────────────────────
SHOPIFY_ADMIN_TOKEN=                           # Custom App admin API token
SHOPIFY_CLIENT_ID=                             # OAuth app client id
SHOPIFY_CLIENT_SECRET=                         # OAuth app client secret
SHOPIFY_WEBHOOK_SECRET=                        # HMAC verification secret for Shopify webhooks

# ─────────────────────────────────────────────────────────────────────────────
# AIRTABLE (legacy CRM source)
# ─────────────────────────────────────────────────────────────────────────────
AIRTABLE_PAT=                                  # Personal access token
AIRTABLE_BASE_ID=app70wZOSKU5xSoGX             # Base ID for One Company CRM

# ─────────────────────────────────────────────────────────────────────────────
# TURN14 (parts distributor)
# ─────────────────────────────────────────────────────────────────────────────
TURN14_CLIENT_ID=                              # Used by /api/admin/turn14-sync (daily cron in vercel.json)
TURN14_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# BRAND-SPECIFIC INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────
FIEXHAUST_APP_SECRET=                          # Fi Exhaust app shared secret
FIEXHAUST_WEBHOOK_SECRET=                      # Fi Exhaust webhook signature
KWSUSPENSION_APP_SECRET=                       # KW Suspensions app shared secret
KWSUSPENSION_WEBHOOK_SECRET=                   # KW Suspensions webhook signature
BRABUS_LOCAL_ASSETS_DEPLOYED=                  # Feature flag: serve Brabus assets from /public when deployed

# ─────────────────────────────────────────────────────────────────────────────
# AUTOMATION / CRM / WEBHOOKS
# ─────────────────────────────────────────────────────────────────────────────
# n8n Automation webhook integration
# Docker compose: http://n8n:5678/webhook/contact-request
# Local dev: http://localhost:5678/webhook/contact-request
AUTOMATION_ENDPOINT=http://localhost:5678/webhook/contact-request
AUTOMATION_API_KEY=                            # Shared secret configured in n8n webhook node
CRM_WEBHOOK_URL=                               # External CRM sink for new orders/leads

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS (translations, descriptions)
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                                # Google Gemini (used by scripts/translate-gemini.mjs)
PERPLEXITY_API_KEY=                            # Perplexity API for research-style prompts

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE (image / asset delivery)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME MEDIA (Vercel Blob)
# ─────────────────────────────────────────────────────────────────────────────
# Create one public store (e.g. one-company-media) and pull linked env vars
# with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=
NEXT_IMAGE_REMOTE_HOSTS=                       # e.g. abc123.public.blob.vercel-storage.com

# ─────────────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────────────
# - Never commit .env.local to git. Use environment-specific secret stores in
#   production (Vercel/Netlify/Azure/etc.).
# - Rotate tokens immediately if leaked. Change the value here and redeploy.
# - For Google Workspace email: configure MX records in GoDaddy DNS
#   (see docs/google-workspace-setup.md).
# - For custom domain: point nameservers or A/CNAME records to your host
#   (see docs/godaddy-domain-setup.md).
# - For Telegram setup details: see docs/telegram-bot-setup.md.
